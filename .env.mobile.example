# Optional local values for mobile smoke tests.
# Copy to .env.mobile.local and keep real device IDs/signing details uncommitted.

# Android physical device or emulator serial. Equivalent to ANDROID_SERIAL.
# NVPN_ANDROID_SERIAL=emulator-5554
# Optional local Android smoke setup. Use this when you only need to verify the
# Android OS VPN/TUN path and do not have a private invite fixture available.
# NVPN_ANDROID_DEBUG_CREATE_NETWORK=1
# NVPN_ANDROID_DEBUG_NETWORK_NAME=Android smoke
# Optional for trusted local test devices; taps Android's system VPN consent OK
# button if the prompt appears during `--vpn-cycle`.
# NVPN_ANDROID_ACCEPT_VPN_DIALOG=1
# Android --vpn-cycle copies the app-private Rust runtime-state JSON after the
# OS VPN network becomes active, validates native TUN counter fields, and saves
# Android VPN interface `ip -s link` counters under artifacts/mobile-android.
# NVPN_ANDROID_RUNTIME_STATE_WAIT_SECS=12
# NVPN_ANDROID_RUNTIME_STATE_MAX_AGE_SECS=60
# Android --vpn-cycle also sends a small shell ping probe toward a non-local
# 10.44/16 address and requires tunPacketsRead to increase by at least that
# many packets. Ping output is saved next to the runtime-state artifact so peer
# probe targets preserve packet loss and RTT jitter evidence.
# NVPN_ANDROID_TUN_PACKET_PROBE=1
# NVPN_ANDROID_TUN_PACKET_PROBE_TARGET=10.44.255.254
# NVPN_ANDROID_TUN_PACKET_PROBE_COUNT=4

# iOS physical device identifier for xcrun devicectl.
# NVPN_IOS_DEVICE=00000000-0000000000000000
# Build/install the current development-signed iphoneos app before a physical
# device smoke. Requires Xcode signing access for the app and packet tunnel IDs.
# NVPN_IOS_INSTALL=1
# NVPN_IOS_ALLOW_PROVISIONING_UPDATES=1
# NVPN_IOS_XCODEBUILD_QUIET=1
# Optional local iOS VPN/Packet Tunnel smoke setup without peer dataplane coverage.
# NVPN_IOS_DEBUG_CREATE_NETWORK=1
# NVPN_IOS_DEBUG_NETWORK_NAME=iOS smoke
# NVPN_IOS_VPN_START_WAIT_SECS=12
# iOS --vpn-cycle sends a small routed UDP burst and requires tunPacketsRead to increase.

# Optional simulator selection. Set the ID when Xcode has duplicate simulator
# names, or set a full xcodebuild destination string.
# NVPN_IOS_SIMULATOR_ID=00000000-0000-0000-0000-000000000000
# NVPN_IOS_DESTINATION=platform=iOS Simulator,id=00000000-0000-0000-0000-000000000000

# Bundle/package overrides for locally signed builds.
# NVPN_ANDROID_PACKAGE=org.nostrvpn.app
# NVPN_ANDROID_ACTIVITY=org.nostrvpn.app/.MainActivity
# NVPN_IOS_BUNDLE_ID=fi.siriusbusiness.nvpn
# NVPN_IOS_PACKET_TUNNEL_BUNDLE_ID=fi.siriusbusiness.nvpn.PacketTunnel
# NVPN_IOS_APP_GROUP_IDENTIFIER=group.fi.siriusbusiness.nvpn

# iOS signing/profile knobs used by release/profile scripts. scripts/ios-build
# maps NVPN_IOS_TEAM_ID to xcodebuild DEVELOPMENT_TEAM.
# NVPN_IOS_TEAM_ID=ABCDE12345
# NVPN_IOS_DEVICE_UDIDS=00000000-0000000000000000
