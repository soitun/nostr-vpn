{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nostr VPN",
  "mainBinaryName": "nostr-vpn-gui",
  "version": "0.3.17",
  "identifier": "to.iris.nvpn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run prepare:sidecar:debug && pnpm dev",
    "beforeBuildCommand": "pnpm run prepare:sidecar:release && pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Nostr VPN",
        "width": 980,
        "height": 860,
        "minWidth": 760,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: tauri: asset: https: wss: ws:; connect-src 'self' tauri: https: wss: ws: http://127.0.0.1:* http://localhost:*; img-src 'self' data: blob: https: http://127.0.0.1:* http://localhost:*"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nvpn"]
      },
      "mobile": [
        {
          "scheme": ["nvpn"],
          "appLink": false
        }
      ]
    },
    "hashtree-updater": {
      "reference": "htree://npub1xdhnr9mrv47kkrn95k6cwecearydeh8e895990n3acntwvmgk2dsdeeycm/releases%2Fnostr-vpn/latest"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/nvpn"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
