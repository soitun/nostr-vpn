<Window x:Class="NostrVpn.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NostrVpn.Windows.Controls"
        Title="Nostr VPN"
        Width="920"
        Height="640"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/nostr-vpn.ico"
        Background="{StaticResource WindowBg}">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource SidebarBg}" Padding="16">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top">
          <Button Style="{StaticResource NavButton}" Command="{Binding ShowDevicesCommand}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE772;" />
              <TextBlock Grid.Column="1" Text="Devices" />
              <Ellipse Grid.Column="2" Width="8" Height="8" Fill="{StaticResource Danger}" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="{Binding HasIncomingJoinRequests, Converter={StaticResource BoolToVisibility}}" />
            </Grid>
          </Button>
          <Button Style="{StaticResource NavButton}" Command="{Binding ShowExitNodesCommand}">
            <StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B8;" Width="24" /><TextBlock Text="Exit Nodes" /></StackPanel>
          </Button>
          <Button Style="{StaticResource NavButton}" Command="{Binding ShowSettingsCommand}">
            <StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Width="24" /><TextBlock Text="Settings" /></StackPanel>
          </Button>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" Background="#FFFFFF" CornerRadius="8" Padding="12" Cursor="Hand" MouseLeftButtonUp="NetworkSwitcher_Click">
          <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Right" FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="10" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="6,0,0,0" />
            <StackPanel>
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="{Binding ShownNetworkStatusBrush}" VerticalAlignment="Center" Margin="0,0,7,0" Visibility="{Binding ShowNetworkStatusDot, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="{Binding ActiveNetworkName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
              </StackPanel>
              <TextBlock Text="{Binding HeroSubtitle}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0" />
            </StackPanel>
          </DockPanel>
        </Border>
      </DockPanel>
    </Border>

    <DockPanel Grid.Column="1">
      <Border DockPanel.Dock="Top" Padding="24,18" Background="{StaticResource WindowBg}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <Ellipse Width="10" Height="10" Fill="{Binding ShownNetworkStatusBrush}" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="{Binding ShowNetworkStatusDot, Converter={StaticResource BoolToVisibility}}" />
              <TextBlock Text="{Binding ActiveNetworkName}" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
            </StackPanel>
            <TextBlock Text="{Binding VpnStatusText}" Foreground="{Binding VpnStatusBrush}" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleVpnCommand}" Content="{Binding VpnButtonText}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Top" Padding="24,4" Background="#F2F4F7" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
            <CheckBox Content="Install automatically" IsChecked="{Binding AutoInstallUpdates, Mode=TwoWay}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,12,0" />
            <Button Content="Install" Command="{Binding InstallUpdateCommand}" MinWidth="72" MinHeight="26" Padding="10,3" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE896;" FontSize="13" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding UpdateStripeText}" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </StackPanel>
        </DockPanel>
      </Border>

      <ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Width="{Binding ActualWidth, ElementName=ContentScroll}">
        <StackPanel Margin="24,0,24,24">
          <Border Style="{StaticResource Card}" Visibility="{Binding Notice, Converter={StaticResource NonEmptyStringToVisibility}}">
            <TextBlock Text="{Binding Notice}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
          </Border>

          <StackPanel Visibility="{Binding HasActiveNetwork, Converter={StaticResource InverseBoolToVisibility}}">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Create Network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding NetworkNameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <Button Grid.Column="1" Content="Create" Command="{Binding CreateNetworkCommand}" />
                </Grid>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Join Network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding InviteInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Paste" Command="{Binding PasteInviteCommand}" Margin="0,0,8,0" />
                    <Button Content="From QR file" Command="{Binding ImportQrImageCommand}" />
                  </StackPanel>
                </Grid>
                <Expander Header="Add manually" Margin="0,10,0,0" IsExpanded="{Binding ManualJoinExpanded, Mode=TwoWay}">
                  <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Both sides have to add each other. Get the admin's Device ID and the network ID from them, then have the admin add your Device ID on their Add device page." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBox Text="{Binding ManualJoinAdminId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4">
                      <TextBox.Style>
                        <Style TargetType="TextBox">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding ManualJoinAdminInvalid}" Value="True">
                              <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
                              <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Not a valid device ID" Foreground="{StaticResource Danger}" FontSize="11" Margin="0,0,0,4" Visibility="{Binding ManualJoinAdminErrorVisibility}" />
                    <TextBox Text="{Binding ManualJoinMeshId, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <Button Content="Add" Command="{Binding ManualAddNetworkCommand}" HorizontalAlignment="Left" />
                  </StackPanel>
                </Expander>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                  <Button DockPanel.Dock="Right" Content="{Binding NearbyDiscoveryButtonText}" Command="{Binding ToggleNearbyDiscoveryCommand}" />
                  <TextBlock Text="Nearby invites" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl ItemsSource="{Binding State.LanPeers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Join" Tag="{Binding Invite}" Click="JoinLanPeer_Click" />
                        <StackPanel>
                          <TextBlock Text="{Binding NodeName}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding NetworkName}" Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No nearby invites yet" Foreground="{StaticResource TextSecondary}" Visibility="{Binding NoNearbyInvitesNoticeVisibility}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=Devices}">
            <Grid Visibility="{Binding HasActiveNetwork, Converter={StaticResource BoolToVisibility}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                  <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Command="{Binding ShowAddDeviceCommand}" Content="+ Add device" Visibility="{Binding ActiveNetwork.LocalIsAdmin, Converter={StaticResource BoolToVisibility}}" />
                    <StackPanel>
                      <TextBlock Text="Devices" FontSize="18" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding HeroSubtitle}" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                  </DockPanel>

                  <ListBox ItemsSource="{Binding ActiveNetwork.Participants}"
                           SelectedItem="{Binding SelectedParticipant, Mode=TwoWay}"
                           BorderThickness="0"
                           Background="Transparent"
                           Margin="0,14,0,0"
                           HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                      <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                      </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border>
                          <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource Card}">
                              <Setter Property="Padding" Value="12" />
                              <Setter Property="Margin" Value="0,0,0,8" />
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" Value="True">
                                  <Setter Property="Background" Value="{StaticResource AccentSoft}" />
                                  <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </Border.Style>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="16" />
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Fill="{StaticResource TextSecondary}" VerticalAlignment="Top" Margin="0,6,0,0" />
                            <StackPanel Grid.Column="1">
                              <WrapPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="This device" Margin="8,0,0,0" Foreground="{StaticResource Ok}" Visibility="{Binding IsSelf, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="Admin" Margin="8,0,0,0" Foreground="{StaticResource Accent}" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="Exit" Margin="8,0,0,0" Foreground="{StaticResource Warn}" Visibility="{Binding OffersExitNode, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Text="via mesh" Margin="8,0,0,0" Foreground="{StaticResource TextSecondary}" Visibility="{Binding IsFipsRouted, Converter={StaticResource BoolToVisibility}}" />
                              </WrapPanel>
                              <TextBlock Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0">
                                <Run Text="{Binding CleanTunnelIp, Mode=OneWay}" /><Run Text="  " /><Run Text="{Binding ConnectivityStateText, Mode=OneWay}" />
                              </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2" Content="Copy" Tag="{Binding Npub}" Click="CopyPeer_Click" Margin="8,0,0,0" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                  <StackPanel Visibility="{Binding SelectedParticipant, Converter={StaticResource ObjectToVisibility}}">
                    <DockPanel LastChildFill="True">
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource TextSecondary}" Margin="0,6,7,0" />
                        <TextBlock Text="{Binding SelectedParticipant.ConnectivityStateText}" Foreground="{StaticResource TextSecondary}" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="{Binding SelectedParticipant.DisplayName}" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,8,0,0">
                          <TextBlock Text="This device" Foreground="{StaticResource Ok}" Margin="0,0,10,0" Visibility="{Binding SelectedParticipant.IsSelf, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="Admin" Foreground="{StaticResource Accent}" Margin="0,0,10,0" Visibility="{Binding SelectedParticipant.IsAdmin, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="Exit" Foreground="{StaticResource Warn}" Margin="0,0,10,0" Visibility="{Binding SelectedParticipant.OffersExitNode, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="direct connection" Foreground="{StaticResource Ok}" Margin="0,0,10,0" Visibility="{Binding SelectedParticipant.IsFipsDirect, Converter={StaticResource BoolToVisibility}}" />
                          <TextBlock Text="via mesh" Foreground="{StaticResource TextSecondary}" Margin="0,0,10,0" Visibility="{Binding SelectedParticipant.IsFipsRouted, Converter={StaticResource BoolToVisibility}}" />
                        </WrapPanel>
                      </StackPanel>
                    </DockPanel>

                    <Grid Margin="0,20,0,0" Visibility="{Binding SelectedParticipantCanRename, Converter={StaticResource BoolToVisibility}}">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="Name" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                      <TextBox x:Name="AliasInput" Grid.Column="1" Text="{Binding SelectedParticipant.MagicDnsAlias, Mode=OneWay}" Margin="0,0,8,0" />
                      <Button Grid.Column="2" Content="Save" Tag="{Binding SelectedParticipant}" Click="SetParticipantAlias_Click" Margin="0,0,8,0" />
                      <Button Grid.Column="3" Content="Admin" Tag="{Binding SelectedParticipant}" Click="ToggleAdmin_Click" Margin="0,0,8,0" Visibility="{Binding SelectedParticipantCanManage, Converter={StaticResource BoolToVisibility}}" />
                      <Button Grid.Column="4" Content="Remove" Tag="{Binding SelectedParticipant}" Click="RemoveParticipant_Click" Visibility="{Binding SelectedParticipantCanManage, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,18,0,0">
                      <StackPanel>
                        <TextBlock Text="Addresses" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                          </Grid.RowDefinitions>
                          <TextBlock Text="MagicDNS" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                          <TextBlock Grid.Column="1" Text="{Binding SelectedParticipant.MagicDnsDisplay}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                          <TextBlock Grid.Row="1" Text="VPN IP" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                          <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedParticipant.CleanTunnelIp}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                          <TextBlock Grid.Row="2" Text="Device ID" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                          <DockPanel Grid.Row="2" Grid.Column="1" LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding SelectedParticipant.Npub}" Click="CopyPeer_Click" Margin="8,0,0,0" />
                            <TextBlock Text="{Binding SelectedParticipant.Npub}" TextTrimming="CharacterEllipsis" />
                          </DockPanel>
                        </Grid>
                      </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,18,0,0">
                      <StackPanel>
                        <TextBlock Text="Connectivity" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <UniformGrid Columns="3" Rows="2">
                          <StackPanel Margin="0,0,12,12">
                            <TextBlock Text="Role" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.RoleText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Margin="0,0,12,12">
                            <TextBlock Text="State" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.ConnectivityStateText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Margin="0,0,12,12">
                            <TextBlock Text="FIPS path" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.FipsPathText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Last seen" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.LastSeenDisplay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Sent" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.TxBytesDisplay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                          <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Received" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                            <TextBlock Text="{Binding SelectedParticipant.RxBytesDisplay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="{Binding SelectedParticipant.StatusDetailText}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,8,0,0" />
                      </StackPanel>
                    </Border>
                  </StackPanel>

                  <StackPanel Visibility="{Binding SelectedParticipant, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="Devices" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="No devices yet" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" />
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <ItemsControl ItemsSource="{Binding ActiveNetwork.InboundJoinRequests}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource Card}">
                    <DockPanel>
                      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="Reject" Tag="{Binding}" Click="RejectJoin_Click" Margin="0,0,8,0" />
                        <Button Content="Accept" Tag="{Binding}" Click="AcceptJoin_Click" />
                      </StackPanel>
                      <StackPanel>
                        <TextBlock Text="{Binding RequesterNodeName}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding RequestedAtText}" Foreground="{StaticResource TextSecondary}" />
                      </StackPanel>
                    </DockPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=AddNetwork}">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Create Network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding NetworkNameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <Button Grid.Column="1" Content="Create" Command="{Binding CreateNetworkCommand}" />
                </Grid>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Join Network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <TextBlock Text="Paste invite code" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,4" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding InviteInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Paste" Command="{Binding PasteInviteCommand}" Margin="0,0,8,0" />
                    <Button Content="From QR file" Command="{Binding ImportQrImageCommand}" />
                  </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" Visibility="{Binding ActiveNetworkJoinStatus, Converter={StaticResource NonEmptyStringToVisibility}}">
                  <TextBlock Text="{Binding ActiveNetworkJoinStatus}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
                  <Button Content="Request Access" Command="{Binding RequestNetworkJoinCommand}" Visibility="{Binding CanRequestActiveNetworkJoin, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
                <Expander Header="Add manually" Margin="0,10,0,0" IsExpanded="{Binding ManualJoinExpanded, Mode=TwoWay}">
                  <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Both sides have to add each other. Get the admin's Device ID and the network ID from them, then have the admin add your Device ID on their Add device page." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <TextBox Text="{Binding ManualJoinAdminId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4">
                      <TextBox.Style>
                        <Style TargetType="TextBox">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding ManualJoinAdminInvalid}" Value="True">
                              <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
                              <Setter Property="BorderThickness" Value="1" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBox.Style>
                    </TextBox>
                    <TextBlock Text="Not a valid device ID" Foreground="{StaticResource Danger}" FontSize="11" Margin="0,0,0,4" Visibility="{Binding ManualJoinAdminErrorVisibility}" />
                    <TextBox Text="{Binding ManualJoinMeshId, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                    <Button Content="Add" Command="{Binding ManualAddNetworkCommand}" HorizontalAlignment="Left" />
                  </StackPanel>
                </Expander>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                  <Button DockPanel.Dock="Right" Content="{Binding NearbyDiscoveryButtonText}" Command="{Binding ToggleNearbyDiscoveryCommand}" />
                  <TextBlock Text="Nearby invites" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                </DockPanel>
                <ItemsControl ItemsSource="{Binding State.LanPeers}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Join" Tag="{Binding Invite}" Click="JoinLanPeer_Click" />
                        <StackPanel>
                          <TextBlock Text="{Binding NodeName}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding NetworkName}" Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="No nearby invites yet" Foreground="{StaticResource TextSecondary}" Visibility="{Binding NoNearbyInvitesNoticeVisibility}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=AddDevice}">
            <Border Style="{StaticResource Card}" Visibility="{Binding ShowActiveNetworkInviteCard, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:QrCodeView Width="150" Height="150" Matrix="{Binding InviteQr}" />
                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                  <TextBlock Text="Invite to my network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                  <TextBlock Text="Share this code with another device to give it access to your network." Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap" />
                  <TextBox Text="{Binding State.ActiveNetworkInvite, Mode=OneWay}" IsReadOnly="True" />
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Copy" Command="{Binding CopyInviteCommand}" Margin="0,0,8,0" />
                    <Button Content="{Binding InviteBroadcastButtonText}" Command="{Binding ToggleInviteBroadcastCommand}" />
                    <CheckBox Content="Allow join requests"
                              IsChecked="{Binding ActiveNetwork.JoinRequestsEnabled, Mode=OneWay}"
                              IsEnabled="{Binding ActiveNetwork.LocalIsAdmin}"
                              Click="JoinRequests_Click"
                              Margin="12,4,0,4" />
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <Border Style="{StaticResource Card}" Visibility="{Binding ActiveNetworkHasIncomingJoinRequests, Converter={StaticResource BoolToVisibility}}">
              <StackPanel>
                <TextBlock Text="Join Requests" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding ActiveNetwork.InboundJoinRequests}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Style="{StaticResource Card}">
                        <DockPanel>
                          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Reject" Tag="{Binding}" Click="RejectJoin_Click" Margin="0,0,8,0" />
                            <Button Content="Accept" Tag="{Binding}" Click="AcceptJoin_Click" />
                          </StackPanel>
                          <StackPanel>
                            <TextBlock Text="{Binding RequesterNodeName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RequestedAtText}" Foreground="{StaticResource TextSecondary}" />
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Visibility="{Binding HasActiveNetwork, Converter={StaticResource BoolToVisibility}}">
              <StackPanel>
                <TextBlock Text="For manual join" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="If the other device can't scan or paste an invite, share these two values. They'll enter them under Join Network → Add manually. You still need to add their Device ID below." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10" />
                <Grid Margin="0,0,0,8">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Your Device ID" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding State.OwnNpub}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  <Button Grid.Column="2" Content="Copy" Tag="{Binding State.OwnNpub}" Click="CopyPeer_Click" />
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Network ID" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding ActiveNetwork.NetworkId}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  <Button Grid.Column="2" Content="Copy" Command="{Binding CopyNetworkIdCommand}" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Visibility="{Binding ActiveNetwork.LocalIsAdmin, Converter={StaticResource BoolToVisibility}}">
              <StackPanel>
                <TextBlock Text="Add by Device ID" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="Manual pairing: enter the other device's Device ID. They also need to add yours." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,8" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding ParticipantInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0">
                    <TextBox.Style>
                      <Style TargetType="TextBox">
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding ParticipantInputInvalid}" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Danger}" />
                            <Setter Property="BorderThickness" Value="1" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBox.Style>
                  </TextBox>
                  <TextBox Grid.Column="1" Text="{Binding ParticipantAliasInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <Button Grid.Column="2" Content="Add" Command="{Binding AddParticipantCommand}" />
                </Grid>
                <TextBlock Text="Not a valid device ID" Foreground="{StaticResource Danger}" FontSize="11" Margin="0,4,0,0" Visibility="{Binding ParticipantInputErrorVisibility}" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=ExitNodes}">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Exit Node" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Button Click="DirectExit_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,8">
                  <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Right" Text="No exit node — your own internet" Foreground="{StaticResource TextSecondary}" Margin="12,0,0,0" />
                    <TextBlock Text="{Binding DirectExitMarker}" Margin="0,0,8,0" />
                    <TextBlock Text="Direct" FontWeight="SemiBold" />
                  </DockPanel>
                </Button>
                <Button Click="WireguardExit_Click" IsEnabled="{Binding State.WireguardExitConfigured}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,0,0,8">
                  <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Right" Text="{Binding WireguardExitSubtitle}" Foreground="{StaticResource TextSecondary}" Margin="12,0,0,0" />
                    <TextBlock Text="{Binding WireguardExitMarker}" Margin="0,0,8,0" />
                    <TextBlock Text="WireGuard upstream" FontWeight="SemiBold" />
                  </DockPanel>
                </Button>
                <ItemsControl ItemsSource="{Binding ActiveNetwork.Participants}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Tag="{Binding Npub}" Click="SetExitNode_Click" Margin="0,0,0,8" HorizontalContentAlignment="Stretch">
                        <DockPanel LastChildFill="False">
                          <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" Foreground="{StaticResource TextSecondary}" Margin="12,0,0,0" />
                          <TextBlock Text="{Binding MagicDnsName}" FontWeight="SemiBold" />
                        </DockPanel>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <CheckBox Content="Offer this device as an exit node" IsChecked="{Binding State.AdvertiseExitNode, Mode=OneWay}" Click="AdvertiseExit_Click" />
                <CheckBox Content="Block internet if exit node disconnects" IsChecked="{Binding State.ExitNodeLeakProtection, Mode=OneWay}" Click="ExitLeakProtection_Click" Margin="0,10,0,0" />
                <TextBlock Text="WireGuard Upstream" FontSize="18" FontWeight="SemiBold" Margin="0,16,0,10" />
                <TextBlock Text="Paste a WireGuard config from an upstream VPN provider such as Mullvad or Proton VPN." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,10" />
                <TextBox Text="{Binding WireguardExitConfig, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" MinHeight="180" />
                <Button Content="Save WireGuard" Command="{Binding SaveWireGuardExitCommand}" HorizontalAlignment="Left" Margin="0,12,0,0" />
              </StackPanel>
            </Border>
          </StackPanel>

          <StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=Settings}">
            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="This Device" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="160" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Name" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding NodeName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,8" />
                  <TextBlock Grid.Column="2" Text="Tunnel IP" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding TunnelIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                  <TextBlock Grid.Row="1" Text="Endpoint" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />
                  <TextBlock Grid.Row="1" Grid.Column="2" Text="Port" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding ListenPort, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                  <CheckBox Content="Autoconnect" IsChecked="{Binding State.Autoconnect, Mode=OneWay}" Click="Autoconnect_Click" />
                  <CheckBox Content="Launch on startup" IsChecked="{Binding State.LaunchOnStartup, Mode=OneWay}" Click="LaunchOnStartup_Click" />
                  <CheckBox Content="Tray on close" IsChecked="{Binding State.CloseToTrayOnClose, Mode=OneWay}" Click="CloseToTray_Click" />
                </StackPanel>
                <Button Content="Save" Command="{Binding SaveNodeCommand}" HorizontalAlignment="Left" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Networks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding NetworkNameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <Button Grid.Column="1" Content="Add" Command="{Binding AddNetworkCommand}" />
                </Grid>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Active" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding NetworkNameDraft, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
                  <Button Grid.Column="2" Content="Save" Command="{Binding SaveNetworkNameCommand}" Margin="0,0,0,8" />
                  <TextBlock Grid.Row="1" Text="Network ID" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NetworkMeshIdDraft, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Copy" Command="{Binding CopyNetworkIdCommand}" Margin="0,0,8,0" />
                    <Button Content="Save" Command="{Binding SaveNetworkMeshIdCommand}" />
                  </StackPanel>
                </Grid>
                <Button Content="Remove this network" Margin="0,8,0,0" HorizontalAlignment="Left" Tag="{Binding ActiveNetwork.Id}" Click="RemoveNetwork_Click" Visibility="{Binding HasActiveNetwork, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding InactiveNetworks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,10,0,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                          <Button Content="Activate" Tag="{Binding Id}" Click="ActivateNetwork_Click" Margin="0,0,8,0" />
                          <Button Content="Remove" Tag="{Binding Id}" Click="RemoveNetwork_Click" />
                        </StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <CheckBox Margin="0,12,0,0" Content="Allow join requests" IsChecked="{Binding ActiveNetwork.JoinRequestsEnabled, Mode=OneWay}" Click="JoinRequests_Click" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                  <TextBlock DockPanel.Dock="Right"
                             Text="{Binding SystemVersionLabel}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="12"
                             Visibility="{Binding SystemVersionLabel, Converter={StaticResource NonEmptyStringToVisibility}}" />
                  <TextBlock Text="System" FontSize="18" FontWeight="SemiBold" />
                </DockPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding ServiceSummary}" Foreground="{StaticResource TextSecondary}" Margin="0,0,18,0" />
                  <TextBlock Text="{Binding CliSummary}" Foreground="{StaticResource TextSecondary}" Margin="0,0,18,0" />
                  <TextBlock Text="{Binding UpdateStatus}" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                  <Button Content="Install service" Command="{Binding InstallServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Enable" Command="{Binding EnableServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Disable" Command="{Binding DisableServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Install CLI" Command="{Binding InstallCliCommand}" Margin="0,0,8,0" />
                  <Button Content="Updates" Command="{Binding CheckUpdatesCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Expander Header="Diagnostics" Margin="0,0,0,14">
              <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="110" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Interface" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Column="1" Text="{Binding DiagnosticsInterface}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Column="2" Text="Gateway" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Column="3" Text="{Binding DiagnosticsGateway}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1" Text="IPv4" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DiagnosticsIpv4}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="IPv6" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding DiagnosticsIpv6}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="2" Text="Mapping" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiagnosticsMapping}" TextTrimming="CharacterEllipsis" Margin="0,0,16,0" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="External" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DiagnosticsExternal}" TextTrimming="CharacterEllipsis" />
                  </Grid>

                  <ItemsControl ItemsSource="{Binding State.Health}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <DockPanel Margin="0,0,0,8">
                          <TextBlock DockPanel.Dock="Left" Text="{Binding Severity}" Foreground="{StaticResource Warn}" FontWeight="SemiBold" Width="82" />
                          <StackPanel>
                            <TextBlock Text="{Binding Summary}" />
                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DockPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </Expander>

          </StackPanel>
        </StackPanel>
        </Grid>
      </ScrollViewer>
    </DockPanel>
  </Grid>
</Window>
