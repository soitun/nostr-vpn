                </TextBlock>
                <CheckBox Style="{StaticResource SwitchCheckBox}" Content="Keep npub.fips outside the tunnel" IsChecked="{Binding State.FipsHostTunnelEnabled, Mode=OneWay}" Click="FipsHostTunnel_Click" />
                <Grid Margin="0,8,0,0" IsEnabled="{Binding State.FipsHostTunnelEnabled}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Your public FIPS address" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,0,8" />
                  <TextBox Grid.Column="1" Text="{Binding PublicFipsAddress, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,8" />
                  <TextBlock Grid.Row="1" Text="Public .fips inbound TCP ports" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FipsHostInboundTcpPorts, UpdateSourceTrigger=PropertyChanged}" ToolTip="Comma-separated port numbers" />
                </Grid>
                <Button Content="Save" Command="{Binding SaveNodeCommand}" HorizontalAlignment="Left" Margin="0,12,0,0" IsEnabled="{Binding PublicFipsRoutingEnabled}" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <TextBlock Text="Networks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBox Text="{Binding NetworkNameInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <Button Grid.Column="1" Content="Add" Command="{Binding AddNetworkCommand}" />
                </Grid>
                <Grid Margin="0,12,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Active" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding NetworkNameDraft, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
                  <Button Grid.Column="2" Content="Save" Command="{Binding SaveNetworkNameCommand}" Margin="0,0,0,8" />
                  <TextBlock Grid.Row="1" Text="Network ID" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                  <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NetworkMeshIdDraft, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                  <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Copy" Command="{Binding CopyNetworkIdCommand}" Margin="0,0,8,0" />
                    <Button Content="Save" Command="{Binding SaveNetworkMeshIdCommand}" />
                  </StackPanel>
                </Grid>
                <Button Content="Remove this network" Margin="0,8,0,0" HorizontalAlignment="Left" Tag="{Binding ActiveNetwork.Id}" Click="RemoveNetwork_Click" Visibility="{Binding HasActiveNetwork, Converter={StaticResource BoolToVisibility}}" />
                <ItemsControl ItemsSource="{Binding InactiveNetworks}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,10,0,0">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                          <Button Content="Activate" Tag="{Binding Id}" Click="ActivateNetwork_Click" Margin="0,0,8,0" />
                          <Button Content="Remove" Tag="{Binding Id}" Click="RemoveNetwork_Click" />
                        </StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                  <TextBlock DockPanel.Dock="Right"
                             Text="{Binding SystemVersionLabel}"
                             Foreground="{StaticResource TextSecondary}"
                             FontSize="12"
                             Visibility="{Binding SystemVersionLabel, Converter={StaticResource NonEmptyStringToVisibility}}" />
                  <TextBlock Text="System" FontSize="18" FontWeight="SemiBold" />
                </DockPanel>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding ServiceSummary}" Foreground="{StaticResource TextSecondary}" Margin="0,0,18,0" />
                  <TextBlock Text="{Binding CliSummary}" Foreground="{StaticResource TextSecondary}" Margin="0,0,18,0" />
                  <TextBlock Text="{Binding UpdateStatus}" Foreground="{StaticResource TextSecondary}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                  <Button Content="Install service" Command="{Binding InstallServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Enable" Command="{Binding EnableServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Disable" Command="{Binding DisableServiceCommand}" Margin="0,0,8,0" />
                  <Button Content="Install CLI" Command="{Binding InstallCliCommand}" Margin="0,0,8,0" />
                  <Button Content="Updates" Command="{Binding CheckUpdatesCommand}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Expander Header="Diagnostics" Margin="0,0,0,14">
              <Border Style="{StaticResource Card}" Margin="0,8,0,0">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110" />
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="110" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Interface" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Column="1" Text="{Binding DiagnosticsInterface}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Column="2" Text="Gateway" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Column="3" Text="{Binding DiagnosticsGateway}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="1" Text="IPv4" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DiagnosticsIpv4}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="IPv6" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding DiagnosticsIpv6}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="2" Text="Mapping" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DiagnosticsMapping}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="External" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding DiagnosticsExternal}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="3" Text="Remote roster" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DiagnosticsPeers}" TextTrimming="CharacterEllipsis" Margin="0,0,16,8" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Roster FIPS" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,8" />
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding DiagnosticsFips}" TextTrimming="CharacterEllipsis" Margin="0,0,0,8" />
                    <TextBlock Grid.Row="4" Text="Other FIPS" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding DiagnosticsOtherFips}" TextTrimming="CharacterEllipsis" />
                  </Grid>

                  <ItemsControl ItemsSource="{Binding State.Health}" Margin="0,12,0,0">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <DockPanel Margin="0,0,0,8">
                          <TextBlock DockPanel.Dock="Left" Text="{Binding Severity}" Foreground="{StaticResource Warn}" FontWeight="SemiBold" Width="82" />
                          <StackPanel>
                            <TextBlock Text="{Binding Summary}" />
                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" />
                          </StackPanel>
                        </DockPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </Expander>

          </StackPanel>
        </StackPanel>
        </Grid>
      </ScrollViewer>
    </DockPanel>
  </Grid>
</Window>
