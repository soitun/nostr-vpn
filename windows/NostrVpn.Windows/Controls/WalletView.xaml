<UserControl x:Class="NostrVpn.Windows.Controls.WalletView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=Wallet}">
  <TextBlock Text="Pay for internet access and receive earnings when you sell bandwidth." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12" />
  <Border Style="{StaticResource Card}">
    <StackPanel>
      <DockPanel LastChildFill="True" Margin="0,0,0,10">
        <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshPaidRouteWallet_Click" />
        <StackPanel>
          <TextBlock Text="Wallet" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="{Binding PaidRouteWalletBalanceText, Mode=OneWay}" FontSize="32" FontWeight="Bold" />
          <TextBlock Text="{Binding PaidRouteWalletFiatText}" Foreground="{StaticResource TextSecondary}" Visibility="{Binding PaidRouteWalletFiatText, Converter={StaticResource NonEmptyStringToVisibility}}" />
          <TextBlock Text="{Binding PaidRouteWalletRateText}" Foreground="{StaticResource TextSecondary}" FontSize="12" Visibility="{Binding PaidRouteWalletRateText, Converter={StaticResource NonEmptyStringToVisibility}}" />
        </StackPanel>
      </DockPanel>
      <TextBlock Text="{Binding State.PaidRouteMarket.Wallet.LastAction.DisplayStatusText}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.DisplayStatusText, Converter={StaticResource NonEmptyStringToVisibility}}" />

      <Grid Margin="0,10,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="130" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="Mint URL" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox Grid.Column="1" Text="{Binding PaidRouteMintUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
        <Button Grid.Column="2" Content="Add" Click="AddPaidRouteWalletMint_Click" IsEnabled="{Binding CanAddPaidRouteWalletMint}" />
      </Grid>

      <TabControl Margin="0,4,0,8">
        <TabItem Header="Receive">
          <StackPanel Margin="8">
            <TextBlock Text="Lightning" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Add a mint before using Lightning." Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" Visibility="{Binding HasPaidRouteWalletMint, Converter={StaticResource InverseBoolToVisibility}}" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Right" Content="Create Invoice" Click="TopUpPaidRouteWallet_Click" IsEnabled="{Binding CanTopUpPaidRouteWallet}" Margin="8,0,0,0" />
              <TextBox Text="{Binding PaidRouteTopUpAmount, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock Text="Token" FontWeight="SemiBold" Margin="0,12,0,6" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Right" Content="Scan QR" Click="ScanPaidRouteWalletToken_Click" Margin="8,0,0,0" />
              <TextBox Text="{Binding PaidRouteReceiveToken, UpdateSourceTrigger=PropertyChanged}" TextChanged="PaidRouteReceiveToken_Changed" />
            </DockPanel>
          </StackPanel>
        </TabItem>
        <TabItem Header="Send">
          <StackPanel Margin="8">
            <TextBlock Text="Lightning" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBlock Text="Add a mint before sending." Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" Visibility="{Binding HasPaidRouteWalletMint, Converter={StaticResource InverseBoolToVisibility}}" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Right" Content="Pay" Click="WithdrawPaidRouteWalletLightning_Click" IsEnabled="{Binding CanWithdrawPaidRouteWalletLightning}" Margin="8,0,0,0" />
              <TextBox Text="{Binding PaidRouteWithdrawInvoice, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
            <TextBlock Text="Token" FontWeight="SemiBold" Margin="0,12,0,6" />
            <DockPanel LastChildFill="True">
              <Button DockPanel.Dock="Right" Content="Export" Click="SendPaidRouteWalletToken_Click" IsEnabled="{Binding CanSendPaidRouteWalletToken}" Margin="8,0,0,0" />
              <TextBox Text="{Binding PaidRouteSendAmount, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>
          </StackPanel>
        </TabItem>
      </TabControl>

      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Invoice" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>
      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.Token, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Token" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.Token}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.Token}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>
      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Preimage" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>

      <TextBlock Text="Mints" FontWeight="SemiBold" Margin="0,10,0,6" />
      <TextBlock Text="{Binding PaidRouteWalletMintsStatusText}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Visibility="{Binding PaidRouteWalletMintsStatusText, Converter={StaticResource NonEmptyStringToVisibility}}" />
      <ItemsControl ItemsSource="{Binding PaidRouteWalletMintRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</StackPanel>
</UserControl>
