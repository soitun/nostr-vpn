<UserControl x:Class="NostrVpn.Windows.Controls.WalletView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<StackPanel Visibility="{Binding Page, Converter={StaticResource PageVisibility}, ConverterParameter=Wallet}">
  <TextBlock Text="Use this Cashu wallet to pay for internet access and receive earnings when you sell bandwidth." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,12" />
  <Border Style="{StaticResource Card}">
    <StackPanel>
      <CheckBox Style="{StaticResource SwitchCheckBox}" Content="Show fiat value" IsChecked="{Binding State.WalletFiatEnabled, Mode=OneWay}" Click="WalletFiatEnabled_Click" />
      <TextBlock Text="Rates from Coinbase and Kraken" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" Visibility="{Binding State.WalletFiatEnabled, Converter={StaticResource BoolToVisibility}}" />
      <ComboBox SelectedValue="{Binding State.WalletFiatCurrency, Mode=OneWay}" SelectedValuePath="Content" SelectionChanged="WalletFiatCurrency_Changed" Margin="0,10,0,0" Visibility="{Binding State.WalletFiatEnabled, Converter={StaticResource BoolToVisibility}}">
        <ComboBoxItem Content="USD" /><ComboBoxItem Content="EUR" /><ComboBoxItem Content="GBP" />
        <ComboBoxItem Content="CAD" /><ComboBoxItem Content="AUD" /><ComboBoxItem Content="JPY" /><ComboBoxItem Content="CHF" />
      </ComboBox>
    </StackPanel>
  </Border>
  <Border Style="{StaticResource Card}">
    <StackPanel>
      <DockPanel LastChildFill="True" Margin="0,0,0,10">
        <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshPaidRouteWallet_Click" />
        <StackPanel>
          <TextBlock Text="Cashu Wallet" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Foreground="{StaticResource TextSecondary}">
            <Run Text="Balance " /><Run Text="{Binding PaidRouteWalletBalanceText, Mode=OneWay}" />
          </TextBlock>
          <TextBlock Text="{Binding PaidRouteWalletFiatText}" Foreground="{StaticResource TextSecondary}" Visibility="{Binding PaidRouteWalletFiatText, Converter={StaticResource NonEmptyStringToVisibility}}" />
          <TextBlock Text="{Binding PaidRouteWalletRateText}" Foreground="{StaticResource TextSecondary}" FontSize="12" Visibility="{Binding PaidRouteWalletRateText, Converter={StaticResource NonEmptyStringToVisibility}}" />
        </StackPanel>
      </DockPanel>
      <TextBlock Text="{Binding State.PaidRouteMarket.Wallet.LastAction.DisplayStatusText}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.DisplayStatusText, Converter={StaticResource NonEmptyStringToVisibility}}" />

      <TextBlock Text="Mints and Tokens" FontWeight="SemiBold" Margin="0,10,0,6" />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="130" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Mint URL" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding PaidRouteMintUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
        <Button Grid.Row="0" Grid.Column="2" Content="Add Mint" Click="AddPaidRouteWalletMint_Click" IsEnabled="{Binding CanAddPaidRouteWalletMint}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Text="Top-up sats" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PaidRouteTopUpAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
        <Button Grid.Row="1" Grid.Column="2" Content="Top Up" Click="TopUpPaidRouteWallet_Click" IsEnabled="{Binding CanTopUpPaidRouteWallet}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Export sats" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding PaidRouteSendAmount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
        <Button Grid.Row="2" Grid.Column="2" Content="Export" Click="SendPaidRouteWalletToken_Click" IsEnabled="{Binding CanSendPaidRouteWalletToken}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="3" Text="Cashu token" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PaidRouteReceiveToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,8" />
        <Button Grid.Row="3" Grid.Column="2" Content="Import" Click="ReceivePaidRouteWalletToken_Click" IsEnabled="{Binding CanReceivePaidRouteWalletToken}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="4" Text="Lightning invoice" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding PaidRouteWithdrawInvoice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
        <Button Grid.Row="4" Grid.Column="2" Content="Withdraw" Click="WithdrawPaidRouteWalletLightning_Click" IsEnabled="{Binding CanWithdrawPaidRouteWalletLightning}" />
      </Grid>

      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Invoice" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.PaymentRequest}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>
      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.Token, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Token" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.Token}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.Token}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>
      <StackPanel Margin="0,10,0,0" Visibility="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage, Converter={StaticResource NonEmptyStringToVisibility}}">
        <TextBlock Text="Preimage" FontWeight="SemiBold" Margin="0,0,0,4" />
        <DockPanel LastChildFill="True">
          <Button DockPanel.Dock="Right" Content="Copy" Tag="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage}" Click="CopyWalletValue_Click" Margin="8,0,0,0" />
          <TextBox Text="{Binding State.PaidRouteMarket.Wallet.LastAction.Preimage}" IsReadOnly="True" />
        </DockPanel>
      </StackPanel>

      <TextBlock Text="Mints" FontWeight="SemiBold" Margin="0,10,0,6" />
      <TextBlock Text="{Binding PaidRouteWalletMintsStatusText}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Visibility="{Binding PaidRouteWalletMintsStatusText, Converter={StaticResource NonEmptyStringToVisibility}}" />
      <ItemsControl ItemsSource="{Binding PaidRouteWalletMintRows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,6" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</StackPanel>
</UserControl>
