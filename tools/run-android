#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ANDROID_DIR="$ROOT/android"
LOCK_SNAPSHOT=""
MANIFEST_SNAPSHOT=""

restore_lock() {
  if [[ -n "$LOCK_SNAPSHOT" && -f "$LOCK_SNAPSHOT" && -f "$ROOT/Cargo.lock" ]]; then
    if ! cmp -s "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"; then
      cp -p "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"
      printf 'restored Cargo.lock after local-FIPS cargo run\n'
    fi
  fi
  if [[ -n "$MANIFEST_SNAPSHOT" && -f "$MANIFEST_SNAPSHOT" && -f "$ROOT/Cargo.toml" ]]; then
    if ! cmp -s "$MANIFEST_SNAPSHOT" "$ROOT/Cargo.toml"; then
      cp -p "$MANIFEST_SNAPSHOT" "$ROOT/Cargo.toml"
      printf 'restored Cargo.toml after local-FIPS cargo run\n'
    fi
  fi
}

prepare_lock_restore() {
  [[ -z "$LOCK_SNAPSHOT" ]] || return 0
  LOCK_SNAPSHOT="$(mktemp)"
  MANIFEST_SNAPSHOT="$(mktemp)"
  cp -p "$ROOT/Cargo.lock" "$LOCK_SNAPSHOT"
  cp -p "$ROOT/Cargo.toml" "$MANIFEST_SNAPSHOT"
  trap restore_lock EXIT
}

validated_fips_repo_path() {
  local fips_path="${NVPN_FIPS_REPO_PATH:-}"
  [[ -n "$fips_path" ]] || return 1
  if [[ ! -d "$fips_path/crates/fips-core" \
        || ! -d "$fips_path/crates/fips-endpoint" \
        || ! -d "$fips_path/crates/fips-identity" ]]; then
    echo "NVPN_FIPS_REPO_PATH must point at a fips checkout with fips-core, fips-endpoint, and fips-identity" >&2
    exit 1
  fi
  printf '%s\n' "$fips_path"
}

prepare_local_fips_manifest() {
  if [[ -n "${NVPN_FIPS_REPO_PATH:-}" ]]; then
    local fips_path
    fips_path="$(validated_fips_repo_path)"
    prepare_lock_restore
    NVPN_LOCAL_FIPS_CORE_PATH="$fips_path/crates/fips-core" \
    NVPN_LOCAL_FIPS_ENDPOINT_PATH="$fips_path/crates/fips-endpoint" \
    NVPN_LOCAL_FIPS_IDENTITY_PATH="$fips_path/crates/fips-identity" \
      perl -0pi -e '
        s#fips-core = \{ version = "([^"]+)", path = "[^"]*" \}#fips-core = { version = "$1", path = "$ENV{NVPN_LOCAL_FIPS_CORE_PATH}" }#;
        s#fips-endpoint = \{ version = "([^"]+)", path = "[^"]*" \}#fips-endpoint = { version = "$1", path = "$ENV{NVPN_LOCAL_FIPS_ENDPOINT_PATH}" }#;
        s#fips-identity = \{ version = "([^"]+)", path = "[^"]*" \}#fips-identity = { version = "$1", path = "$ENV{NVPN_LOCAL_FIPS_IDENTITY_PATH}" }#;
      ' "$ROOT/Cargo.toml"
    printf 'using local FIPS crates from %s\n' "$fips_path"
  fi
}

find_gradle() {
  local cached
  cached="$(find "$HOME/.gradle/wrapper/dists" -path '*/bin/gradle' -type f 2>/dev/null | sort -V | grep -v '/gradle-9\.' | tail -n 1 || true)"
  if [[ -n "$cached" ]]; then
    printf '%s\n' "$cached"
    return
  fi
  if command -v gradle >/dev/null 2>&1; then
    command -v gradle
    return
  fi
  if [[ -z "$cached" ]]; then
    cached="$(find "$HOME/.gradle/wrapper/dists" -path '*/bin/gradle' -type f 2>/dev/null | sort -V | tail -n 1 || true)"
  fi
  if [[ -n "$cached" ]]; then
    printf '%s\n' "$cached"
    return
  fi
  echo "gradle not found; install Gradle or run from a machine with a cached Gradle wrapper distribution" >&2
  exit 1
}

if [[ -z "${ANDROID_HOME:-}" && -d "$HOME/Library/Android/sdk" ]]; then
  export ANDROID_HOME="$HOME/Library/Android/sdk"
fi
if [[ -n "${ANDROID_NDK_HOME:-}" && ! -d "$ANDROID_NDK_HOME" ]]; then
  unset ANDROID_NDK_HOME
fi
if [[ -n "${NDK_HOME:-}" && ! -d "$NDK_HOME" ]]; then
  unset NDK_HOME
fi
if [[ -z "${ANDROID_NDK_HOME:-}" && -n "${ANDROID_HOME:-}" ]]; then
  latest_ndk="$(find "$ANDROID_HOME/ndk" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort -V | tail -n 1 || true)"
  if [[ -n "$latest_ndk" ]]; then
    export ANDROID_NDK_HOME="$latest_ndk"
  fi
fi
export NDK_HOME="${ANDROID_NDK_HOME:-${NDK_HOME:-}}"

if [[ -n "${NVPN_FIPS_REPO_PATH:-}" ]]; then
  prepare_local_fips_manifest
fi

GRADLE="$(find_gradle)"
cmd="${1:-assembleDebug}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  build|assembleDebug|debug)
    env -u NVPN_FIPS_REPO_PATH "$GRADLE" -p "$ANDROID_DIR" :app:assembleDebug "$@"
    ;;
  release|assembleRelease)
    env -u NVPN_FIPS_REPO_PATH "$GRADLE" -p "$ANDROID_DIR" :app:assembleRelease "$@"
    ;;
  install|installDebug)
    env -u NVPN_FIPS_REPO_PATH "$GRADLE" -p "$ANDROID_DIR" :app:installDebug "$@"
    ;;
  *)
    env -u NVPN_FIPS_REPO_PATH "$GRADLE" -p "$ANDROID_DIR" "$cmd" "$@"
    ;;
esac
