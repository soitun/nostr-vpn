#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ANDROID_DIR="$ROOT/android"
LOCK_SNAPSHOT=""

restore_lock() {
  if [[ -n "$LOCK_SNAPSHOT" && -f "$LOCK_SNAPSHOT" && -f "$ROOT/Cargo.lock" ]]; then
    if ! cmp -s "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"; then
      cp -p "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"
      printf 'restored Cargo.lock after local-FIPS cargo run\n'
    fi
  fi
}

prepare_lock_restore() {
  [[ -z "$LOCK_SNAPSHOT" ]] || return 0
  LOCK_SNAPSHOT="$(mktemp)"
  cp -p "$ROOT/Cargo.lock" "$LOCK_SNAPSHOT"
  trap restore_lock EXIT
}

validated_fips_repo_path() {
  local fips_path="${NVPN_FIPS_REPO_PATH:-}"
  [[ -n "$fips_path" ]] || return 1
  if [[ ! -d "$fips_path/crates/fips-core" \
        || ! -d "$fips_path/crates/fips-endpoint" \
        || ! -d "$fips_path/crates/fips-identity" ]]; then
    echo "NVPN_FIPS_REPO_PATH must point at a fips checkout with fips-core, fips-endpoint, and fips-identity" >&2
    exit 1
  fi
}

find_gradle() {
  local cached
  cached="$(find "$HOME/.gradle/wrapper/dists" -path '*/bin/gradle' -type f 2>/dev/null | sort -V | grep -v '/gradle-9\.' | tail -n 1 || true)"
  if [[ -n "$cached" ]]; then
    printf '%s\n' "$cached"
    return
  fi
  if command -v gradle >/dev/null 2>&1; then
    command -v gradle
    return
  fi
  if [[ -z "$cached" ]]; then
    cached="$(find "$HOME/.gradle/wrapper/dists" -path '*/bin/gradle' -type f 2>/dev/null | sort -V | tail -n 1 || true)"
  fi
  if [[ -n "$cached" ]]; then
    printf '%s\n' "$cached"
    return
  fi
  echo "gradle not found; install Gradle or run from a machine with a cached Gradle wrapper distribution" >&2
  exit 1
}

if [[ -z "${ANDROID_HOME:-}" && -d "$HOME/Library/Android/sdk" ]]; then
  export ANDROID_HOME="$HOME/Library/Android/sdk"
fi
if [[ -n "${ANDROID_NDK_HOME:-}" && ! -d "$ANDROID_NDK_HOME" ]]; then
  unset ANDROID_NDK_HOME
fi
if [[ -n "${NDK_HOME:-}" && ! -d "$NDK_HOME" ]]; then
  unset NDK_HOME
fi
if [[ -z "${ANDROID_NDK_HOME:-}" && -n "${ANDROID_HOME:-}" ]]; then
  latest_ndk="$(find "$ANDROID_HOME/ndk" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | sort -V | tail -n 1 || true)"
  if [[ -n "$latest_ndk" ]]; then
    export ANDROID_NDK_HOME="$latest_ndk"
  fi
fi
export NDK_HOME="${ANDROID_NDK_HOME:-${NDK_HOME:-}}"

if [[ -n "${NVPN_FIPS_REPO_PATH:-}" ]]; then
  validated_fips_repo_path
  prepare_lock_restore
fi

GRADLE="$(find_gradle)"
cmd="${1:-assembleDebug}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$cmd" in
  build|assembleDebug|debug)
    "$GRADLE" -p "$ANDROID_DIR" :app:assembleDebug "$@"
    ;;
  release|assembleRelease)
    "$GRADLE" -p "$ANDROID_DIR" :app:assembleRelease "$@"
    ;;
  install|installDebug)
    "$GRADLE" -p "$ANDROID_DIR" :app:installDebug "$@"
    ;;
  *)
    "$GRADLE" -p "$ANDROID_DIR" "$cmd" "$@"
    ;;
esac
