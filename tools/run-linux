#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT/linux"

if ! command -v docker >/dev/null 2>&1; then
    echo "Docker is required for the Linux desktop dev environment." >&2
    exit 1
fi

docker compose up -d --build

container_ready=0
for _ in $(seq 1 20); do
    if docker compose exec -T nostr-vpn-linux true >/dev/null 2>&1; then
        container_ready=1
        break
    fi
    sleep 0.25
done
if [ "$container_ready" -ne 1 ]; then
    echo "Linux desktop container exited before it became ready." >&2
    docker compose ps >&2 || true
    docker compose logs --no-color --tail 200 nostr-vpn-linux >&2 || true
    exit 1
fi

if [ "$#" -eq 0 ]; then
    set -- cargo run
fi

compose_exec=(docker compose exec)
if [ ! -t 0 ]; then
    compose_exec+=(-T)
fi

status=0
"${compose_exec[@]}" nostr-vpn-linux /usr/local/bin/dev-entrypoint "$@" || status=$?

if [ "${CI:-}" = "true" ] && command -v sudo >/dev/null 2>&1; then
    # Docker creates these bind-mount subdirectories as root on GitHub runners.
    # Restore ownership so later host-side cargo steps can reuse the checkout.
    sudo chown -R "$(id -u):$(id -g)" "$ROOT/target" "$ROOT/linux/target" 2>/dev/null || true
fi

exit "$status"
