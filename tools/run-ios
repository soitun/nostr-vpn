#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# Source release_common.sh so xcodegen can substitute NVPN_APP_VERSION_NAME /
# NVPN_APP_VERSION_CODE into project.yml's MARKETING_VERSION and
# CURRENT_PROJECT_VERSION. xcodegen only does plain ${VAR} substitution — the
# bash-style ${VAR:-default} syntax leaks through verbatim into pbxproj and
# xcodebuild then emits an empty CFBundleVersion, which makes the simulator
# fail with "Invalid placeholder attributes" when installing the app
# extension. Always resolving from the workspace version keeps debug + sim
# builds working.
if [[ -f "$ROOT/scripts/release_common.sh" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT/scripts/release_common.sh"
  resolve_shared_build_metadata "$ROOT"
fi
export NVPN_IOS_BUNDLE_ID="${NVPN_IOS_BUNDLE_ID:-${NVPN_DEFAULT_IOS_BUNDLE_ID:-fi.siriusbusiness.nvpn}}"
export NVPN_IOS_PACKET_TUNNEL_BUNDLE_ID="${NVPN_IOS_PACKET_TUNNEL_BUNDLE_ID:-$NVPN_IOS_BUNDLE_ID.PacketTunnel}"
export NVPN_IOS_APP_GROUP_IDENTIFIER="${NVPN_IOS_APP_GROUP_IDENTIFIER:-group.$NVPN_IOS_BUNDLE_ID}"
IOS_DIR="$ROOT/ios"
BUILD_DIR="$IOS_DIR/.build"
FRAMEWORKS_DIR="$IOS_DIR/Frameworks"
BINDINGS_DIR="$IOS_DIR/Bindings"
PROFILE="${NVPN_IOS_RUST_PROFILE:-debug}"
MIN_VERSION="${NVPN_IOS_MIN_VERSION:-17.0}"
PROJECT="$IOS_DIR/NostrVpnIos.xcodeproj"
SCHEME="NostrVpnIos"
SIMULATOR_NAME="${NVPN_IOS_SIMULATOR_NAME:-iPhone 17 Pro}"
cargo_config_args=()
LOCK_SNAPSHOT=""

restore_lock() {
  if [[ -n "$LOCK_SNAPSHOT" && -f "$LOCK_SNAPSHOT" && -f "$ROOT/Cargo.lock" ]]; then
    if ! cmp -s "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"; then
      cp -p "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"
      printf 'restored Cargo.lock after local-FIPS cargo run\n'
    fi
  fi
}

prepare_lock_restore() {
  [[ -z "$LOCK_SNAPSHOT" ]] || return 0
  LOCK_SNAPSHOT="$(mktemp)"
  cp -p "$ROOT/Cargo.lock" "$LOCK_SNAPSHOT"
  trap restore_lock EXIT
}

validated_fips_repo_path() {
  local fips_path="${NVPN_FIPS_REPO_PATH:-}"
  [[ -n "$fips_path" ]] || return 1
  if [[ ! -d "$fips_path/crates/fips-core" \
        || ! -d "$fips_path/crates/fips-endpoint" \
        || ! -d "$fips_path/crates/fips-identity" ]]; then
    echo "NVPN_FIPS_REPO_PATH must point at a fips checkout with fips-core, fips-endpoint, and fips-identity" >&2
    exit 1
  fi
  printf '%s\n' "$fips_path"
}

prepare_cargo_config() {
  cargo_config_args=()
  if [[ -n "${NVPN_FIPS_REPO_PATH:-}" ]]; then
    local fips_path
    fips_path="$(validated_fips_repo_path)"
    prepare_lock_restore
    cargo_config_args+=(
      --config "patch.crates-io.fips-core.path=\"$fips_path/crates/fips-core\""
      --config "patch.crates-io.fips-endpoint.path=\"$fips_path/crates/fips-endpoint\""
      --config "patch.crates-io.fips-identity.path=\"$fips_path/crates/fips-identity\""
    )
    printf 'using local FIPS crates from %s\n' "$fips_path"
  fi
}

target_root() {
  local dir="${CARGO_TARGET_DIR:-$ROOT/target}"
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$ROOT" "$dir"
  fi
}

rust_lib() {
  local target="$1"
  printf '%s/%s/%s/libnostr_vpn_app_core.a\n' "$(target_root)" "$target" "$PROFILE"
}

build_rust_target() {
  local target="$1"
  local sdk="$2"
  local clang_target="$3"
  local min_flag="$4"
  local dev_dir toolchain_bin sdkroot
  dev_dir="$(xcode-select -p)"
  toolchain_bin="$dev_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  sdkroot="$(xcrun --sdk "$sdk" --show-sdk-path)"

  local cargo_args=(build -p nostr-vpn-app-core --target "$target")
  if [[ "$PROFILE" == "release" ]]; then
    cargo_args+=(--release)
  fi

  prepare_cargo_config
  local cargo_cmd=(cargo)
  if [[ ${#cargo_config_args[@]} -gt 0 ]]; then
    cargo_cmd+=("${cargo_config_args[@]}")
  fi
  cargo_cmd+=("${cargo_args[@]}")

  env \
    SDKROOT="$sdkroot" \
    IPHONEOS_DEPLOYMENT_TARGET="$MIN_VERSION" \
    CC="$toolchain_bin/clang" \
    CXX="$toolchain_bin/clang++" \
    AR="$toolchain_bin/ar" \
    RANLIB="$toolchain_bin/ranlib" \
    CARGO_TARGET_AARCH64_APPLE_IOS_LINKER="$toolchain_bin/clang" \
    CARGO_TARGET_AARCH64_APPLE_IOS_SIM_LINKER="$toolchain_bin/clang" \
    RUSTFLAGS="-C linker=$toolchain_bin/clang -C link-arg=-target -C link-arg=$clang_target -C link-arg=$min_flag=$MIN_VERSION" \
    "${cargo_cmd[@]}"
}

build_rust() {
  build_rust_target "aarch64-apple-ios-sim" "iphonesimulator" "arm64-apple-ios${MIN_VERSION}-simulator" "-mios-simulator-version-min"
  build_rust_target "aarch64-apple-ios" "iphoneos" "arm64-apple-ios${MIN_VERSION}" "-miphoneos-version-min"
}

build_xcframework() {
  local framework="$FRAMEWORKS_DIR/NostrVpnAppCore.xcframework"
  rm -rf "$framework"
  mkdir -p "$FRAMEWORKS_DIR"
  xcodebuild -create-xcframework \
    -library "$(rust_lib aarch64-apple-ios-sim)" \
    -headers "$BINDINGS_DIR" \
    -library "$(rust_lib aarch64-apple-ios)" \
    -headers "$BINDINGS_DIR" \
    -output "$framework"
}

generate_project() {
  if ! command -v xcodegen >/dev/null 2>&1; then
    echo "xcodegen is required for iOS project generation" >&2
    exit 1
  fi
  (cd "$IOS_DIR" && xcodegen generate --spec project.yml)
  # XcodeGen emits objectVersion 77 on newer Xcode installs even though this
  # project uses classic groups. Xcode 15 runners cannot open that format.
  perl -0pi -e 's/objectVersion = 77;/objectVersion = 56;/' "$PROJECT/project.pbxproj"
}

build_app() {
  build_rust
  build_xcframework
  generate_project
  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration Debug \
    -derivedDataPath "$BUILD_DIR/DerivedData" \
    -destination "$(ios_destination)" \
    CODE_SIGNING_ALLOWED=NO \
    build
}

sim_device_id() {
  xcrun simctl list devices available \
    | sed -n "s/.*$SIMULATOR_NAME (\([0-9A-F-]\{36\}\)).*/\1/p" \
    | head -n 1
}

ios_destination() {
  if [[ -n "${NVPN_IOS_DESTINATION:-}" ]]; then
    printf '%s\n' "$NVPN_IOS_DESTINATION"
    return
  fi
  if [[ -n "${NVPN_IOS_SIMULATOR_ID:-}" ]]; then
    printf 'platform=iOS Simulator,id=%s\n' "$NVPN_IOS_SIMULATOR_ID"
    return
  fi
  local device
  device="$(sim_device_id)"
  if [[ -n "$device" ]]; then
    printf 'platform=iOS Simulator,id=%s\n' "$device"
  else
    printf 'platform=iOS Simulator,name=%s\n' "$SIMULATOR_NAME"
  fi
}

run_app() {
  build_app
  local device app_path
  device="${NVPN_IOS_SIMULATOR_ID:-$(sim_device_id)}"
  if [[ -z "$device" ]]; then
    echo "No available iOS simulator found" >&2
    exit 1
  fi
  xcrun simctl boot "$device" >/dev/null 2>&1 || true
  xcrun simctl bootstatus "$device" -b
  app_path="$(find "$BUILD_DIR/DerivedData/Build/Products/Debug-iphonesimulator" -maxdepth 1 -name '*.app' -type d | head -n 1)"
  if [[ -z "$app_path" ]]; then
    echo "Built iOS app not found" >&2
    exit 1
  fi
  xcrun simctl install "$device" "$app_path"
  xcrun simctl launch "$device" "$NVPN_IOS_BUNDLE_ID"
  sleep 3
  mkdir -p "$ROOT/artifacts"
  xcrun simctl io "$device" screenshot "$ROOT/artifacts/nostr-vpn-ios.png"
}

case "${1:-build}" in
  rust) build_rust ;;
  xcframework) build_rust; build_xcframework ;;
  project) generate_project ;;
  build) build_app ;;
  run) run_app ;;
  *)
    echo "usage: ./tools/run-ios [rust|xcframework|project|build|run]" >&2
    exit 2
    ;;
esac
