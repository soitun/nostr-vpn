FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      dnsmasq \
      iproute2 \
      iptables \
      socat \
      wireguard-tools \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/mobile-wireguard-exit-server.sh /usr/local/bin/mobile-wireguard-exit-server

ENTRYPOINT ["/usr/local/bin/mobile-wireguard-exit-server"]
