#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CORE_DIR="$ROOT/crates/nostr-vpn-app-core"
MACOS_DIR="$ROOT/macos"
BINDINGS_DIR="$MACOS_DIR/Bindings"
FRAMEWORKS_DIR="$MACOS_DIR/Frameworks"
BUILD_DIR="$MACOS_DIR/.build"
DIST_DIR="$ROOT/dist"
MACOS_DIST_DIR="$DIST_DIR/macos"
PROFILE="${NVPN_MACOS_RUST_PROFILE:-debug}"
HOST_TARGET="${NVPN_MACOS_HOST_TARGET:-$(rustc -vV | awk '/host:/ {print $2}')}"
TARGETS="${NVPN_MACOS_RUST_TARGETS:-$(rustc -vV | awk '/host:/ {print $2}')}"
XCODE_CONFIGURATION="${NVPN_MACOS_XCODE_CONFIGURATION:-Debug}"
PROJECT="$MACOS_DIR/NostrVpnMac.xcodeproj"
SCHEME="NostrVpnMac"
APP_NAME="Nostr VPN.app"
VOLUME_NAME="Nostr VPN"

if [[ -f "$ROOT/scripts/release_common.sh" ]]; then
  # shellcheck disable=SC1091
  source "$ROOT/scripts/release_common.sh"
fi

if ! declare -F bool_is_true >/dev/null 2>&1; then
  bool_is_true() {
    case "${1:-}" in
      1|true|TRUE|True|yes|YES|Yes|on|ON|On) return 0 ;;
      *) return 1 ;;
    esac
  }
fi

load_env_file_defaults() {
  local env_file="$1"
  local line
  local key
  local value

  [[ -f "$env_file" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* || "$line" != *=* ]] && continue

    key="${line%%=*}"
    key="${key%"${key##*[![:space:]]}"}"
    key="${key#"${key%%[![:space:]]*}"}"
    [[ "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || continue
    [[ -n "${!key:-}" ]] && continue

    value="${line#*=}"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    if [[ "$value" == \"*\" && "$value" == *\" ]]; then
      value="${value:1:${#value}-2}"
    elif [[ "$value" == \'*\' && "$value" == *\' ]]; then
      value="${value:1:${#value}-2}"
    fi
    export "$key=$value"
  done < "$env_file"
}

load_env_file_defaults "${NVPN_RELEASE_ENV_FILE:-$ROOT/release.env}"
load_env_file_defaults "$ROOT/.env.release.local"
if declare -F load_appstoreconnect_defaults >/dev/null 2>&1; then
  load_appstoreconnect_defaults
fi
if declare -F enable_deterministic_build_env >/dev/null 2>&1; then
  enable_deterministic_build_env "$ROOT"
fi

usage() {
  cat <<'EOF'
usage: ./scripts/macos-build <command>

commands:
  macos-gen-swift           regenerate UniFFI Swift bindings
  macos-rust                build Rust app-core and CLI for macOS targets
  macos-xcframework         build the app-core xcframework
  macos-xcodeproj           regenerate the Xcode project
  macos-build               build the development app with signing disabled
  macos-app                 build a release app bundle, signed when configured
  macos-notarize            notarize and staple the release app bundle
  macos-dmg                 build the signed/notarized release DMG
  macos-release-artifacts   build the release DMG and updater .app.tar.gz

release signing env:
  MACOS_SIGNING_IDENTITY       Developer ID Application identity
  MACOS_NOTARY_PROFILE         notarytool keychain profile
  NVPN_ASC_AUTH_KEY_PATH       App Store Connect API key .p8 path
  NVPN_ASC_AUTH_KEY_ID         App Store Connect API key id
  NVPN_ASC_AUTH_KEY_ISSUER_ID  App Store Connect issuer id
  MACOS_NOTARIZE_APPLE_ID      Apple ID for notarytool app-password auth
  MACOS_NOTARIZE_APP_PASSWORD  App-specific password for notarytool
  MACOS_NOTARIZE_TEAM_ID       Apple developer team id for notarytool
EOF
}

target_root() {
  if [[ -z "${CARGO_TARGET_ROOT:-}" ]]; then
    CARGO_TARGET_ROOT="$(
      cargo metadata --no-deps --format-version 1 \
        | node -e 'let input = ""; process.stdin.on("data", chunk => input += chunk); process.stdin.on("end", () => process.stdout.write(JSON.parse(input).target_directory));'
    )"
  fi
  printf '%s\n' "$CARGO_TARGET_ROOT"
}

macos_rust_target_root() {
  local dir="${NVPN_MACOS_CARGO_TARGET_DIR:-$BUILD_DIR/cargo-target}"
  if [[ "$dir" = /* ]]; then
    printf '%s\n' "$dir"
  else
    printf '%s/%s\n' "$ROOT" "$dir"
  fi
}

host_dynamic_lib() {
  printf '%s/%s/%s/libnostr_vpn_app_core.dylib\n' "$(target_root)" "$HOST_TARGET" "$PROFILE"
}

target_static_lib() {
  local target="$1"
  printf '%s/%s/%s/libnostr_vpn_app_core.a\n' "$(macos_rust_target_root)" "$target" "$PROFILE"
}

target_cli_bin() {
  local target="$1"
  printf '%s/%s/%s/nvpn\n' "$(macos_rust_target_root)" "$target" "$PROFILE"
}

run_macos_gen_swift() {
  local generated_bindings_dir

  if [[ "$PROFILE" == "release" ]]; then
    cargo build --locked -p nostr-vpn-app-core --release --target "$HOST_TARGET"
  else
    cargo build --locked -p nostr-vpn-app-core --target "$HOST_TARGET"
  fi

  mkdir -p "$BUILD_DIR"
  generated_bindings_dir="$(mktemp -d "$BUILD_DIR/bindings.XXXXXX")"
  trap 'rm -rf "$generated_bindings_dir"' RETURN

  if [[ "$PROFILE" == "release" ]]; then
    cargo run --locked -q --manifest-path "$CORE_DIR/uniffi-bindgen/Cargo.toml" --release --target "$HOST_TARGET" -- generate \
      --library "$(host_dynamic_lib)" \
      --language swift \
      --out-dir "$generated_bindings_dir" \
      --config "$CORE_DIR/uniffi.toml"
  else
    cargo run --locked -q --manifest-path "$CORE_DIR/uniffi-bindgen/Cargo.toml" --target "$HOST_TARGET" -- generate \
      --library "$(host_dynamic_lib)" \
      --language swift \
      --out-dir "$generated_bindings_dir" \
      --config "$CORE_DIR/uniffi.toml"
  fi

  while IFS= read -r -d '' generated_file; do
    perl -0777 -pi -e 's/[ \t]+$//mg; s/\n*\z/\n/' "$generated_file"
  done < <(find "$generated_bindings_dir" -type f \( -name '*.swift' -o -name '*.h' -o -name '*.modulemap' \) -print0)

  rm -rf "$BINDINGS_DIR"
  mv "$generated_bindings_dir" "$BINDINGS_DIR"
  trap - RETURN
}

run_macos_rust() {
  local target
  local dev_dir
  local toolchain_bin
  local cc_bin
  local cxx_bin
  local ar_bin
  local ranlib_bin
  local sdkroot
  local min_version="${NVPN_MACOS_MIN_VERSION:-14.0}"
  local arch_target
  local rustflags_env_var
  local target_rustflags

  dev_dir="$(xcode-select -p)"
  toolchain_bin="$dev_dir/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  cc_bin="$toolchain_bin/clang"
  cxx_bin="$toolchain_bin/clang++"
  ar_bin="$toolchain_bin/ar"
  ranlib_bin="$toolchain_bin/ranlib"
  sdkroot="$(xcrun --sdk macosx --show-sdk-path)"

  for target in $TARGETS; do
    case "$target" in
      aarch64-apple-darwin)
        arch_target="arm64-apple-macos${min_version}"
        rustflags_env_var="CARGO_TARGET_AARCH64_APPLE_DARWIN_RUSTFLAGS"
        ;;
      x86_64-apple-darwin)
        arch_target="x86_64-apple-macos${min_version}"
        rustflags_env_var="CARGO_TARGET_X86_64_APPLE_DARWIN_RUSTFLAGS"
        ;;
      *)
        echo "Unsupported macOS target: $target" >&2
        exit 2
        ;;
    esac
    target_rustflags="-C linker=$cc_bin -C link-arg=-target -C link-arg=$arch_target -C link-arg=-mmacosx-version-min=${min_version}"

    if [[ "$PROFILE" == "release" ]]; then
      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CARGO_TARGET_DIR="$(macos_rust_target_root)" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        "$rustflags_env_var=$target_rustflags" \
        cargo build --locked -p nostr-vpn-app-core --release --target "$target"

      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CARGO_TARGET_DIR="$(macos_rust_target_root)" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        "$rustflags_env_var=$target_rustflags" \
        cargo build --locked -p nvpn --release --bin nvpn --target "$target"
    else
      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CARGO_TARGET_DIR="$(macos_rust_target_root)" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        "$rustflags_env_var=$target_rustflags" \
        cargo build --locked -p nostr-vpn-app-core --target "$target"

      env \
        SDKROOT="$sdkroot" \
        MACOSX_DEPLOYMENT_TARGET="$min_version" \
        CC="$cc_bin" \
        CXX="$cxx_bin" \
        AR="$ar_bin" \
        RANLIB="$ranlib_bin" \
        CARGO_TARGET_DIR="$(macos_rust_target_root)" \
        CFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_aarch64_apple_darwin="-target arm64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CXXFLAGS_x86_64_apple_darwin="-target x86_64-apple-macos${min_version} -mmacosx-version-min=${min_version}" \
        CARGO_TARGET_AARCH64_APPLE_DARWIN_LINKER="$cc_bin" \
        CARGO_TARGET_X86_64_APPLE_DARWIN_LINKER="$cc_bin" \
        "$rustflags_env_var=$target_rustflags" \
        cargo build --locked -p nvpn --bin nvpn --target "$target"
    fi
  done
}

run_macos_xcframework() {
  local headers_dir="$BUILD_DIR/headers"
  local universal_lib="$BUILD_DIR/libnostr_vpn_app_core_macos.a"
  local framework="$FRAMEWORKS_DIR/NostrVpnAppCore.xcframework"
  local header_path
  local modulemap_path
  local libs=()
  local target

  run_macos_gen_swift
  run_macos_rust

  header_path="$(find "$BINDINGS_DIR" -maxdepth 1 -name '*.h' | head -n 1)"
  modulemap_path="$(find "$BINDINGS_DIR" -maxdepth 1 -name '*.modulemap' | head -n 1)"
  if [[ -z "${header_path:-}" || -z "${modulemap_path:-}" ]]; then
    echo "Missing generated Swift headers/modulemap in $BINDINGS_DIR" >&2
    exit 1
  fi

  rm -rf "$headers_dir" "$universal_lib" "$framework"
  mkdir -p "$headers_dir" "$FRAMEWORKS_DIR" "$BUILD_DIR" "$MACOS_DIR/Resources/binaries"
  cp "$header_path" "$headers_dir/"
  cp "$modulemap_path" "$headers_dir/module.modulemap"

  for target in $TARGETS; do
    libs+=("$(target_static_lib "$target")")
    cp "$(target_cli_bin "$target")" "$MACOS_DIR/Resources/binaries/nvpn"
  done

  if [[ "${#libs[@]}" -eq 1 ]]; then
    cp "${libs[0]}" "$universal_lib"
  else
    lipo -create "${libs[@]}" -output "$universal_lib"
  fi

  xcodebuild -create-xcframework \
    -library "$universal_lib" \
    -headers "$headers_dir" \
    -output "$framework"
}

run_macos_xcodeproj() {
  if ! command -v xcodegen >/dev/null 2>&1; then
    echo "xcodegen is required for macOS project generation" >&2
    exit 1
  fi
  node "$ROOT/scripts/sync-versions.mjs"
  # Resolve NVPN_APP_VERSION_NAME / NVPN_APP_VERSION_CODE from the workspace
  # version so xcodegen can substitute them into project.yml (MARKETING_VERSION
  # and CURRENT_PROJECT_VERSION). Without this each release would carry
  # CFBundleVersion = "1" and Apple would dedupe uploads silently.
  if declare -F resolve_shared_build_metadata >/dev/null 2>&1; then
    resolve_shared_build_metadata "$ROOT"
  fi
  (cd "$MACOS_DIR" && xcodegen generate --spec project.yml)
  # XcodeGen emits objectVersion 77 on newer Xcode installs even though this
  # project uses classic groups. Xcode 15 runners cannot open that format.
  perl -0pi -e 's/objectVersion = 77;/objectVersion = 56;/' "$PROJECT/project.pbxproj"
}

run_macos_build() {
  local host_arch
  local built_app
  host_arch="$(uname -m)"
  run_macos_xcframework
  run_macos_xcodeproj
  built_app="$BUILD_DIR/DerivedData/Build/Products/$XCODE_CONFIGURATION/$APP_NAME"
  # A previously launched DerivedData app can acquire macOS access-control xattrs
  # that make Xcode's later resource copies fail with Operation not permitted.
  rm -rf "$built_app"
  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$XCODE_CONFIGURATION" \
    -derivedDataPath "$BUILD_DIR/DerivedData" \
    -destination "platform=macOS,arch=$host_arch" \
    CODE_SIGNING_ALLOWED=NO \
    build
}

release_version_tag() {
  local version

  if [[ -n "${NVPN_RELEASE_TAG:-}" ]]; then
    case "$NVPN_RELEASE_TAG" in
      v*) printf '%s\n' "$NVPN_RELEASE_TAG" ;;
      *) printf 'v%s\n' "$NVPN_RELEASE_TAG" ;;
    esac
    return 0
  fi

  if declare -F package_version >/dev/null 2>&1; then
    version="$(package_version "$ROOT")"
  else
    version="$(
      awk '
        /^\[workspace.package\]/ { inside = 1; next }
        /^\[/ { inside = 0 }
        inside && $1 == "version" {
          gsub(/"/, "", $3)
          print $3
          exit
        }
      ' "$ROOT/Cargo.toml"
    )"
  fi

  [[ -n "$version" ]] || {
    echo "Could not determine release version from Cargo.toml" >&2
    exit 1
  }
  printf 'v%s\n' "${version#v}"
}

release_app_path() {
  printf '%s/%s\n' "$MACOS_DIST_DIR" "$APP_NAME"
}

release_asset_path() {
  local suffix="$1"
  printf '%s/nostr-vpn-%s-macos-arm64%s\n' "$DIST_DIR" "$(release_version_tag)" "$suffix"
}

developer_id_identity() {
  if [[ -n "${MACOS_SIGNING_IDENTITY:-}" ]]; then
    printf '%s\n' "$MACOS_SIGNING_IDENTITY"
    return 0
  fi
  if [[ -n "${NVPN_MACOS_SIGNING_IDENTITY:-}" ]]; then
    printf '%s\n' "$NVPN_MACOS_SIGNING_IDENTITY"
    return 0
  fi
  security find-identity -v -p codesigning 2>/dev/null \
    | awk -F '"' '/Developer ID Application:/ { print $2; exit }'
}

verify_signing_identity() {
  local identity="$1"
  security find-identity -v -p codesigning | grep -Fq "\"$identity\"" || {
    echo "Developer ID signing identity not found in keychain: $identity" >&2
    exit 1
  }
}

team_id_from_identity() {
  local identity="$1"
  if [[ "$identity" =~ \(([A-Z0-9]+)\)$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
  fi
}

has_notary_credentials() {
  if [[ -n "${MACOS_NOTARY_PROFILE:-}" ]]; then
    return 0
  fi
  [[ -n "${NVPN_ASC_AUTH_KEY_PATH:-}" \
    && -n "${NVPN_ASC_AUTH_KEY_ID:-}" \
    && -n "${NVPN_ASC_AUTH_KEY_ISSUER_ID:-}" ]] && return 0
  [[ -n "${MACOS_NOTARIZE_APPLE_ID:-}" \
    && -n "${MACOS_NOTARIZE_APP_PASSWORD:-}" \
    && -n "${MACOS_NOTARIZE_TEAM_ID:-}" ]]
}

require_notary_credentials() {
  if has_notary_credentials; then
    return 0
  fi
  echo "Notarization credentials are required. Set MACOS_NOTARY_PROFILE, NVPN_ASC_AUTH_KEY_PATH/NVPN_ASC_AUTH_KEY_ID/NVPN_ASC_AUTH_KEY_ISSUER_ID, or MACOS_NOTARIZE_APPLE_ID/MACOS_NOTARIZE_APP_PASSWORD/MACOS_NOTARIZE_TEAM_ID." >&2
  exit 1
}

submit_notarization() {
  local item_path="$1"

  if [[ -n "${NVPN_ASC_AUTH_KEY_PATH:-}" \
    && -n "${NVPN_ASC_AUTH_KEY_ID:-}" \
    && -n "${NVPN_ASC_AUTH_KEY_ISSUER_ID:-}" ]]; then
    xcrun notarytool submit "$item_path" \
      --key "$NVPN_ASC_AUTH_KEY_PATH" \
      --key-id "$NVPN_ASC_AUTH_KEY_ID" \
      --issuer "$NVPN_ASC_AUTH_KEY_ISSUER_ID" \
      --wait \
      --output-format json
    return 0
  fi

  if [[ -n "${MACOS_NOTARY_PROFILE:-}" ]]; then
    xcrun notarytool submit "$item_path" \
      --keychain-profile "$MACOS_NOTARY_PROFILE" \
      --wait \
      --output-format json
    return 0
  fi

  if [[ -n "${MACOS_NOTARIZE_APPLE_ID:-}" \
    && -n "${MACOS_NOTARIZE_APP_PASSWORD:-}" \
    && -n "${MACOS_NOTARIZE_TEAM_ID:-}" ]]; then
    xcrun notarytool submit "$item_path" \
      --apple-id "$MACOS_NOTARIZE_APPLE_ID" \
      --password "$MACOS_NOTARIZE_APP_PASSWORD" \
      --team-id "$MACOS_NOTARIZE_TEAM_ID" \
      --wait \
      --output-format json
    return 0
  fi

  require_notary_credentials
}

app_is_stapled() {
  xcrun stapler validate "$(release_app_path)" >/dev/null 2>&1
}

sign_release_app_deep() {
  local app_path="$1"
  local identity="$2"

  while IFS= read -r -d '' executable; do
    if file "$executable" | grep -Eq 'Mach-O'; then
      codesign --force --timestamp --options runtime --sign "$identity" "$executable"
    fi
  done < <(find "$app_path/Contents" -type f -perm -111 -print0)

  codesign --force --deep --timestamp --options runtime --sign "$identity" "$app_path"
  codesign --verify --deep --strict --verbose=2 "$app_path"
}

run_macos_app() {
  local signing_identity
  local team_id
  local products_dir
  local built_app
  local app_path
  local sign_args=()

  PROFILE="${NVPN_MACOS_RUST_PROFILE:-release}"
  TARGETS="${NVPN_MACOS_RUST_TARGETS:-aarch64-apple-darwin}"
  XCODE_CONFIGURATION="${NVPN_MACOS_XCODE_CONFIGURATION:-Release}"

  run_macos_xcframework
  run_macos_xcodeproj

  signing_identity="$(developer_id_identity || true)"
  if [[ -n "$signing_identity" ]]; then
    verify_signing_identity "$signing_identity"
    team_id="${NVPN_MACOS_DEVELOPMENT_TEAM:-}"
    if [[ -z "$team_id" ]]; then
      team_id="$(team_id_from_identity "$signing_identity" || true)"
    fi
    sign_args+=(
      CODE_SIGNING_ALLOWED=YES
      CODE_SIGNING_REQUIRED=YES
      CODE_SIGN_STYLE=Manual
      CODE_SIGN_IDENTITY="$signing_identity"
      ENABLE_HARDENED_RUNTIME=YES
      CODE_SIGN_INJECT_BASE_ENTITLEMENTS=NO
      OTHER_CODE_SIGN_FLAGS=--timestamp
    )
    if [[ -n "$team_id" ]]; then
      sign_args+=(DEVELOPMENT_TEAM="$team_id")
    fi
  elif bool_is_true "${NVPN_MACOS_REQUIRE_SIGNING:-false}"; then
    echo "Developer ID signing is required for release artifacts. Set MACOS_SIGNING_IDENTITY." >&2
    exit 1
  else
    sign_args+=(CODE_SIGNING_ALLOWED=NO)
  fi

  xcodebuild \
    -project "$PROJECT" \
    -scheme "$SCHEME" \
    -configuration "$XCODE_CONFIGURATION" \
    -derivedDataPath "$BUILD_DIR/ReleaseDerivedData" \
    -destination "generic/platform=macOS" \
    ARCHS=arm64 \
    ONLY_ACTIVE_ARCH=NO \
    SKIP_INSTALL=NO \
    "${sign_args[@]}" \
    build

  products_dir="$BUILD_DIR/ReleaseDerivedData/Build/Products/$XCODE_CONFIGURATION"
  built_app="$(find "$products_dir" -maxdepth 2 -name "$APP_NAME" -print -quit)"
  if [[ -z "$built_app" ]]; then
    echo "No native macOS app bundle found under $products_dir" >&2
    exit 1
  fi

  app_path="$(release_app_path)"
  rm -rf "$app_path"
  mkdir -p "$MACOS_DIST_DIR"
  ditto "$built_app" "$app_path"

  if [[ -n "$signing_identity" ]]; then
    sign_release_app_deep "$app_path" "$signing_identity"
  fi

  printf '%s\n' "$app_path"
}

run_macos_notarize() {
  local app_path
  local notarize_zip

  app_path="$(release_app_path)"
  if [[ ! -d "$app_path" ]]; then
    run_macos_app >/dev/null
  fi

  if ! has_notary_credentials; then
    if bool_is_true "${NVPN_MACOS_REQUIRE_NOTARIZATION:-false}"; then
      require_notary_credentials
    fi
    echo "Skipping macOS notarization because no notary credentials are configured." >&2
    return 0
  fi

  codesign --verify --deep --strict --verbose=2 "$app_path"
  notarize_zip="$BUILD_DIR/$(basename "$app_path" .app)-notary.zip"
  rm -f "$notarize_zip"
  ditto -c -k --sequesterRsrc --keepParent "$app_path" "$notarize_zip"
  submit_notarization "$notarize_zip"
  xcrun stapler staple "$app_path"
  xcrun stapler validate "$app_path"
}

prepare_release_defaults() {
  PROFILE="${NVPN_MACOS_RUST_PROFILE:-release}"
  TARGETS="${NVPN_MACOS_RUST_TARGETS:-aarch64-apple-darwin}"
  XCODE_CONFIGURATION="${NVPN_MACOS_XCODE_CONFIGURATION:-Release}"
  NVPN_MACOS_REQUIRE_SIGNING="${NVPN_MACOS_REQUIRE_SIGNING:-1}"
  NVPN_MACOS_REQUIRE_NOTARIZATION="${NVPN_MACOS_REQUIRE_NOTARIZATION:-1}"
  export NVPN_MACOS_REQUIRE_SIGNING NVPN_MACOS_REQUIRE_NOTARIZATION
}

prepare_signed_notarized_app() {
  local force_rebuild="${1:-true}"
  local app_path

  app_path="$(release_app_path)"
  if bool_is_true "$force_rebuild" || [[ ! -d "$app_path" ]]; then
    run_macos_app >/dev/null
  fi
  if ! app_is_stapled; then
    run_macos_notarize
  fi
}

run_macos_updater_archive() {
  local app_path
  local archive_path

  prepare_release_defaults
  prepare_signed_notarized_app "${NVPN_MACOS_FORCE_REBUILD_APP:-true}"

  app_path="$(release_app_path)"
  archive_path="$(release_asset_path ".app.tar.gz")"
  rm -f "$archive_path"
  tar -czf "$archive_path" -C "$(dirname "$app_path")" "$(basename "$app_path")"
  printf '%s\n' "$archive_path"
}

run_macos_dmg() {
  local app_path
  local dmg_path
  local stage_dir
  local signing_identity

  prepare_release_defaults
  prepare_signed_notarized_app "${NVPN_MACOS_FORCE_REBUILD_APP:-true}"

  app_path="$(release_app_path)"
  dmg_path="$(release_asset_path ".dmg")"
  stage_dir="$BUILD_DIR/dmg-stage"

  rm -rf "$stage_dir" "$dmg_path"
  mkdir -p "$stage_dir" "$DIST_DIR"
  ditto "$app_path" "$stage_dir/$APP_NAME"
  ln -s /Applications "$stage_dir/Applications"
  hdiutil create \
    -volname "$VOLUME_NAME" \
    -srcfolder "$stage_dir" \
    -fs HFS+ \
    -format UDZO \
    -ov \
    "$dmg_path"

  signing_identity="$(developer_id_identity || true)"
  if [[ -n "$signing_identity" ]]; then
    codesign --force --timestamp --sign "$signing_identity" "$dmg_path"
  fi

  if has_notary_credentials; then
    submit_notarization "$dmg_path"
    xcrun stapler staple "$dmg_path"
    xcrun stapler validate "$dmg_path"
    spctl --assess --type open --context context:primary-signature --verbose=2 "$dmg_path"
  elif bool_is_true "${NVPN_MACOS_REQUIRE_NOTARIZATION:-false}"; then
    require_notary_credentials
  fi

  printf '%s\n' "$dmg_path"
}

run_macos_release_artifacts() {
  local tag
  local dmg_path
  local updater_path

  prepare_release_defaults
  tag="$(release_version_tag)"
  rm -f "$DIST_DIR/nostr-vpn-$tag-macos-arm64.zip"

  prepare_signed_notarized_app true
  updater_path="$(release_asset_path ".app.tar.gz")"
  rm -f "$updater_path"
  tar -czf "$updater_path" -C "$MACOS_DIST_DIR" "$APP_NAME"

  NVPN_MACOS_FORCE_REBUILD_APP=0 run_macos_dmg
  dmg_path="$(release_asset_path ".dmg")"

  printf 'Created macOS release artifacts:\n'
  printf '  %s\n' "$dmg_path"
  printf '  %s\n' "$updater_path"
}

case "${1:-}" in
  macos-gen-swift) run_macos_gen_swift ;;
  macos-rust) run_macos_rust ;;
  macos-xcframework) run_macos_xcframework ;;
  macos-xcodeproj) run_macos_xcodeproj ;;
  macos-build) run_macos_build ;;
  macos-app) run_macos_app ;;
  macos-notarize) run_macos_notarize ;;
  macos-dmg) run_macos_dmg ;;
  macos-release-artifacts) run_macos_release_artifacts ;;
  -h|--help|"") usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
