#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
if [[ -n "${NVPN_IOS_ASC_ROOT:-}" && -z "${NVPN_ASC_ROOT:-}" ]]; then
  export NVPN_ASC_ROOT="$NVPN_IOS_ASC_ROOT"
fi
load_appstoreconnect_defaults
resolve_shared_build_metadata "$ROOT"

IOS_BUNDLE_ID="${NVPN_IOS_BUNDLE_ID:-$NVPN_DEFAULT_IOS_BUNDLE_ID}"
APP_NAME="${NVPN_ASC_APP_NAME:-Nostr VPN}"
APP_SKU="${NVPN_ASC_APP_SKU:-$IOS_BUNDLE_ID}"
APP_PRIMARY_LOCALE="${NVPN_ASC_APP_PRIMARY_LOCALE:-en-US}"
ACTION="${1:-put}"

usage() {
  cat <<'EOF'
usage: ./scripts/testflight-internal <ensure-app|compliance|put|attach|wait|status|groups|expire|public|public-submit|public-attach|public-status>

Commands:
  ensure-app   create the App Store Connect app record if it is missing
  compliance   set export-compliance metadata on the uploaded build
  put          wait for the uploaded build, then attach it to internal TestFlight groups
  attach       attach the already-visible build to internal TestFlight groups
  wait         wait until the uploaded build is visible and valid
  status       print current App Store Connect build/internal-group status
  groups       list TestFlight groups for the app
  expire       expire a TestFlight build; defaults to the workspace build number
  public       wait, prepare metadata, submit Beta App Review, and attach external groups
  public-submit
               submit the already-visible build for Beta App Review
  public-attach
               attach the already-visible build to external TestFlight groups
  public-status
               print current public TestFlight status

Environment:
  NVPN_TESTFLIGHT_GROUPS          optional comma-separated internal group names or IDs
  NVPN_TESTFLIGHT_PUBLIC_GROUPS   optional comma-separated external group names or IDs
  NVPN_TESTFLIGHT_PUBLIC_GROUP_NAME
                                   default Public Beta when creating an external group
  NVPN_TESTFLIGHT_PUBLIC_LINK_ENABLED
                                   default true for external groups
  NVPN_TESTFLIGHT_PUBLIC_LINK_LIMIT
                                   optional override; existing limit is preserved
  NVPN_TESTFLIGHT_WHATS_NEW       optional What to Test text
  NVPN_TESTFLIGHT_BETA_DESCRIPTION
                                   optional public beta app description
  NVPN_TESTFLIGHT_PRIVACY_POLICY_URL
                                   required unless already set in App Store Connect
  NVPN_TESTFLIGHT_FEEDBACK_EMAIL  required unless already set in App Store Connect
  NVPN_TESTFLIGHT_CONTACT_FIRST_NAME,
  NVPN_TESTFLIGHT_CONTACT_LAST_NAME,
  NVPN_TESTFLIGHT_CONTACT_PHONE,
  NVPN_TESTFLIGHT_CONTACT_EMAIL   required unless already set in App Store Connect
  NVPN_TESTFLIGHT_REVIEW_NOTES    optional Beta App Review notes
  NVPN_TESTFLIGHT_BUILD_NUMBER    optional build number for expire/status-style operations
  NVPN_TESTFLIGHT_WAIT_ATTEMPTS   default 40
  NVPN_TESTFLIGHT_WAIT_SECONDS    default 30
  NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION
                                   default false for internal-only builds that do not
                                   require export-compliance documentation
  NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID
                                   required when the build uses non-exempt encryption
EOF
}

case "$ACTION" in
  ensure-app|compliance|put|attach|wait|status|groups|expire|public|public-submit|public-attach|public-status)
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

require_var NVPN_ASC_AUTH_KEY_PATH
require_var NVPN_ASC_AUTH_KEY_ID
require_var NVPN_ASC_AUTH_KEY_ISSUER_ID

if [[ ! -f "$NVPN_ASC_AUTH_KEY_PATH" ]]; then
  echo "ASC API key file not found: $NVPN_ASC_AUTH_KEY_PATH" >&2
  exit 1
fi

export NVPN_TESTFLIGHT_ACTION="$ACTION"
export NVPN_IOS_BUNDLE_ID="$IOS_BUNDLE_ID"
export NVPN_ASC_APP_NAME="$APP_NAME"
export NVPN_ASC_APP_SKU="$APP_SKU"
export NVPN_ASC_APP_PRIMARY_LOCALE="$APP_PRIMARY_LOCALE"

python3 <<'PY'
import base64
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

try:
    from cryptography.hazmat.primitives import hashes, serialization
    from cryptography.hazmat.primitives.asymmetric import ec, utils
except ImportError as exc:
    raise SystemExit(
        "Python package 'cryptography' is required for App Store Connect JWT signing."
    ) from exc


BASE_URL = "https://api.appstoreconnect.apple.com/v1/"
ACTION = os.environ["NVPN_TESTFLIGHT_ACTION"]
BUNDLE_ID = os.environ["NVPN_IOS_BUNDLE_ID"]
APP_NAME = os.environ["NVPN_ASC_APP_NAME"]
APP_SKU = os.environ["NVPN_ASC_APP_SKU"]
APP_PRIMARY_LOCALE = os.environ["NVPN_ASC_APP_PRIMARY_LOCALE"]
VERSION_NAME = os.environ["NVPN_APP_VERSION_NAME"]
BUILD_NUMBER = os.environ.get("NVPN_TESTFLIGHT_BUILD_NUMBER", "").strip() or os.environ["NVPN_APP_VERSION_CODE"]
WAIT_ATTEMPTS = int(os.environ.get("NVPN_TESTFLIGHT_WAIT_ATTEMPTS", "40"))
WAIT_SECONDS = int(os.environ.get("NVPN_TESTFLIGHT_WAIT_SECONDS", "30"))
USES_NONEXEMPT_ENCRYPTION_RAW = os.environ.get(
    "NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION", "false"
)
USES_NONEXEMPT_ENCRYPTION = USES_NONEXEMPT_ENCRYPTION_RAW.strip().lower() in {
    "1",
    "true",
    "yes",
    "on",
}
APP_ENCRYPTION_DECLARATION_ID = os.environ.get(
    "NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID", ""
).strip()
PUBLIC_ACTIONS = {"public", "public-submit", "public-attach", "public-status"}
DEFAULT_PUBLIC_GROUP_NAME = "Public Beta"
DEFAULT_PUBLIC_LINK_LIMIT = 9999
DEFAULT_WHATS_NEW = (
    "Please test creating or importing a Nostr VPN network, starting and stopping the iOS "
    "packet tunnel, nearby join requests, peer connectivity, routing settings, "
    "WireGuard exit-node routing, and TestFlight feedback or crash reporting."
)
DEFAULT_BETA_DESCRIPTION = (
    "Nostr VPN is a private VPN and generic WireGuard exit-node utility. It creates "
    "private mesh tunnels between devices and services the user chooses, and can route "
    "traffic through user-controlled WireGuard exit nodes. It is not a public VPN, "
    "consumer internet proxy, anonymity, or stealth browsing service."
)
DEFAULT_REVIEW_NOTES = (
    "No demo account is required. To review, create a network in the app or approve a "
    "signed join request from another Nostr VPN device, then use the main VPN switch to "
    "start and stop the iOS packet tunnel. The app uses Apple's NetworkExtension packet "
    "tunnel APIs for VPN control. Nostr VPN is a private VPN and generic WireGuard "
    "exit-node utility: users choose their own networks, peers, routes, services, and "
    "exit nodes. It does not sell or operate public VPN exits and is not a public "
    "internet stealth, anonymity, or proxy provider. On iOS, first VPN activation "
    "opens an in-app disclosure before starting the tunnel. The disclosure explains "
    "what VPN data is used, how it is used for configured private networks and "
    "WireGuard exit nodes, and that the developer does not sell, use for ads/tracking, "
    "or disclose VPN data to third parties."
)


def fail(message, code=1):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def bool_env(name, default=False):
    raw = os.environ.get(name)
    if raw is None or raw == "":
        return default
    return raw.strip().lower() in {"1", "true", "yes", "on"}


def int_env(name):
    raw = os.environ.get(name)
    if raw is None or raw.strip() == "":
        return None
    return int(raw.strip())


def b64url(data):
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def create_token():
    with open(os.environ["NVPN_ASC_AUTH_KEY_PATH"], "rb") as key_file:
        private_key = serialization.load_pem_private_key(key_file.read(), password=None)

    now = int(time.time())
    header = {
        "alg": "ES256",
        "kid": os.environ["NVPN_ASC_AUTH_KEY_ID"],
        "typ": "JWT",
    }
    payload = {
        "iss": os.environ["NVPN_ASC_AUTH_KEY_ISSUER_ID"],
        "iat": now,
        "exp": now + 20 * 60,
        "aud": "appstoreconnect-v1",
    }
    signing_input = (
        f"{b64url(json.dumps(header, separators=(',', ':')).encode())}."
        f"{b64url(json.dumps(payload, separators=(',', ':')).encode())}"
    ).encode("ascii")
    der_signature = private_key.sign(signing_input, ec.ECDSA(hashes.SHA256()))
    r_value, s_value = utils.decode_dss_signature(der_signature)
    signature = r_value.to_bytes(32, "big") + s_value.to_bytes(32, "big")
    return signing_input.decode("ascii") + "." + b64url(signature)


TOKEN = create_token()


def request(method, path_or_url, params=None, body=None):
    if path_or_url.startswith("https://"):
        url = path_or_url
    else:
        url = BASE_URL + path_or_url
        if params:
            url += "?" + urllib.parse.urlencode(params)

    data = json.dumps(body).encode("utf-8") if body is not None else None
    req = urllib.request.Request(
        url,
        data=data,
        method=method,
        headers={
            "Authorization": f"Bearer {TOKEN}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            raw = response.read().decode("utf-8")
            return response.status, json.loads(raw) if raw else {}
    except urllib.error.HTTPError as error:
        raw = error.read().decode("utf-8", errors="replace")
        try:
            body = json.loads(raw)
        except json.JSONDecodeError:
            body = raw
        return error.code, body


def require_ok(status, body, operation):
    if 200 <= status < 300:
        return body
    fail(f"{operation} failed: HTTP {status}\n{json.dumps(body, indent=2)}")


def get_all(path, params=None):
    status, body = request("GET", path, params)
    body = require_ok(status, body, f"GET {path}")
    data = list(body.get("data", []))
    next_url = body.get("links", {}).get("next")
    while next_url:
        status, body = request("GET", next_url)
        body = require_ok(status, body, f"GET {next_url}")
        data.extend(body.get("data", []))
        next_url = body.get("links", {}).get("next")
    return data


def find_app():
    apps = get_all("apps", {"filter[bundleId]": BUNDLE_ID, "limit": "10"})
    for app in apps:
        if app.get("attributes", {}).get("bundleId") == BUNDLE_ID:
            return app
    return apps[0] if apps else None


def exact_bundle_id():
    bundle_ids = get_all("bundleIds", {"filter[identifier]": BUNDLE_ID, "limit": "200"})
    for bundle_id in bundle_ids:
        if bundle_id.get("attributes", {}).get("identifier") == BUNDLE_ID:
            return bundle_id
    fail(f"No Apple Developer bundle ID found for {BUNDLE_ID}")


def ensure_app():
    app = find_app()
    if app:
        print(
            f"App Store Connect app exists: "
            f"{app.get('attributes', {}).get('name', APP_NAME)} [{app['id']}]"
        )
        return app

    bundle_id = exact_bundle_id()
    body = {
        "data": {
            "type": "apps",
            "attributes": {
                "name": APP_NAME,
                "primaryLocale": APP_PRIMARY_LOCALE,
                "sku": APP_SKU,
                "platform": "IOS",
            },
            "relationships": {
                "bundleId": {
                    "data": {
                        "type": "bundleIds",
                        "id": bundle_id["id"],
                    }
                }
            },
        }
    }
    status, response = request("POST", "apps", body=body)
    if status == 409:
        app = find_app()
        if app:
            print(f"App Store Connect app exists: {app['id']}")
            return app
    app = require_ok(status, response, "Create App Store Connect app").get("data")
    print(f"Created App Store Connect app: {APP_NAME} [{app['id']}]")
    return app


APP = ensure_app() if ACTION == "ensure-app" else find_app()
if APP is None:
    fail(f"No App Store Connect app found for bundle {BUNDLE_ID}. Run ensure-app first.")

APP_ID = APP["id"]

if ACTION == "ensure-app":
    raise SystemExit(0)


def find_build():
    builds = get_all(
        "builds",
        {
            "filter[app]": APP_ID,
            "filter[version]": BUILD_NUMBER,
            "limit": "10",
        },
    )
    for build in builds:
        attrs = build.get("attributes", {})
        if str(attrs.get("version")) == str(BUILD_NUMBER):
            return build
    return builds[0] if builds else None


def get_build(build_id):
    status, body = request(
        "GET",
        f"builds/{build_id}",
        {
            "fields[builds]": (
                "version,uploadedDate,processingState,buildAudienceType,"
                "usesNonExemptEncryption,expired,expirationDate"
            )
        },
    )
    return require_ok(status, body, f"GET builds/{build_id}").get("data")


def wait_for_valid_build():
    for attempt in range(1, WAIT_ATTEMPTS + 1):
        build = find_build()
        if build is not None:
            state = build["attributes"].get("processingState")
            print(
                f"Found TestFlight build {BUILD_NUMBER}: {state} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
            if state == "VALID":
                return build
            if state in {"FAILED", "INVALID"}:
                fail(f"Build {BUILD_NUMBER} is {state}")
        else:
            print(
                f"Waiting for TestFlight build {BUILD_NUMBER} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
        if attempt < WAIT_ATTEMPTS:
            time.sleep(WAIT_SECONDS)
    fail(f"Build {BUILD_NUMBER} did not become VALID in time")


def build_beta_detail(build):
    status, body = request("GET", f"builds/{build['id']}/buildBetaDetail")
    return require_ok(status, body, "Read build beta detail").get("data")


def internal_beta_state(build):
    detail = build_beta_detail(build)
    return detail.get("attributes", {}).get("internalBuildState")


def patch_build_compliance(build, *, uses_nonexempt_encryption, declaration_id=None):
    data = {
        "type": "builds",
        "id": build["id"],
        "attributes": {
            "usesNonExemptEncryption": uses_nonexempt_encryption,
        },
    }
    if declaration_id:
        data["relationships"] = {
            "appEncryptionDeclaration": {
                "data": {
                    "type": "appEncryptionDeclarations",
                    "id": declaration_id,
                }
            }
        }

    status, body = request("PATCH", f"builds/{build['id']}", body={"data": data})
    require_ok(status, body, "Set build export compliance")
    return get_build(build["id"])


def expire_build(build):
    build = get_build(build["id"])
    if build.get("attributes", {}).get("expired") is True:
        print(f"Build {BUILD_NUMBER} is already expired.")
        return build

    status, body = request(
        "PATCH",
        f"builds/{build['id']}",
        body={
            "data": {
                "type": "builds",
                "id": build["id"],
                "attributes": {"expired": True},
            }
        },
    )
    require_ok(status, body, "Expire build")
    print(f"Expired TestFlight build {BUILD_NUMBER}.")
    return get_build(build["id"])


def ensure_export_compliance(build):
    build = get_build(build["id"])
    current = build.get("attributes", {}).get("usesNonExemptEncryption")
    if USES_NONEXEMPT_ENCRYPTION:
        if not APP_ENCRYPTION_DECLARATION_ID:
            fail(
                "Build uses non-exempt encryption. Set "
                "NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID to an approved "
                "App Store Connect app encryption declaration, or set "
                "NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION=false only if export "
                "compliance documentation is not required."
            )
        build = patch_build_compliance(
            build,
            uses_nonexempt_encryption=True,
            declaration_id=APP_ENCRYPTION_DECLARATION_ID,
        )
        print(
            "Linked export-compliance declaration "
            f"{APP_ENCRYPTION_DECLARATION_ID} to build {BUILD_NUMBER}"
        )
        return build

    if current is False:
        print(f"Build {BUILD_NUMBER} export compliance is already set.")
        return build

    build = patch_build_compliance(build, uses_nonexempt_encryption=False)
    print(
        f"Set build {BUILD_NUMBER} export compliance: "
        "no non-exempt encryption documentation required."
    )
    return build


def wait_for_internal_testable_build(build):
    for attempt in range(1, WAIT_ATTEMPTS + 1):
        state = internal_beta_state(build)
        print(
            f"Internal TestFlight state for build {BUILD_NUMBER}: {state} "
            f"(attempt {attempt}/{WAIT_ATTEMPTS})",
            flush=True,
        )
        if state in {"READY_FOR_BETA_TESTING", "IN_BETA_TESTING"}:
            return build
        if state in {"PROCESSING_EXCEPTION", "EXPIRED", "MISSING_EXPORT_COMPLIANCE"}:
            fail(f"Build {BUILD_NUMBER} is not internally testable: {state}")
        if attempt < WAIT_ATTEMPTS:
            time.sleep(WAIT_SECONDS)
    fail(f"Build {BUILD_NUMBER} did not become internally testable in time")


def groups():
    return get_all(
        "betaGroups",
        {
            "filter[app]": APP_ID,
            "fields[betaGroups]": (
                "name,createdDate,isInternalGroup,hasAccessToAllBuilds,"
                "publicLinkEnabled,publicLinkId,publicLinkLimitEnabled,publicLinkLimit,"
                "publicLink,feedbackEnabled"
            ),
            "limit": "200",
        },
    )


def create_internal_group():
    group_name = os.environ.get("NVPN_TESTFLIGHT_DEFAULT_GROUP", "Internal Testers")
    body = {
        "data": {
            "type": "betaGroups",
            "attributes": {
                "name": group_name,
                "isInternalGroup": True,
            },
            "relationships": {
                "app": {
                    "data": {
                        "type": "apps",
                        "id": APP_ID,
                    }
                }
            },
        }
    }
    status, response = request("POST", "betaGroups", body=body)
    group = require_ok(status, response, "Create internal TestFlight group").get("data")
    print(f"Created internal TestFlight group: {group_name}")
    return group


def create_external_group():
    group_name = os.environ.get(
        "NVPN_TESTFLIGHT_PUBLIC_GROUP_NAME", DEFAULT_PUBLIC_GROUP_NAME
    ).strip() or DEFAULT_PUBLIC_GROUP_NAME
    attrs = {
        "name": group_name,
        "isInternalGroup": False,
        "hasAccessToAllBuilds": False,
        "feedbackEnabled": bool_env("NVPN_TESTFLIGHT_FEEDBACK_ENABLED", True),
    }
    if bool_env("NVPN_TESTFLIGHT_PUBLIC_LINK_ENABLED", True):
        attrs["publicLinkEnabled"] = True
        attrs["publicLinkLimitEnabled"] = bool_env(
            "NVPN_TESTFLIGHT_PUBLIC_LINK_LIMIT_ENABLED", True
        )
        if attrs["publicLinkLimitEnabled"]:
            attrs["publicLinkLimit"] = (
                int_env("NVPN_TESTFLIGHT_PUBLIC_LINK_LIMIT")
                or DEFAULT_PUBLIC_LINK_LIMIT
            )

    body = {
        "data": {
            "type": "betaGroups",
            "attributes": attrs,
            "relationships": {
                "app": {
                    "data": {
                        "type": "apps",
                        "id": APP_ID,
                    }
                }
            },
        }
    }
    status, response = request("POST", "betaGroups", body=body)
    group = require_ok(status, response, "Create external TestFlight group").get("data")
    print(f"Created external TestFlight group: {group_name}")
    return group


def select_internal_groups(all_groups):
    wanted_raw = os.environ.get("NVPN_TESTFLIGHT_GROUPS", "").strip()
    if not wanted_raw:
        selected = [
            group
            for group in all_groups
            if group.get("attributes", {}).get("isInternalGroup") is True
        ]
        if not selected:
            selected = [create_internal_group()]
    else:
        wanted = {item.strip() for item in wanted_raw.split(",") if item.strip()}
        selected = [
            group
            for group in all_groups
            if group["id"] in wanted or group.get("attributes", {}).get("name") in wanted
        ]
        matched = {
            group["id"] for group in selected
        } | {group.get("attributes", {}).get("name") for group in selected}
        missing = sorted(wanted - matched)
        if missing:
            fail(f"TestFlight group not found: {', '.join(missing)}")
        external = [
            group.get("attributes", {}).get("name", group["id"])
            for group in selected
            if group.get("attributes", {}).get("isInternalGroup") is not True
        ]
        if external and os.environ.get("NVPN_TESTFLIGHT_ALLOW_EXTERNAL") != "true":
            fail(
                "Refusing to attach external TestFlight group(s): "
                + ", ".join(external)
                + ". Set NVPN_TESTFLIGHT_ALLOW_EXTERNAL=true to override."
            )

    if not selected:
        fail("No internal TestFlight groups found")
    return selected


def select_external_groups(all_groups, *, create_missing=False):
    wanted_raw = (
        os.environ.get("NVPN_TESTFLIGHT_PUBLIC_GROUPS", "").strip()
        or os.environ.get("NVPN_TESTFLIGHT_GROUPS", "").strip()
    )
    if not wanted_raw:
        selected = [
            group
            for group in all_groups
            if group.get("attributes", {}).get("isInternalGroup") is not True
        ]
        if not selected and create_missing:
            selected = [create_external_group()]
    else:
        wanted = {item.strip() for item in wanted_raw.split(",") if item.strip()}
        selected = [
            group
            for group in all_groups
            if group["id"] in wanted or group.get("attributes", {}).get("name") in wanted
        ]
        matched = {
            group["id"] for group in selected
        } | {group.get("attributes", {}).get("name") for group in selected}
        missing = sorted(wanted - matched)
        if missing:
            fail(f"TestFlight group not found: {', '.join(missing)}")

    external = [
        group
        for group in selected
        if group.get("attributes", {}).get("isInternalGroup") is not True
    ]
    if len(external) != len(selected):
        fail("Refusing to attach internal group(s) in public TestFlight mode")
    if not external:
        fail("No external TestFlight groups found")
    return external


def ensure_public_group_settings(selected_groups):
    if not bool_env("NVPN_TESTFLIGHT_PUBLIC_LINK_ENABLED", True):
        return selected_groups

    updated = []
    for group in selected_groups:
        attrs = {
            "feedbackEnabled": bool_env("NVPN_TESTFLIGHT_FEEDBACK_ENABLED", True),
            "publicLinkEnabled": True,
            "publicLinkLimitEnabled": bool_env(
                "NVPN_TESTFLIGHT_PUBLIC_LINK_LIMIT_ENABLED", True
            ),
        }
        if attrs["publicLinkLimitEnabled"]:
            group_attrs = group.get("attributes", {})
            attrs["publicLinkLimit"] = (
                int_env("NVPN_TESTFLIGHT_PUBLIC_LINK_LIMIT")
                or group_attrs.get("publicLinkLimit")
                or DEFAULT_PUBLIC_LINK_LIMIT
            )
        status, body = request(
            "PATCH",
            f"betaGroups/{group['id']}",
            body={
                "data": {
                    "type": "betaGroups",
                    "id": group["id"],
                    "attributes": attrs,
                }
            },
        )
        if 200 <= status < 300:
            updated.append(body.get("data", group))
            continue
        print(
            "Warning: could not enable public link for "
            f"{group.get('attributes', {}).get('name', group['id'])}: "
            f"HTTP {status}",
            file=sys.stderr,
        )
        updated.append(group)
    return updated


def group_has_build(group_id, build):
    for item in get_all(f"betaGroups/{group_id}/builds", {"limit": "200"}):
        if item["id"] == build["id"]:
            return True
    return False


def group_testers(group_id):
    return get_all(
        f"betaGroups/{group_id}/betaTesters",
        {
            "fields[betaTesters]": "firstName,lastName,email,inviteType,state",
            "limit": "200",
        },
    )


def summarize_build(build, selected_groups=None):
    attrs = build["attributes"]
    detail = build_beta_detail(build)
    detail_attrs = detail.get("attributes", {})
    print(f"Nostr VPN {VERSION_NAME} ({BUILD_NUMBER})")
    print(f"Build: {build['id']}")
    print(f"State: {attrs.get('processingState')}")
    print(f"Audience: {attrs.get('buildAudienceType')}")
    print(f"Uses Non-Exempt Encryption: {attrs.get('usesNonExemptEncryption')}")
    print(f"Internal Beta State: {detail_attrs.get('internalBuildState')}")
    print(f"Uploaded: {attrs.get('uploadedDate')}")

    selected = selected_groups or select_internal_groups(groups())
    print("Internal TestFlight groups:")
    for group in selected:
        group_attrs = group.get("attributes", {})
        attached = group_has_build(group["id"], build)
        tester_count = len(group_testers(group["id"]))
        print(
            f"  - {group_attrs.get('name', group['id'])}: "
            f"{'attached' if attached else 'not attached'}, "
            f"{tester_count} tester(s)"
        )


def summarize_public_build(build, selected_groups):
    attrs = build["attributes"]
    detail = build_beta_detail(build)
    detail_attrs = detail.get("attributes", {})
    print(f"Nostr VPN {VERSION_NAME} ({BUILD_NUMBER})")
    print(f"Build: {build['id']}")
    print(f"State: {attrs.get('processingState')}")
    print(f"Audience: {attrs.get('buildAudienceType')}")
    print(f"Uses Non-Exempt Encryption: {attrs.get('usesNonExemptEncryption')}")
    print(f"External Beta State: {detail_attrs.get('externalBuildState')}")
    print(f"Beta Review: {beta_review_state(build)}")
    print(f"Uploaded: {attrs.get('uploadedDate')}")
    print("External TestFlight groups:")
    for group in selected_groups:
        group_attrs = group.get("attributes", {})
        attached = group_has_build(group["id"], build)
        tester_count = len(group_testers(group["id"]))
        public_link = group_attrs.get("publicLink")
        link_suffix = f", {public_link}" if public_link else ""
        print(
            f"  - {group_attrs.get('name', group['id'])}: "
            f"{'attached' if attached else 'not attached'}, "
            f"{tester_count} tester(s), "
            f"public link {'on' if group_attrs.get('publicLinkEnabled') else 'off'}"
            f"{link_suffix}"
        )


def attach_build(build, selected_groups):
    body = {
        "data": [
            {"type": "betaGroups", "id": group["id"]}
            for group in selected_groups
        ]
    }
    status, response_body = request(
        "POST",
        f"builds/{build['id']}/relationships/betaGroups",
        body=body,
    )
    if not (200 <= status < 300 or status == 409):
        fail(f"Attach failed: HTTP {status}\n{json.dumps(response_body, indent=2)}")

    failures = [
        group.get("attributes", {}).get("name", group["id"])
        for group in selected_groups
        if not group_has_build(group["id"], build)
    ]
    if failures:
        fail("Build was not found in group(s) after attach: " + ", ".join(failures))

    print(f"Attached build {BUILD_NUMBER} to internal TestFlight group(s):")
    for group in selected_groups:
        print(f"  - {group.get('attributes', {}).get('name', group['id'])}")


def attach_public_build(build, selected_groups):
    body = {
        "data": [
            {"type": "betaGroups", "id": group["id"]}
            for group in selected_groups
        ]
    }
    status, response_body = request(
        "POST",
        f"builds/{build['id']}/relationships/betaGroups",
        body=body,
    )
    if not (200 <= status < 300 or status == 409):
        fail(f"Attach failed: HTTP {status}\n{json.dumps(response_body, indent=2)}")

    print(f"Attached build {BUILD_NUMBER} to external TestFlight group(s):")
    for group in selected_groups:
        print(f"  - {group.get('attributes', {}).get('name', group['id'])}")


def ensure_public_build(build):
    build = get_build(build["id"])
    state = build["attributes"].get("processingState")
    if state != "VALID":
        fail(f"Build {BUILD_NUMBER} is {state}, not VALID")
    if build["attributes"].get("buildAudienceType") == "INTERNAL_ONLY":
        fail(
            f"Build {BUILD_NUMBER} is INTERNAL_ONLY. Upload a new build with "
            "NVPN_IOS_INTERNAL_ONLY=false before public TestFlight submission."
        )
    return build


def beta_review_detail():
    status, body = request("GET", f"apps/{APP_ID}/betaAppReviewDetail")
    return require_ok(status, body, "Read beta app review detail").get("data")


def beta_app_localizations():
    return get_all(f"apps/{APP_ID}/betaAppLocalizations", {"limit": "200"})


def required_metadata_value(env_name, current, label, default=""):
    value = os.environ.get(env_name, "").strip() or str(current or "").strip() or default
    if not value:
        fail(f"Missing TestFlight review metadata: {label} ({env_name})")
    return value


def patch_beta_review_detail():
    detail = beta_review_detail()
    attrs = detail.get("attributes", {}) if detail else {}
    contact_first = required_metadata_value(
        "NVPN_TESTFLIGHT_CONTACT_FIRST_NAME",
        attrs.get("contactFirstName"),
        "contact first name",
    )
    contact_last = required_metadata_value(
        "NVPN_TESTFLIGHT_CONTACT_LAST_NAME",
        attrs.get("contactLastName"),
        "contact last name",
    )
    contact_phone = required_metadata_value(
        "NVPN_TESTFLIGHT_CONTACT_PHONE",
        attrs.get("contactPhone"),
        "contact phone",
    )
    contact_email = required_metadata_value(
        "NVPN_TESTFLIGHT_CONTACT_EMAIL",
        attrs.get("contactEmail"),
        "contact email",
    )
    notes = (
        os.environ.get("NVPN_TESTFLIGHT_REVIEW_NOTES", "").strip()
        or attrs.get("notes")
        or DEFAULT_REVIEW_NOTES
    )
    body = {
        "data": {
            "type": "betaAppReviewDetails",
            "id": detail["id"],
            "attributes": {
                "contactFirstName": contact_first,
                "contactLastName": contact_last,
                "contactPhone": contact_phone,
                "contactEmail": contact_email,
                "demoAccountRequired": False,
                "notes": notes,
            },
        }
    }
    status, response = request(
        "PATCH",
        f"betaAppReviewDetails/{detail['id']}",
        body=body,
    )
    require_ok(status, response, "Update beta app review detail")
    print("Updated Beta App Review contact and notes")


def upsert_beta_app_localization():
    locale = os.environ.get("NVPN_TESTFLIGHT_LOCALE", "en-US")
    existing = None
    for item in beta_app_localizations():
        if item.get("attributes", {}).get("locale") == locale:
            existing = item
            break
    if existing is None:
        localizations = beta_app_localizations()
        existing = localizations[0] if localizations else None

    attrs = existing.get("attributes", {}) if existing else {}
    description = (
        os.environ.get("NVPN_TESTFLIGHT_BETA_DESCRIPTION", "").strip()
        or attrs.get("description")
        or DEFAULT_BETA_DESCRIPTION
    )
    feedback_email = required_metadata_value(
        "NVPN_TESTFLIGHT_FEEDBACK_EMAIL",
        attrs.get("feedbackEmail"),
        "feedback email",
    )
    privacy_policy_url = required_metadata_value(
        "NVPN_TESTFLIGHT_PRIVACY_POLICY_URL",
        attrs.get("privacyPolicyUrl"),
        "privacy policy URL",
    )
    localization_attrs = {
        "description": description,
        "feedbackEmail": feedback_email,
        "privacyPolicyUrl": privacy_policy_url,
    }
    marketing_url = os.environ.get("NVPN_TESTFLIGHT_MARKETING_URL", "").strip()
    if marketing_url:
        localization_attrs["marketingUrl"] = marketing_url

    if existing:
        status, body = request(
            "PATCH",
            f"betaAppLocalizations/{existing['id']}",
            body={
                "data": {
                    "type": "betaAppLocalizations",
                    "id": existing["id"],
                    "attributes": localization_attrs,
                }
            },
        )
        require_ok(status, body, "Update beta app localization")
    else:
        localization_attrs["locale"] = locale
        status, body = request(
            "POST",
            "betaAppLocalizations",
            body={
                "data": {
                    "type": "betaAppLocalizations",
                    "attributes": localization_attrs,
                    "relationships": {
                        "app": {
                            "data": {
                                "type": "apps",
                                "id": APP_ID,
                            }
                        }
                    },
                }
            },
        )
        require_ok(status, body, "Create beta app localization")
    print(f"Updated beta app localization for {locale}")


def ensure_public_metadata():
    patch_beta_review_detail()
    upsert_beta_app_localization()


def beta_build_localizations(build):
    return get_all(f"builds/{build['id']}/betaBuildLocalizations", {"limit": "200"})


def upsert_what_to_test(build):
    whats_new = os.environ.get("NVPN_TESTFLIGHT_WHATS_NEW", "").strip() or DEFAULT_WHATS_NEW
    locale = os.environ.get("NVPN_TESTFLIGHT_LOCALE", "en-US")
    existing = None
    for item in beta_build_localizations(build):
        if item.get("attributes", {}).get("locale") == locale:
            existing = item
            break

    if existing:
        status, body = request(
            "PATCH",
            f"betaBuildLocalizations/{existing['id']}",
            body={
                "data": {
                    "type": "betaBuildLocalizations",
                    "id": existing["id"],
                    "attributes": {"whatsNew": whats_new},
                }
            },
        )
        require_ok(status, body, "Update What to Test")
    else:
        status, body = request(
            "POST",
            "betaBuildLocalizations",
            body={
                "data": {
                    "type": "betaBuildLocalizations",
                    "attributes": {
                        "locale": locale,
                        "whatsNew": whats_new,
                    },
                    "relationships": {
                        "build": {
                            "data": {
                                "type": "builds",
                                "id": build["id"],
                            }
                        }
                    },
                }
            },
        )
        require_ok(status, body, "Create What to Test")
    print(f"Updated What to Test for {locale}")


def beta_review_state(build):
    status, body = request("GET", f"builds/{build['id']}/betaAppReviewSubmission")
    if status == 404:
        return "not submitted"
    if not (200 <= status < 300):
        return f"unknown (HTTP {status})"
    data = body.get("data")
    if not data:
        return "not submitted"
    attrs = data.get("attributes", {})
    return attrs.get("betaReviewState") or attrs.get("state") or "submitted"


def submit_beta_review(build):
    state = beta_review_state(build)
    if state not in {"not submitted", "REJECTED"}:
        print(f"Beta App Review already submitted: {state}")
        return

    status, body = request(
        "POST",
        "betaAppReviewSubmissions",
        body={
            "data": {
                "type": "betaAppReviewSubmissions",
                "relationships": {
                    "build": {
                        "data": {
                            "type": "builds",
                            "id": build["id"],
                        }
                    }
                },
            }
        },
    )
    if status == 409:
        print("Beta App Review submission already exists")
        return
    require_ok(status, body, "Submit Beta App Review")
    data = body.get("data", {})
    review_state = data.get("attributes", {}).get("betaReviewState") or "submitted"
    print(f"Submitted build {BUILD_NUMBER} for Beta App Review: {review_state}")


if ACTION == "groups":
    print(f"TestFlight groups for {BUNDLE_ID}:")
    for group in groups():
        attrs = group.get("attributes", {})
        kind = "internal" if attrs.get("isInternalGroup") else "external"
        tester_count = len(group_testers(group["id"]))
        public = ""
        if kind == "external":
            link = attrs.get("publicLink")
            public = (
                f", public link {'on' if attrs.get('publicLinkEnabled') else 'off'}"
                + (f", {link}" if link else "")
            )
        print(
            f"  - {attrs.get('name', group['id'])} "
            f"[{kind}] {group['id']} ({tester_count} tester(s)){public}"
        )
    raise SystemExit(0)

if ACTION == "expire":
    build = find_build()
    if build is None:
        fail(f"Build {BUILD_NUMBER} is not visible in App Store Connect")
    build = expire_build(build)
    summarize_public_build(build, select_external_groups(groups()))
    raise SystemExit(0)

if ACTION in {"put", "wait", "public"}:
    build = wait_for_valid_build()
else:
    build = find_build()
    if build is None:
        fail(f"Build {BUILD_NUMBER} is not visible in App Store Connect yet")
    if ACTION in {"attach", "public-submit", "public-attach"} and build["attributes"].get("processingState") != "VALID":
        fail(f"Build {BUILD_NUMBER} is {build['attributes'].get('processingState')}, not VALID")

if ACTION in {"put", "attach", "compliance", "public", "public-submit", "public-attach"}:
    build = ensure_export_compliance(build)
else:
    build = get_build(build["id"])

if ACTION == "compliance":
    summarize_build(build)
    raise SystemExit(0)

if ACTION in PUBLIC_ACTIONS:
    selected_groups = select_external_groups(
        groups(), create_missing=ACTION in {"public", "public-attach"}
    )
    build = ensure_public_build(build)
    if ACTION in {"public", "public-submit"}:
        ensure_public_metadata()
        upsert_what_to_test(build)
        submit_beta_review(build)
    if ACTION in {"public", "public-attach"}:
        selected_groups = ensure_public_group_settings(selected_groups)
        attach_public_build(build, selected_groups)
    summarize_public_build(build, selected_groups)
    raise SystemExit(0)

selected_groups = select_internal_groups(groups())
if ACTION in {"put", "attach"}:
    build = wait_for_internal_testable_build(build)
    attach_build(build, selected_groups)
else:
    summarize_build(build, selected_groups)
