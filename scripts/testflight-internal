#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
load_appstoreconnect_defaults
resolve_shared_build_metadata "$ROOT"

IOS_BUNDLE_ID="${NVPN_IOS_BUNDLE_ID:-to.iris.nvpn}"
APP_NAME="${NVPN_ASC_APP_NAME:-Nostr VPN}"
APP_SKU="${NVPN_ASC_APP_SKU:-$IOS_BUNDLE_ID}"
APP_PRIMARY_LOCALE="${NVPN_ASC_APP_PRIMARY_LOCALE:-en-US}"
ACTION="${1:-put}"

usage() {
  cat <<'EOF'
usage: ./scripts/testflight-internal <ensure-app|compliance|put|attach|wait|status|groups>

Commands:
  ensure-app   create the App Store Connect app record if it is missing
  compliance   set export-compliance metadata on the uploaded build
  put          wait for the uploaded build, then attach it to internal TestFlight groups
  attach       attach the already-visible build to internal TestFlight groups
  wait         wait until the uploaded build is visible and valid
  status       print current App Store Connect build/internal-group status
  groups       list TestFlight groups for the app

Environment:
  NVPN_TESTFLIGHT_GROUPS          optional comma-separated internal group names or IDs
  NVPN_TESTFLIGHT_WAIT_ATTEMPTS   default 40
  NVPN_TESTFLIGHT_WAIT_SECONDS    default 30
  NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION
                                   default false for internal-only builds that do not
                                   require export-compliance documentation
  NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID
                                   required when the build uses non-exempt encryption
EOF
}

case "$ACTION" in
  ensure-app|compliance|put|attach|wait|status|groups)
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

require_var NVPN_ASC_AUTH_KEY_PATH
require_var NVPN_ASC_AUTH_KEY_ID
require_var NVPN_ASC_AUTH_KEY_ISSUER_ID

if [[ ! -f "$NVPN_ASC_AUTH_KEY_PATH" ]]; then
  echo "ASC API key file not found: $NVPN_ASC_AUTH_KEY_PATH" >&2
  exit 1
fi

export NVPN_TESTFLIGHT_ACTION="$ACTION"
export NVPN_IOS_BUNDLE_ID="$IOS_BUNDLE_ID"
export NVPN_ASC_APP_NAME="$APP_NAME"
export NVPN_ASC_APP_SKU="$APP_SKU"
export NVPN_ASC_APP_PRIMARY_LOCALE="$APP_PRIMARY_LOCALE"

python3 <<'PY'
import base64
import json
import os
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

try:
    from cryptography.hazmat.primitives import hashes, serialization
    from cryptography.hazmat.primitives.asymmetric import ec, utils
except ImportError as exc:
    raise SystemExit(
        "Python package 'cryptography' is required for App Store Connect JWT signing."
    ) from exc


BASE_URL = "https://api.appstoreconnect.apple.com/v1/"
ACTION = os.environ["NVPN_TESTFLIGHT_ACTION"]
BUNDLE_ID = os.environ["NVPN_IOS_BUNDLE_ID"]
APP_NAME = os.environ["NVPN_ASC_APP_NAME"]
APP_SKU = os.environ["NVPN_ASC_APP_SKU"]
APP_PRIMARY_LOCALE = os.environ["NVPN_ASC_APP_PRIMARY_LOCALE"]
VERSION_NAME = os.environ["NVPN_APP_VERSION_NAME"]
BUILD_NUMBER = os.environ["NVPN_APP_VERSION_CODE"]
WAIT_ATTEMPTS = int(os.environ.get("NVPN_TESTFLIGHT_WAIT_ATTEMPTS", "40"))
WAIT_SECONDS = int(os.environ.get("NVPN_TESTFLIGHT_WAIT_SECONDS", "30"))
USES_NONEXEMPT_ENCRYPTION_RAW = os.environ.get(
    "NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION", "false"
)
USES_NONEXEMPT_ENCRYPTION = USES_NONEXEMPT_ENCRYPTION_RAW.strip().lower() in {
    "1",
    "true",
    "yes",
    "on",
}
APP_ENCRYPTION_DECLARATION_ID = os.environ.get(
    "NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID", ""
).strip()


def fail(message, code=1):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def b64url(data):
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def create_token():
    with open(os.environ["NVPN_ASC_AUTH_KEY_PATH"], "rb") as key_file:
        private_key = serialization.load_pem_private_key(key_file.read(), password=None)

    now = int(time.time())
    header = {
        "alg": "ES256",
        "kid": os.environ["NVPN_ASC_AUTH_KEY_ID"],
        "typ": "JWT",
    }
    payload = {
        "iss": os.environ["NVPN_ASC_AUTH_KEY_ISSUER_ID"],
        "iat": now,
        "exp": now + 20 * 60,
        "aud": "appstoreconnect-v1",
    }
    signing_input = (
        f"{b64url(json.dumps(header, separators=(',', ':')).encode())}."
        f"{b64url(json.dumps(payload, separators=(',', ':')).encode())}"
    ).encode("ascii")
    der_signature = private_key.sign(signing_input, ec.ECDSA(hashes.SHA256()))
    r_value, s_value = utils.decode_dss_signature(der_signature)
    signature = r_value.to_bytes(32, "big") + s_value.to_bytes(32, "big")
    return signing_input.decode("ascii") + "." + b64url(signature)


TOKEN = create_token()


def request(method, path_or_url, params=None, body=None):
    if path_or_url.startswith("https://"):
        url = path_or_url
    else:
        url = BASE_URL + path_or_url
        if params:
            url += "?" + urllib.parse.urlencode(params)

    data = json.dumps(body).encode("utf-8") if body is not None else None
    req = urllib.request.Request(
        url,
        data=data,
        method=method,
        headers={
            "Authorization": f"Bearer {TOKEN}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            raw = response.read().decode("utf-8")
            return response.status, json.loads(raw) if raw else {}
    except urllib.error.HTTPError as error:
        raw = error.read().decode("utf-8", errors="replace")
        try:
            body = json.loads(raw)
        except json.JSONDecodeError:
            body = raw
        return error.code, body


def require_ok(status, body, operation):
    if 200 <= status < 300:
        return body
    fail(f"{operation} failed: HTTP {status}\n{json.dumps(body, indent=2)}")


def get_all(path, params=None):
    status, body = request("GET", path, params)
    body = require_ok(status, body, f"GET {path}")
    data = list(body.get("data", []))
    next_url = body.get("links", {}).get("next")
    while next_url:
        status, body = request("GET", next_url)
        body = require_ok(status, body, f"GET {next_url}")
        data.extend(body.get("data", []))
        next_url = body.get("links", {}).get("next")
    return data


def find_app():
    apps = get_all("apps", {"filter[bundleId]": BUNDLE_ID, "limit": "10"})
    for app in apps:
        if app.get("attributes", {}).get("bundleId") == BUNDLE_ID:
            return app
    return apps[0] if apps else None


def exact_bundle_id():
    bundle_ids = get_all("bundleIds", {"filter[identifier]": BUNDLE_ID, "limit": "200"})
    for bundle_id in bundle_ids:
        if bundle_id.get("attributes", {}).get("identifier") == BUNDLE_ID:
            return bundle_id
    fail(f"No Apple Developer bundle ID found for {BUNDLE_ID}")


def ensure_app():
    app = find_app()
    if app:
        print(
            f"App Store Connect app exists: "
            f"{app.get('attributes', {}).get('name', APP_NAME)} [{app['id']}]"
        )
        return app

    bundle_id = exact_bundle_id()
    body = {
        "data": {
            "type": "apps",
            "attributes": {
                "name": APP_NAME,
                "primaryLocale": APP_PRIMARY_LOCALE,
                "sku": APP_SKU,
                "platform": "IOS",
            },
            "relationships": {
                "bundleId": {
                    "data": {
                        "type": "bundleIds",
                        "id": bundle_id["id"],
                    }
                }
            },
        }
    }
    status, response = request("POST", "apps", body=body)
    if status == 409:
        app = find_app()
        if app:
            print(f"App Store Connect app exists: {app['id']}")
            return app
    app = require_ok(status, response, "Create App Store Connect app").get("data")
    print(f"Created App Store Connect app: {APP_NAME} [{app['id']}]")
    return app


APP = ensure_app() if ACTION == "ensure-app" else find_app()
if APP is None:
    fail(f"No App Store Connect app found for bundle {BUNDLE_ID}. Run ensure-app first.")

APP_ID = APP["id"]

if ACTION == "ensure-app":
    raise SystemExit(0)


def find_build():
    builds = get_all(
        "builds",
        {
            "filter[app]": APP_ID,
            "filter[version]": BUILD_NUMBER,
            "limit": "10",
        },
    )
    for build in builds:
        attrs = build.get("attributes", {})
        if str(attrs.get("version")) == str(BUILD_NUMBER):
            return build
    return builds[0] if builds else None


def get_build(build_id):
    status, body = request(
        "GET",
        f"builds/{build_id}",
        {
            "fields[builds]": (
                "version,uploadedDate,processingState,buildAudienceType,"
                "usesNonExemptEncryption"
            )
        },
    )
    return require_ok(status, body, f"GET builds/{build_id}").get("data")


def wait_for_valid_build():
    for attempt in range(1, WAIT_ATTEMPTS + 1):
        build = find_build()
        if build is not None:
            state = build["attributes"].get("processingState")
            print(
                f"Found TestFlight build {BUILD_NUMBER}: {state} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
            if state == "VALID":
                return build
            if state in {"FAILED", "INVALID"}:
                fail(f"Build {BUILD_NUMBER} is {state}")
        else:
            print(
                f"Waiting for TestFlight build {BUILD_NUMBER} "
                f"(attempt {attempt}/{WAIT_ATTEMPTS})",
                flush=True,
            )
        if attempt < WAIT_ATTEMPTS:
            time.sleep(WAIT_SECONDS)
    fail(f"Build {BUILD_NUMBER} did not become VALID in time")


def build_beta_detail(build):
    status, body = request("GET", f"builds/{build['id']}/buildBetaDetail")
    return require_ok(status, body, "Read build beta detail").get("data")


def internal_beta_state(build):
    detail = build_beta_detail(build)
    return detail.get("attributes", {}).get("internalBuildState")


def patch_build_compliance(build, *, uses_nonexempt_encryption, declaration_id=None):
    data = {
        "type": "builds",
        "id": build["id"],
        "attributes": {
            "usesNonExemptEncryption": uses_nonexempt_encryption,
        },
    }
    if declaration_id:
        data["relationships"] = {
            "appEncryptionDeclaration": {
                "data": {
                    "type": "appEncryptionDeclarations",
                    "id": declaration_id,
                }
            }
        }

    status, body = request("PATCH", f"builds/{build['id']}", body={"data": data})
    require_ok(status, body, "Set build export compliance")
    return get_build(build["id"])


def ensure_export_compliance(build):
    build = get_build(build["id"])
    current = build.get("attributes", {}).get("usesNonExemptEncryption")
    if USES_NONEXEMPT_ENCRYPTION:
        if not APP_ENCRYPTION_DECLARATION_ID:
            fail(
                "Build uses non-exempt encryption. Set "
                "NVPN_TESTFLIGHT_APP_ENCRYPTION_DECLARATION_ID to an approved "
                "App Store Connect app encryption declaration, or set "
                "NVPN_TESTFLIGHT_USES_NONEXEMPT_ENCRYPTION=false only if export "
                "compliance documentation is not required."
            )
        build = patch_build_compliance(
            build,
            uses_nonexempt_encryption=True,
            declaration_id=APP_ENCRYPTION_DECLARATION_ID,
        )
        print(
            "Linked export-compliance declaration "
            f"{APP_ENCRYPTION_DECLARATION_ID} to build {BUILD_NUMBER}"
        )
        return build

    if current is False:
        print(f"Build {BUILD_NUMBER} export compliance is already set.")
        return build

    build = patch_build_compliance(build, uses_nonexempt_encryption=False)
    print(
        f"Set build {BUILD_NUMBER} export compliance: "
        "no non-exempt encryption documentation required."
    )
    return build


def wait_for_internal_testable_build(build):
    for attempt in range(1, WAIT_ATTEMPTS + 1):
        state = internal_beta_state(build)
        print(
            f"Internal TestFlight state for build {BUILD_NUMBER}: {state} "
            f"(attempt {attempt}/{WAIT_ATTEMPTS})",
            flush=True,
        )
        if state in {"READY_FOR_BETA_TESTING", "IN_BETA_TESTING"}:
            return build
        if state in {"PROCESSING_EXCEPTION", "EXPIRED", "MISSING_EXPORT_COMPLIANCE"}:
            fail(f"Build {BUILD_NUMBER} is not internally testable: {state}")
        if attempt < WAIT_ATTEMPTS:
            time.sleep(WAIT_SECONDS)
    fail(f"Build {BUILD_NUMBER} did not become internally testable in time")


def groups():
    return get_all("betaGroups", {"filter[app]": APP_ID, "limit": "200"})


def create_internal_group():
    group_name = os.environ.get("NVPN_TESTFLIGHT_DEFAULT_GROUP", "Internal Testers")
    body = {
        "data": {
            "type": "betaGroups",
            "attributes": {
                "name": group_name,
                "isInternalGroup": True,
            },
            "relationships": {
                "app": {
                    "data": {
                        "type": "apps",
                        "id": APP_ID,
                    }
                }
            },
        }
    }
    status, response = request("POST", "betaGroups", body=body)
    group = require_ok(status, response, "Create internal TestFlight group").get("data")
    print(f"Created internal TestFlight group: {group_name}")
    return group


def select_internal_groups(all_groups):
    wanted_raw = os.environ.get("NVPN_TESTFLIGHT_GROUPS", "").strip()
    if not wanted_raw:
        selected = [
            group
            for group in all_groups
            if group.get("attributes", {}).get("isInternalGroup") is True
        ]
        if not selected:
            selected = [create_internal_group()]
    else:
        wanted = {item.strip() for item in wanted_raw.split(",") if item.strip()}
        selected = [
            group
            for group in all_groups
            if group["id"] in wanted or group.get("attributes", {}).get("name") in wanted
        ]
        matched = {
            group["id"] for group in selected
        } | {group.get("attributes", {}).get("name") for group in selected}
        missing = sorted(wanted - matched)
        if missing:
            fail(f"TestFlight group not found: {', '.join(missing)}")
        external = [
            group.get("attributes", {}).get("name", group["id"])
            for group in selected
            if group.get("attributes", {}).get("isInternalGroup") is not True
        ]
        if external and os.environ.get("NVPN_TESTFLIGHT_ALLOW_EXTERNAL") != "true":
            fail(
                "Refusing to attach external TestFlight group(s): "
                + ", ".join(external)
                + ". Set NVPN_TESTFLIGHT_ALLOW_EXTERNAL=true to override."
            )

    if not selected:
        fail("No internal TestFlight groups found")
    return selected


def group_has_build(group_id, build):
    for item in get_all(f"betaGroups/{group_id}/builds"):
        if item["id"] == build["id"]:
            return True
    return False


def group_testers(group_id):
    return get_all(
        f"betaGroups/{group_id}/betaTesters",
        {
            "fields[betaTesters]": "firstName,lastName,email,inviteType,state",
            "limit": "200",
        },
    )


def summarize_build(build, selected_groups=None):
    attrs = build["attributes"]
    detail = build_beta_detail(build)
    detail_attrs = detail.get("attributes", {})
    print(f"Nostr VPN {VERSION_NAME} ({BUILD_NUMBER})")
    print(f"Build: {build['id']}")
    print(f"State: {attrs.get('processingState')}")
    print(f"Audience: {attrs.get('buildAudienceType')}")
    print(f"Uses Non-Exempt Encryption: {attrs.get('usesNonExemptEncryption')}")
    print(f"Internal Beta State: {detail_attrs.get('internalBuildState')}")
    print(f"Uploaded: {attrs.get('uploadedDate')}")

    selected = selected_groups or select_internal_groups(groups())
    print("Internal TestFlight groups:")
    for group in selected:
        group_attrs = group.get("attributes", {})
        attached = group_has_build(group["id"], build)
        tester_count = len(group_testers(group["id"]))
        print(
            f"  - {group_attrs.get('name', group['id'])}: "
            f"{'attached' if attached else 'not attached'}, "
            f"{tester_count} tester(s)"
        )


def attach_build(build, selected_groups):
    body = {
        "data": [
            {"type": "betaGroups", "id": group["id"]}
            for group in selected_groups
        ]
    }
    status, response_body = request(
        "POST",
        f"builds/{build['id']}/relationships/betaGroups",
        body=body,
    )
    if not (200 <= status < 300 or status == 409):
        fail(f"Attach failed: HTTP {status}\n{json.dumps(response_body, indent=2)}")

    failures = [
        group.get("attributes", {}).get("name", group["id"])
        for group in selected_groups
        if not group_has_build(group["id"], build)
    ]
    if failures:
        fail("Build was not found in group(s) after attach: " + ", ".join(failures))

    print(f"Attached build {BUILD_NUMBER} to internal TestFlight group(s):")
    for group in selected_groups:
        print(f"  - {group.get('attributes', {}).get('name', group['id'])}")


if ACTION == "groups":
    print(f"TestFlight groups for {BUNDLE_ID}:")
    for group in groups():
        attrs = group.get("attributes", {})
        kind = "internal" if attrs.get("isInternalGroup") else "external"
        tester_count = len(group_testers(group["id"]))
        print(
            f"  - {attrs.get('name', group['id'])} "
            f"[{kind}] {group['id']} ({tester_count} tester(s))"
        )
    raise SystemExit(0)

if ACTION in {"put", "wait"}:
    build = wait_for_valid_build()
else:
    build = find_build()
    if build is None:
        fail(f"Build {BUILD_NUMBER} is not visible in App Store Connect yet")
    if ACTION == "attach" and build["attributes"].get("processingState") != "VALID":
        fail(f"Build {BUILD_NUMBER} is {build['attributes'].get('processingState')}, not VALID")

if ACTION in {"put", "attach", "compliance"}:
    build = ensure_export_compliance(build)
else:
    build = get_build(build["id"])

if ACTION == "compliance":
    summarize_build(build)
    raise SystemExit(0)

selected_groups = select_internal_groups(groups())
if ACTION in {"put", "attach"}:
    build = wait_for_internal_testable_build(build)
    attach_build(build, selected_groups)
else:
    summarize_build(build, selected_groups)
PY
