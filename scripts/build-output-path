#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RAW=0

if [[ ${1:-} == "--raw" ]]; then
  RAW=1
  shift
fi

print_one() {
  if [[ "$RAW" == 1 ]]; then
    printf '%s\n' "$1"
  else
    printf 'Build output: %s\n' "$1"
  fi
}

print_many() {
  if [[ "$RAW" == 1 ]]; then
    printf '%s\n' "$@"
    return
  fi
  printf 'Build outputs:\n'
  for path in "$@"; do
    printf '  %s\n' "$path"
  done
}

cargo_target_dir() {
  (
    cd "$ROOT"
    cargo metadata --no-deps --format-version=1 \
      | python3 -c 'import json,sys; print(json.load(sys.stdin)["target_directory"])'
  )
}

cargo_binary_path() {
  local bin="${1:?missing binary name}"
  local profile="${2:-debug}"
  local target="${3:-}"
  local target_dir
  local exe_suffix=""

  target_dir="$(cargo_target_dir)"
  case "$(uname -s)" in
    MINGW*|MSYS*|CYGWIN*) exe_suffix=".exe" ;;
  esac
  if [[ -n "$target" ]]; then
    print_one "$target_dir/$target/$profile/$bin$exe_suffix"
  else
    print_one "$target_dir/$profile/$bin$exe_suffix"
  fi
}

if [[ ${1:-} == "nvpn" || ${1:-} == "cargo-bin" ]]; then
  if [[ ${1:-} == "cargo-bin" ]]; then
    shift
    bin="${1:-nvpn}"
    shift || true
  else
    bin="nvpn"
    shift
  fi
  profile="debug"
  target=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --release)
        profile="release"
        shift
        ;;
      --debug)
        profile="debug"
        shift
        ;;
      --profile)
        profile="${2:?--profile requires a value}"
        shift 2
        ;;
      --target)
        target="${2:?--target requires a value}"
        shift 2
        ;;
      *)
        echo "unknown build-output-path argument: $1" >&2
        exit 2
        ;;
    esac
  done
  cargo_binary_path "$bin" "$profile" "$target"
  exit 0
fi

macos_app_path() {
  local project="$ROOT/macos/NostrVpnMac.xcodeproj"
  local scheme="NostrVpnMac"
  local build_dir="$ROOT/macos/.build"
  local configuration="${NVPN_MACOS_XCODE_CONFIGURATION:-Debug}"
  local host_arch
  local settings
  local target_build_dir
  local wrapper_name
  local app_path

  host_arch="$(uname -m)"
  settings="$(
    xcodebuild \
      -project "$project" \
      -scheme "$scheme" \
      -configuration "$configuration" \
      -derivedDataPath "$build_dir/DerivedData" \
      -destination "platform=macOS,arch=$host_arch" \
      -showBuildSettings 2>/dev/null || true
  )"
  target_build_dir="$(awk -F' = ' '/^[[:space:]]*(TARGET_BUILD_DIR|BUILT_PRODUCTS_DIR) = / { print $2; exit }' <<<"$settings")"
  wrapper_name="$(awk -F' = ' '/^[[:space:]]*(WRAPPER_NAME|FULL_PRODUCT_NAME) = / { print $2; exit }' <<<"$settings")"
  if [[ -n "${target_build_dir:-}" && -n "${wrapper_name:-}" ]]; then
    app_path="$target_build_dir/$wrapper_name"
    if [[ -d "$app_path" ]]; then
      print_one "$app_path"
      return 0
    fi
  fi

  app_path="$(find "$build_dir/DerivedData/Build/Products" -maxdepth 4 -name 'Nostr VPN.app' -type d -print -quit 2>/dev/null || true)"
  if [[ -n "${app_path:-}" && -d "$app_path" ]]; then
    print_one "$app_path"
    return 0
  fi

  echo "Build output not found under $build_dir/DerivedData/Build/Products" >&2
  return 1
}

case "$(uname -s)" in
  Darwin)
    macos_app_path
    ;;
  Linux)
    print_one "nostr-vpn-linux-dev:/workspace/nostr-vpn/linux/target/debug/nostr-vpn"
    ;;
  MINGW*|MSYS*|CYGWIN*)
    print_one "$ROOT/windows/NostrVpn.Windows/bin/Debug/net8.0-windows/NostrVpn.Windows.exe"
    ;;
  *)
    print_many \
      "$(cargo_binary_path nvpn debug | sed 's/^Build output: //')" \
      "$(cargo_binary_path nostr-vpn-reflector debug | sed 's/^Build output: //')"
    ;;
esac
