#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
load_appstoreconnect_defaults
resolve_shared_build_metadata "$ROOT"

GUI_DIR="$ROOT/crates/nostr-vpn-gui"
APPLE_DIR="$GUI_DIR/src-tauri/gen/apple"
IOS_PROJECT="$APPLE_DIR/nostr-vpn-gui.xcodeproj"
IOS_SCHEME="nostr-vpn-gui_iOS"
IOS_DIST_DIR="$ROOT/dist/ios"
IOS_EXPORT_METHOD="${NVPN_IOS_EXPORT_METHOD:-app-store-connect}"
IOS_SIGNING_STYLE_FROM_ENV="${NVPN_IOS_SIGNING_STYLE+x}"
IOS_SIGNING_STYLE="${NVPN_IOS_SIGNING_STYLE:-automatic}"
IOS_BUNDLE_ID="${NVPN_IOS_BUNDLE_ID:-to.iris.nvpn}"
IOS_PACKET_TUNNEL_BUNDLE_ID="${NVPN_IOS_PACKET_TUNNEL_BUNDLE_ID:-to.iris.nvpn.PacketTunnel}"
IOS_DEVELOPMENT_TEAM="${NVPN_IOS_DEVELOPMENT_TEAM:-J8PPJKD7TA}"
IOS_INTERNAL_ONLY="${NVPN_IOS_INTERNAL_ONLY:-true}"
IOS_ATTACH_INTERNAL_AFTER_UPLOAD="${NVPN_IOS_ATTACH_INTERNAL_AFTER_UPLOAD:-true}"
IOS_ARCHIVE_BASENAME="${NVPN_IOS_ARCHIVE_BASENAME:-$(release_slug ios)}"
IOS_ARCHIVE_PATH="${NVPN_IOS_ARCHIVE_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.xcarchive}"
IOS_EXPORT_PATH="${NVPN_IOS_EXPORT_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}}"
IOS_UPLOAD_LOG_PATH="${NVPN_IOS_UPLOAD_LOG_PATH:-$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}-upload}"
IOS_PROFILES_ENV_PATH="${NVPN_IOS_PROFILES_ENV_PATH:-$IOS_DIST_DIR/provisioning.env}"

AUTH_ARGS=()

usage() {
  cat <<'EOF'
usage: ./scripts/ios-release <print-config|ensure-app|ensure-profiles|prepare|archive|export|upload|internal|all>

Commands:
  ensure-app    create the App Store Connect app record if it is missing
  ensure-profiles
                create/download App Store provisioning profiles for manual export
  prepare       install frontend deps and build the web assets
  archive       build a signed iOS .xcarchive
  export        export the archive as an .ipa
  upload        export the archive and upload the .ipa to App Store Connect
  internal      attach the uploaded build to internal TestFlight groups
  all           ensure app, archive, upload, wait for processing, attach internally
EOF
}

normalize_signing_style() {
  case "$IOS_SIGNING_STYLE" in
    automatic|Automatic)
      IOS_SIGNING_STYLE="automatic"
      IOS_CODE_SIGN_STYLE="Automatic"
      ;;
    manual|Manual)
      IOS_SIGNING_STYLE="manual"
      IOS_CODE_SIGN_STYLE="Manual"
      ;;
    *)
      echo "Unsupported NVPN_IOS_SIGNING_STYLE: $IOS_SIGNING_STYLE" >&2
      exit 2
      ;;
  esac
}

configure_auth_args() {
  AUTH_ARGS=()
  if [[ "$IOS_SIGNING_STYLE" == "manual" ]]; then
    return 0
  fi
  if [[ -n "${NVPN_ASC_AUTH_KEY_PATH:-}" || -n "${NVPN_ASC_AUTH_KEY_ID:-}" || -n "${NVPN_ASC_AUTH_KEY_ISSUER_ID:-}" ]]; then
    require_var NVPN_ASC_AUTH_KEY_PATH
    require_var NVPN_ASC_AUTH_KEY_ID
    require_var NVPN_ASC_AUTH_KEY_ISSUER_ID
    AUTH_ARGS+=(
      -authenticationKeyPath "$NVPN_ASC_AUTH_KEY_PATH"
      -authenticationKeyID "$NVPN_ASC_AUTH_KEY_ID"
      -authenticationKeyIssuerID "$NVPN_ASC_AUTH_KEY_ISSUER_ID"
    )
  fi
  if bool_is_true "${NVPN_IOS_ALLOW_PROVISIONING_UPDATES:-true}"; then
    AUTH_ARGS+=(-allowProvisioningUpdates)
  fi
}

run_xcodebuild() {
  if [[ "${#AUTH_ARGS[@]}" -gt 0 ]]; then
    xcodebuild "${AUTH_ARGS[@]}" "$@"
  else
    xcodebuild "$@"
  fi
}

require_manual_signing_inputs() {
  if [[ "$IOS_SIGNING_STYLE" != "manual" ]]; then
    return 0
  fi
  require_var NVPN_IOS_PROVISIONING_PROFILE_UUID
  require_var NVPN_IOS_PACKET_TUNNEL_PROVISIONING_PROFILE_UUID
  require_var NVPN_IOS_CODE_SIGN_IDENTITY
}

maybe_use_manual_export_profiles() {
  if [[ -z "$IOS_SIGNING_STYLE_FROM_ENV" ]] && bool_is_true "${NVPN_IOS_USE_MANUAL_EXPORT_PROFILES:-true}"; then
    IOS_SIGNING_STYLE="manual"
  fi
}

load_manual_profile_env() {
  if [[ "$IOS_SIGNING_STYLE" != "manual" ]]; then
    return 0
  fi
  if [[ -n "${NVPN_IOS_PROVISIONING_PROFILE_UUID:-}" && -n "${NVPN_IOS_PACKET_TUNNEL_PROVISIONING_PROFILE_UUID:-}" && -n "${NVPN_IOS_CODE_SIGN_IDENTITY:-}" ]]; then
    return 0
  fi

  "$ROOT/scripts/ios-profiles" ensure >&2
  if [[ -f "$IOS_PROFILES_ENV_PATH" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$IOS_PROFILES_ENV_PATH"
    set +a
  fi
}

print_config() {
  cat <<EOF
ios.project=$IOS_PROJECT
ios.scheme=$IOS_SCHEME
ios.bundle.id=$IOS_BUNDLE_ID
ios.packet.tunnel.bundle.id=$IOS_PACKET_TUNNEL_BUNDLE_ID
ios.development.team=$IOS_DEVELOPMENT_TEAM
ios.signing.style=$IOS_SIGNING_STYLE
ios.export.method=$IOS_EXPORT_METHOD
ios.internal.only=$IOS_INTERNAL_ONLY
ios.attach.internal.after.upload=$IOS_ATTACH_INTERNAL_AFTER_UPLOAD
ios.archive.path=$IOS_ARCHIVE_PATH
ios.export.path=$IOS_EXPORT_PATH
ios.profiles.env.path=$IOS_PROFILES_ENV_PATH
app.version.name=$NVPN_APP_VERSION_NAME
app.version.code=$NVPN_APP_VERSION_CODE
build.git.sha=$NVPN_BUILD_GIT_SHA
build.timestamp.utc=$NVPN_BUILD_TIMESTAMP_UTC
asc.auth.key.configured=$([[ -n "${NVPN_ASC_AUTH_KEY_PATH:-}" && -n "${NVPN_ASC_AUTH_KEY_ID:-}" && -n "${NVPN_ASC_AUTH_KEY_ISSUER_ID:-}" ]] && printf true || printf false)
EOF
}

prepare_release_inputs() {
  export NVPN_APP_VERSION="$NVPN_APP_VERSION_NAME"
  export NVPN_BUILD_GIT_SHA
  export NVPN_BUILD_TIMESTAMP_UTC

  (
    cd "$GUI_DIR"
    pnpm install --frozen-lockfile
    pnpm build
  )
}

archive_app() {
  normalize_signing_style
  configure_auth_args
  require_var IOS_DEVELOPMENT_TEAM
  ensure_dir "$IOS_DIST_DIR"
  prepare_release_inputs
  rm -rf "$IOS_ARCHIVE_PATH"

  run_xcodebuild \
    -project "$IOS_PROJECT" \
    -scheme "$IOS_SCHEME" \
    -configuration Release \
    -destination generic/platform=iOS \
    -archivePath "$IOS_ARCHIVE_PATH" \
    MARKETING_VERSION="$NVPN_APP_VERSION_NAME" \
    CURRENT_PROJECT_VERSION="$NVPN_APP_VERSION_CODE" \
    DEVELOPMENT_TEAM="$IOS_DEVELOPMENT_TEAM" \
    CODE_SIGN_STYLE="$IOS_CODE_SIGN_STYLE" \
    archive

  write_manifest "$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.env" \
    archive_path "$IOS_ARCHIVE_PATH" \
    bundle_id "$IOS_BUNDLE_ID" \
    packet_tunnel_bundle_id "$IOS_PACKET_TUNNEL_BUNDLE_ID" \
    app_version_name "$NVPN_APP_VERSION_NAME" \
    app_version_code "$NVPN_APP_VERSION_CODE" \
    build_git_sha "$NVPN_BUILD_GIT_SHA" \
    build_timestamp_utc "$NVPN_BUILD_TIMESTAMP_UTC"
}

write_export_options() {
  local destination="$1"
  local output_path="$2"
  local internal_testing_only_tag="false"
  local manual_block=""

  if bool_is_true "$IOS_INTERNAL_ONLY"; then
    internal_testing_only_tag="true"
  fi

  if [[ "$IOS_SIGNING_STYLE" == "manual" ]]; then
    manual_block="
  <key>signingCertificate</key>
  <string>${NVPN_IOS_CODE_SIGN_IDENTITY}</string>
  <key>provisioningProfiles</key>
  <dict>
    <key>${IOS_BUNDLE_ID}</key>
    <string>${NVPN_IOS_PROVISIONING_PROFILE_UUID}</string>
    <key>${IOS_PACKET_TUNNEL_BUNDLE_ID}</key>
    <string>${NVPN_IOS_PACKET_TUNNEL_PROVISIONING_PROFILE_UUID}</string>
  </dict>"
  fi

  cat > "$output_path" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>destination</key>
  <string>${destination}</string>
  <key>method</key>
  <string>${IOS_EXPORT_METHOD}</string>
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
  <key>signingStyle</key>
  <string>${IOS_SIGNING_STYLE}</string>
  <key>stripSwiftSymbols</key>
  <true/>
  <key>teamID</key>
  <string>${IOS_DEVELOPMENT_TEAM}</string>
  <key>testFlightInternalTestingOnly</key>
  <${internal_testing_only_tag}/>
  <key>uploadSymbols</key>
  <true/>${manual_block}
</dict>
</plist>
EOF
}

export_archive() {
  local export_options_plist
  local ipa_path

  maybe_use_manual_export_profiles
  normalize_signing_style
  load_manual_profile_env
  configure_auth_args
  require_manual_signing_inputs
  require_var IOS_DEVELOPMENT_TEAM
  if [[ ! -d "$IOS_ARCHIVE_PATH" ]]; then
    echo "Archive not found at $IOS_ARCHIVE_PATH. Run ./scripts/ios-release archive first." >&2
    exit 1
  fi

  export_options_plist="$(mktemp "${TMPDIR:-/tmp}/nvpn-ios-export-options.XXXXXX")"
  mv "$export_options_plist" "${export_options_plist}.plist"
  export_options_plist="${export_options_plist}.plist"
  trap 'rm -f "${export_options_plist:-}"' EXIT
  write_export_options export "$export_options_plist"

  rm -rf "$IOS_EXPORT_PATH"
  ensure_dir "$IOS_EXPORT_PATH"
  run_xcodebuild \
    -exportArchive \
    -archivePath "$IOS_ARCHIVE_PATH" \
    -exportPath "$IOS_EXPORT_PATH" \
    -exportOptionsPlist "$export_options_plist" >&2

  ipa_path="$(find "$IOS_EXPORT_PATH" -maxdepth 1 -type f -name '*.ipa' | sort | head -n 1)"
  if [[ -z "${ipa_path:-}" ]]; then
    echo "iOS export did not produce an IPA in $IOS_EXPORT_PATH" >&2
    exit 1
  fi

  write_manifest "$IOS_DIST_DIR/${IOS_ARCHIVE_BASENAME}.ipa.env" \
    ipa_path "$ipa_path" \
    archive_path "$IOS_ARCHIVE_PATH" \
    bundle_id "$IOS_BUNDLE_ID" \
    packet_tunnel_bundle_id "$IOS_PACKET_TUNNEL_BUNDLE_ID" \
    app_version_name "$NVPN_APP_VERSION_NAME" \
    app_version_code "$NVPN_APP_VERSION_CODE" \
    build_git_sha "$NVPN_BUILD_GIT_SHA" \
    build_timestamp_utc "$NVPN_BUILD_TIMESTAMP_UTC"

  rm -f "$export_options_plist"
  trap - EXIT

  printf '%s\n' "$ipa_path"
}

upload_archive() {
  local ipa_path
  "$ROOT/scripts/testflight-internal" ensure-app
  ipa_path="$(export_archive)"

  require_var NVPN_ASC_AUTH_KEY_ID
  require_var NVPN_ASC_AUTH_KEY_ISSUER_ID
  if [[ -n "${NVPN_ASC_AUTH_KEY_PATH:-}" && ! -f "$NVPN_ASC_AUTH_KEY_PATH" ]]; then
    echo "ASC API key file not found: $NVPN_ASC_AUTH_KEY_PATH" >&2
    exit 1
  fi

  ensure_dir "$IOS_UPLOAD_LOG_PATH"
  xcrun altool --upload-app \
    --type ios \
    --file "$ipa_path" \
    --apiKey "$NVPN_ASC_AUTH_KEY_ID" \
    --apiIssuer "$NVPN_ASC_AUTH_KEY_ISSUER_ID" \
    | tee "$IOS_UPLOAD_LOG_PATH/altool-upload.log"

  if bool_is_true "$IOS_ATTACH_INTERNAL_AFTER_UPLOAD"; then
    "$ROOT/scripts/testflight-internal" put
  fi
}

case "${1:-}" in
  print-config)
    print_config
    ;;
  ensure-app)
    "$ROOT/scripts/testflight-internal" ensure-app
    ;;
  ensure-profiles)
    "$ROOT/scripts/ios-profiles" ensure
    ;;
  prepare)
    prepare_release_inputs
    ;;
  archive)
    archive_app
    ;;
  export)
    export_archive
    ;;
  upload)
    upload_archive
    ;;
  internal)
    "$ROOT/scripts/testflight-internal" put
    ;;
  all)
    "$ROOT/scripts/testflight-internal" ensure-app
    archive_app
    upload_archive
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
