#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
WORKSPACE=$(git rev-parse --show-toplevel)

export NVPN_LINUX_MUSL_IMAGE=${NVPN_ARMV6_MUSL_IMAGE:-${NVPN_LINUX_MUSL_IMAGE:-messense/rust-musl-cross:arm-musleabihf}}
export NVPN_LINUX_MUSL_BUILD_ROOT=${NVPN_ARMV6_BUILD_ROOT:-${NVPN_LINUX_MUSL_BUILD_ROOT:-${TMPDIR:-/tmp}}}
export NVPN_LINUX_MUSL_TARGET_DIR=${NVPN_ARMV6_TARGET_DIR:-${NVPN_LINUX_MUSL_TARGET_DIR:-$WORKSPACE/target/nvpn-armv6-musl}}
export NVPN_LINUX_MUSL_KEEP_WORK=${NVPN_ARMV6_KEEP_WORK:-${NVPN_LINUX_MUSL_KEEP_WORK:-0}}

exec "$SCRIPT_DIR/build-nvpn-linux-musl" arm-unknown-linux-musleabihf
