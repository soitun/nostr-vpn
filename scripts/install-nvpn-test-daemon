#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INSTALLER="${NVPN_INSTALL_TEST_DAEMON:-/usr/local/sbin/nvpn-install-test-daemon}"
STAGE_ROOT="${NVPN_TEST_DAEMON_STAGE_ROOT:-/tmp}"
INSTALL_MODE="${NVPN_TEST_DAEMON_INSTALL_MODE:-auto}"
SERVICE_IFACE="${NVPN_TEST_DAEMON_IFACE:-utun}"
SERVICE_CONFIG="${NVPN_TEST_DAEMON_CONFIG:-}"
MESH_REFRESH_INTERVAL_SECS="${NVPN_TEST_DAEMON_MESH_REFRESH_INTERVAL_SECS:-20}"
LOCK_SNAPSHOT=""
FIPS_EXTERNAL_PUBSUB="${NVPN_FIPS_EXTERNAL_PUBSUB:-0}"

case "$(uname -s)" in
  Darwin) ;;
  *)
    echo "install-nvpn-test-daemon is macOS-only" >&2
    exit 1
    ;;
esac

restore_lock() {
  if [[ -n "$LOCK_SNAPSHOT" && -f "$LOCK_SNAPSHOT" && -f "$ROOT/Cargo.lock" ]]; then
    if ! cmp -s "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"; then
      cp -p "$LOCK_SNAPSHOT" "$ROOT/Cargo.lock"
      printf 'restored Cargo.lock after local-FIPS cargo run\n'
    fi
    rm -f "$LOCK_SNAPSHOT"
  fi
}

prepare_lock_restore() {
  [[ -z "$LOCK_SNAPSHOT" ]] || return 0
  LOCK_SNAPSHOT="$(mktemp)"
  cp -p "$ROOT/Cargo.lock" "$LOCK_SNAPSHOT"
  trap restore_lock EXIT
}

case "$INSTALL_MODE" in
  auto|helper|service) ;;
  *)
    echo "NVPN_TEST_DAEMON_INSTALL_MODE must be auto, helper, or service" >&2
    exit 1
    ;;
esac

cd "$ROOT"
cargo_config_args=()
patch_local_fips=0
if [[ "${NVPN_PATCH_LOCAL_FIPS:-0}" =~ ^(1|true|TRUE|True|yes|YES|Yes|on|ON|On)$ ]]; then
  patch_local_fips=1
  FIPS_REPO_PATH="${NVPN_FIPS_REPO_PATH:-$ROOT/../fips}"
  if [[ ! -f "$FIPS_REPO_PATH/crates/fips-core/Cargo.toml" \
        || ! -f "$FIPS_REPO_PATH/crates/fips-endpoint/Cargo.toml" \
        || ! -f "$FIPS_REPO_PATH/crates/fips-identity/Cargo.toml" ]]; then
    echo "NVPN_PATCH_LOCAL_FIPS=1 requires NVPN_FIPS_REPO_PATH to point at a fips checkout" >&2
    exit 1
  fi
  prepare_lock_restore
  cargo_config_args+=(--config "patch.crates-io.fips-core.path=\"$FIPS_REPO_PATH/crates/fips-core\"")
  cargo_config_args+=(--config "patch.crates-io.fips-endpoint.path=\"$FIPS_REPO_PATH/crates/fips-endpoint\"")
  cargo_config_args+=(--config "patch.crates-io.fips-identity.path=\"$FIPS_REPO_PATH/crates/fips-identity\"")
fi

if [[ "$FIPS_EXTERNAL_PUBSUB" =~ ^(1|true|TRUE|True|yes|YES|Yes|on|ON|On)$ \
      && "$patch_local_fips" != "1" ]]; then
  echo "NVPN_FIPS_EXTERNAL_PUBSUB=1 requires NVPN_PATCH_LOCAL_FIPS=1" >&2
  exit 1
fi

cargo_build=(cargo)
cargo_metadata=(cargo)
if ((${#cargo_config_args[@]})); then
  cargo_build+=("${cargo_config_args[@]}")
  cargo_metadata+=("${cargo_config_args[@]}")
fi

cargo_feature_args=()
if [[ "$patch_local_fips" == "1" ]]; then
  fips_core_version="$(awk -F'"' '/^version = / { print $2; exit }' "$FIPS_REPO_PATH/crates/fips-core/Cargo.toml")"
  fips_endpoint_version="$(awk -F'"' '/^version = / { print $2; exit }' "$FIPS_REPO_PATH/crates/fips-endpoint/Cargo.toml")"
  if [[ -z "$fips_core_version" || -z "$fips_endpoint_version" ]]; then
    echo "failed to read local FIPS crate versions" >&2
    exit 1
  fi
  "${cargo_build[@]}" update -p fips-core --precise "$fips_core_version"
  "${cargo_build[@]}" update -p fips-endpoint --precise "$fips_endpoint_version"
fi
if [[ "$FIPS_EXTERNAL_PUBSUB" =~ ^(1|true|TRUE|True|yes|YES|Yes|on|ON|On)$ ]]; then
  cargo_feature_args+=(--features fips-external-pubsub)
fi

"${cargo_build[@]}" build -p nvpn --bin nvpn --release "${cargo_feature_args[@]}"

BIN="$("$ROOT/scripts/build-output-path" --raw nvpn --release)"
if [[ ! -x "$BIN" ]]; then
  echo "built nvpn binary not found at Cargo target path: $BIN" >&2
  exit 1
fi

EXPECTED_VERSION="$(
  "${cargo_metadata[@]}" metadata --no-deps --format-version=1 \
    | python3 -c 'import json,sys; print(next(p["version"] for p in json.load(sys.stdin)["packages"] if p["name"] == "nvpn"))'
)"
ACTUAL_VERSION="$("$BIN" version)"
if [[ "$ACTUAL_VERSION" != "$EXPECTED_VERSION" ]]; then
  cat >&2 <<EOF
refusing to install stale nvpn binary
  expected version: $EXPECTED_VERSION
  actual version:   $ACTUAL_VERSION
  binary:           $BIN
EOF
  exit 1
fi

STAGE_DIR="$STAGE_ROOT/nvpn-build-$ACTUAL_VERSION-$(date +%s)-$$/release"
mkdir -p "$STAGE_DIR"
cp "$BIN" "$STAGE_DIR/nvpn"
xattr -c "$STAGE_DIR/nvpn" 2>/dev/null || true
codesign --force --sign - "$STAGE_DIR/nvpn"

echo "Installing nvpn $ACTUAL_VERSION from $STAGE_DIR/nvpn"
if [[ "$INSTALL_MODE" == "helper" || ( "$INSTALL_MODE" == "auto" && -x "$INSTALLER" ) ]]; then
  if [[ ! -x "$INSTALLER" ]]; then
    echo "missing installer helper: $INSTALLER" >&2
    exit 1
  fi
  sudo "$INSTALLER" "$STAGE_DIR/nvpn"
else
  service_args=(service install --force --iface "$SERVICE_IFACE" --mesh-refresh-interval-secs "$MESH_REFRESH_INTERVAL_SECS")
  if [[ -n "$SERVICE_CONFIG" ]]; then
    service_args+=(--config "$SERVICE_CONFIG")
  fi
  sudo "$STAGE_DIR/nvpn" "${service_args[@]}"
fi
printf '%s\n' "$STAGE_DIR/nvpn"
