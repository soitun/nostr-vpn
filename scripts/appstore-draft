#!/usr/bin/env bash

set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck disable=SC1091
source "$ROOT/scripts/release_common.sh"

load_release_env "$ROOT"
load_appstoreconnect_defaults
resolve_shared_build_metadata "$ROOT"

IOS_BUNDLE_ID="${NVPN_IOS_BUNDLE_ID:-$NVPN_DEFAULT_IOS_BUNDLE_ID}"
APP_PRIMARY_LOCALE="${NVPN_ASC_APP_PRIMARY_LOCALE:-en-US}"
SCREENSHOT_ROOT="${NVPN_IOS_SCREENSHOT_DIR:-$ROOT/artifacts/appstore-screenshots}"
ACTION="${1:-put}"

usage() {
  cat <<'EOF'
usage: ./scripts/appstore-draft <put|submit|status>

Creates or updates the editable iOS App Store version draft for the workspace
version, links the matching App Store Connect build, updates en-US metadata,
and uploads screenshots from artifacts/appstore-screenshots.

Environment:
  NVPN_ASC_AUTH_KEY_PATH, NVPN_ASC_AUTH_KEY_ID, NVPN_ASC_AUTH_KEY_ISSUER_ID
                              App Store Connect API key settings
  NVPN_IOS_BUNDLE_ID          app bundle id (default fi.siriusbusiness.nvpn)
  NVPN_ASC_APP_PRIMARY_LOCALE locale (default en-US)
  NVPN_IOS_SCREENSHOT_DIR     screenshot root (default artifacts/appstore-screenshots)
  NVPN_APPSTORE_DESCRIPTION   optional App Store description override
  NVPN_APPSTORE_KEYWORDS      optional keywords override
  NVPN_APPSTORE_SUPPORT_URL   optional support URL override
  NVPN_APPSTORE_PRIVACY_URL   optional privacy policy URL override
  NVPN_APPSTORE_MARKETING_URL optional marketing URL override
  NVPN_APPSTORE_COPYRIGHT     optional copyright override
  NVPN_APPSTORE_CATEGORY_ID   optional primary category id (default UTILITIES)
  NVPN_APPSTORE_REVIEW_*      optional App Review contact/notes overrides
EOF
}

case "$ACTION" in
  put|submit|status)
    ;;
  -h|--help|help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

require_var NVPN_ASC_AUTH_KEY_PATH
require_var NVPN_ASC_AUTH_KEY_ID
require_var NVPN_ASC_AUTH_KEY_ISSUER_ID

if [[ ! -f "$NVPN_ASC_AUTH_KEY_PATH" ]]; then
  echo "ASC API key file not found: $NVPN_ASC_AUTH_KEY_PATH" >&2
  exit 1
fi

export NVPN_APPSTORE_ACTION="$ACTION"
export NVPN_IOS_BUNDLE_ID="$IOS_BUNDLE_ID"
export NVPN_ASC_APP_PRIMARY_LOCALE="$APP_PRIMARY_LOCALE"
export NVPN_IOS_SCREENSHOT_DIR="$SCREENSHOT_ROOT"

python3 <<'PY'
import base64
import hashlib
import json
import mimetypes
import os
from pathlib import Path
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

try:
    from cryptography.hazmat.primitives import hashes, serialization
    from cryptography.hazmat.primitives.asymmetric import ec, utils
except ImportError as exc:
    raise SystemExit(
        "Python package 'cryptography' is required for App Store Connect JWT signing."
    ) from exc


BASE_URL = "https://api.appstoreconnect.apple.com/v1/"
ACTION = os.environ["NVPN_APPSTORE_ACTION"]
BUNDLE_ID = os.environ["NVPN_IOS_BUNDLE_ID"]
LOCALE = os.environ["NVPN_ASC_APP_PRIMARY_LOCALE"]
VERSION_NAME = os.environ["NVPN_APP_VERSION_NAME"]
BUILD_NUMBER = os.environ["NVPN_APP_VERSION_CODE"]
SCREENSHOT_ROOT = Path(os.environ["NVPN_IOS_SCREENSHOT_DIR"]) / LOCALE

EDITABLE_STATES = {
    "PREPARE_FOR_SUBMISSION",
    "DEVELOPER_REJECTED",
    "REJECTED",
    "METADATA_REJECTED",
}

DEFAULT_DESCRIPTION = """Nostr VPN creates private mesh VPN networks between your own devices and trusted peers.

Create a network, invite devices, start the VPN, and reach your private services through encrypted tunnels. Devices can use readable MagicDNS names, direct LAN paths when available, relay-assisted paths when needed, and optional exit-node routing through a peer or WireGuard upstream you control.

You choose the networks, peers, relays, routes, and exit nodes. Nostr VPN does not sell or operate public VPN exits and is not a public internet proxy, anonymity, or stealth browsing service."""

DEFAULT_PROMOTIONAL_TEXT = "Private mesh VPN for your own devices and trusted peers."
DEFAULT_WHATS_NEW = """Initial public launch draft for the current Nostr VPN release.

This build includes native mobile network management, device presence, MagicDNS names, private mesh routing, WireGuard upstream settings, and TestFlight hardening."""
DEFAULT_KEYWORDS = "VPN,mesh,WireGuard,Nostr,private network,LAN,peer-to-peer,DNS"
DEFAULT_SUPPORT_URL = "https://github.com/mmalmi/nostr-vpn/issues"
DEFAULT_MARKETING_URL = "https://nostrvpn.org/"
DEFAULT_PRIVACY_URL = "https://nostrvpn.org/privacy/"
DEFAULT_COPYRIGHT = "2026 Sirius Business Oy"
DEFAULT_CATEGORY_ID = "UTILITIES"
DEFAULT_CONTENT_RIGHTS_DECLARATION = "DOES_NOT_USE_THIRD_PARTY_CONTENT"
DEFAULT_PRICE_TERRITORY = "USA"
DEFAULT_REVIEW_CONTACT_FIRST = "Sirius"
DEFAULT_REVIEW_CONTACT_LAST = "Business"
DEFAULT_REVIEW_CONTACT_PHONE = "+35868028660"
DEFAULT_REVIEW_CONTACT_EMAIL = "nostrvpn@siriusbusiness.fi"
DEFAULT_REVIEW_NOTES = """Nostr VPN is a private mesh VPN for networks, peers, relays, routes, and exit nodes that the user configures.

No demo account is required. To review the app, create a network in the app, add/import a peer invite if you have another device, and start the VPN from the Devices tab. The app shows the required VPN data-use disclosure before enabling the tunnel, then iOS shows the system VPN permission prompt.

Nostr VPN is not a public VPN, public proxy, anonymity, stealth, or censorship-circumvention service. Sirius Business does not sell VPN data, use it for ads or tracking, or disclose it to third parties."""


def fail(message, code=1):
    print(message, file=sys.stderr)
    raise SystemExit(code)


def env_value(name, default=""):
    return os.environ.get(name, "").strip() or default


def required_metadata_value(name, current, label, default=""):
    value = env_value(name, current or default)
    if not value:
        fail(f"{name} or existing {label} is required")
    return value


def b64url(data):
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def create_token():
    with open(os.environ["NVPN_ASC_AUTH_KEY_PATH"], "rb") as key_file:
        private_key = serialization.load_pem_private_key(key_file.read(), password=None)

    now = int(time.time())
    header = {
        "alg": "ES256",
        "kid": os.environ["NVPN_ASC_AUTH_KEY_ID"],
        "typ": "JWT",
    }
    payload = {
        "iss": os.environ["NVPN_ASC_AUTH_KEY_ISSUER_ID"],
        "iat": now,
        "exp": now + 20 * 60,
        "aud": "appstoreconnect-v1",
    }
    signing_input = (
        f"{b64url(json.dumps(header, separators=(',', ':')).encode())}."
        f"{b64url(json.dumps(payload, separators=(',', ':')).encode())}"
    ).encode("ascii")
    der_signature = private_key.sign(signing_input, ec.ECDSA(hashes.SHA256()))
    r_value, s_value = utils.decode_dss_signature(der_signature)
    signature = r_value.to_bytes(32, "big") + s_value.to_bytes(32, "big")
    return signing_input.decode("ascii") + "." + b64url(signature)


TOKEN = create_token()


def request(method, path_or_url, params=None, body=None, headers=None, auth=True):
    if path_or_url.startswith("https://"):
        url = path_or_url
    else:
        url = BASE_URL + path_or_url
        if params:
            url += "?" + urllib.parse.urlencode(params)

    data = None
    request_headers = dict(headers or {})
    if body is not None:
        data = json.dumps(body).encode("utf-8")
        request_headers["Content-Type"] = "application/json"
    if auth:
        request_headers["Authorization"] = f"Bearer {TOKEN}"

    req = urllib.request.Request(url, data=data, headers=request_headers, method=method)
    try:
        with urllib.request.urlopen(req) as response:
            raw = response.read()
            if not raw:
                return response.status, {}
            return response.status, json.loads(raw.decode("utf-8"))
    except urllib.error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        try:
            body = json.loads(raw) if raw else {}
        except json.JSONDecodeError:
            body = {"raw": raw}
        return exc.code, body


def upload_request(operation, chunk):
    headers = {
        header["name"]: header["value"]
        for header in operation.get("requestHeaders", [])
    }
    req = urllib.request.Request(
        operation["url"],
        data=chunk,
        headers=headers,
        method=operation.get("method", "PUT"),
    )
    try:
        with urllib.request.urlopen(req) as response:
            response.read()
            return response.status
    except urllib.error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        fail(f"Screenshot upload failed: HTTP {exc.code}\n{raw}")


def require_ok(status, body, label):
    if 200 <= status < 300:
        return body
    fail(f"{label} failed: HTTP {status}\n{json.dumps(body, indent=2)}")


def get_all(path, params=None):
    items = []
    next_url = None
    while True:
        if next_url:
            status, body = request("GET", next_url)
        else:
            query = {"limit": "200"}
            if params:
                query.update(params)
            status, body = request("GET", path, query)
        require_ok(status, body, f"GET {path}")
        items.extend(body.get("data", []))
        next_url = body.get("links", {}).get("next")
        if not next_url:
            return items


def find_app():
    apps = get_all("apps", {"filter[bundleId]": BUNDLE_ID, "limit": "10"})
    for app in apps:
        if app.get("attributes", {}).get("bundleId") == BUNDLE_ID:
            return app
    return apps[0] if apps else None


def app_store_versions(app_id):
    return get_all(
        f"apps/{app_id}/appStoreVersions",
        {
            "fields[appStoreVersions]": (
                "versionString,appStoreState,platform,createdDate,copyright,"
                "releaseType,usesIdfa,downloadable"
            ),
            "limit": "200",
        },
    )


def patch_version(version, attrs):
    status, body = request(
        "PATCH",
        f"appStoreVersions/{version['id']}",
        body={
            "data": {
                "type": "appStoreVersions",
                "id": version["id"],
                "attributes": attrs,
            }
        },
    )
    return require_ok(status, body, "Update App Store version").get("data")


def create_version(app_id):
    status, body = request(
        "POST",
        "appStoreVersions",
        body={
            "data": {
                "type": "appStoreVersions",
                "attributes": {
                    "platform": "IOS",
                    "versionString": VERSION_NAME,
                    "releaseType": "AFTER_APPROVAL",
                    "usesIdfa": False,
                },
                "relationships": {
                    "app": {"data": {"type": "apps", "id": app_id}}
                },
            }
        },
    )
    return require_ok(status, body, "Create App Store version").get("data")


def ensure_version(app_id):
    versions = app_store_versions(app_id)
    for version in versions:
        attrs = version.get("attributes", {})
        if attrs.get("platform") == "IOS" and attrs.get("versionString") == VERSION_NAME:
            return patch_version(
                version,
                {
                    "releaseType": "AFTER_APPROVAL",
                    "usesIdfa": False,
                    "copyright": env_value(
                        "NVPN_APPSTORE_COPYRIGHT",
                        DEFAULT_COPYRIGHT,
                    ),
                },
            )

    editable = [
        version
        for version in versions
        if version.get("attributes", {}).get("platform") == "IOS"
        and version.get("attributes", {}).get("appStoreState") in EDITABLE_STATES
    ]
    if editable:
        return patch_version(
            editable[0],
            {
                "versionString": VERSION_NAME,
                "releaseType": "AFTER_APPROVAL",
                "usesIdfa": False,
                "copyright": env_value(
                    "NVPN_APPSTORE_COPYRIGHT",
                    DEFAULT_COPYRIGHT,
                ),
            },
        )

    return create_version(app_id)


def version_localizations(version_id):
    return get_all(
        f"appStoreVersions/{version_id}/appStoreVersionLocalizations",
        {
            "fields[appStoreVersionLocalizations]": (
                "description,locale,keywords,marketingUrl,promotionalText,"
                "supportUrl,whatsNew"
            ),
            "limit": "200",
        },
    )


def metadata_attrs(existing=None):
    current = existing.get("attributes", {}) if existing else {}
    description = env_value(
        "NVPN_APPSTORE_DESCRIPTION",
        current.get("description") or DEFAULT_DESCRIPTION,
    )
    keywords = env_value(
        "NVPN_APPSTORE_KEYWORDS",
        current.get("keywords") or DEFAULT_KEYWORDS,
    )
    if len(keywords) > 100:
        fail(f"NVPN_APPSTORE_KEYWORDS is {len(keywords)} characters; App Store limit is 100")
    attrs = {
        "description": description,
        "keywords": keywords,
        "promotionalText": env_value(
            "NVPN_APPSTORE_PROMOTIONAL_TEXT",
            current.get("promotionalText") or DEFAULT_PROMOTIONAL_TEXT,
        ),
        "supportUrl": env_value(
            "NVPN_APPSTORE_SUPPORT_URL",
            current.get("supportUrl") or DEFAULT_SUPPORT_URL,
        ),
        "whatsNew": env_value(
            "NVPN_APPSTORE_WHATS_NEW",
            current.get("whatsNew") or DEFAULT_WHATS_NEW,
        ),
    }
    marketing_url = env_value(
        "NVPN_APPSTORE_MARKETING_URL",
        current.get("marketingUrl") or DEFAULT_MARKETING_URL,
    )
    if marketing_url:
        attrs["marketingUrl"] = marketing_url
    return attrs


def whats_new_locked(body):
    for error in body.get("errors", []):
        detail = str(error.get("detail", ""))
        if "whatsNew" in detail and error.get("code") in {"STATE_ERROR", "ENTITY_ERROR.ATTRIBUTE.INVALID"}:
            return True
    return False


def ensure_localization(version_id):
    existing = None
    for localization in version_localizations(version_id):
        if localization.get("attributes", {}).get("locale") == LOCALE:
            existing = localization
            break

    attrs = metadata_attrs(existing)
    if existing:
        status, body = request(
            "PATCH",
            f"appStoreVersionLocalizations/{existing['id']}",
            body={
                "data": {
                    "type": "appStoreVersionLocalizations",
                    "id": existing["id"],
                    "attributes": attrs,
                }
            },
        )
        if not (200 <= status < 300) and whats_new_locked(body) and "whatsNew" in attrs:
            attrs.pop("whatsNew", None)
            print("App Store localization state does not allow whatsNew; retrying without it")
            status, body = request(
                "PATCH",
                f"appStoreVersionLocalizations/{existing['id']}",
                body={
                    "data": {
                        "type": "appStoreVersionLocalizations",
                        "id": existing["id"],
                        "attributes": attrs,
                    }
                },
            )
        return require_ok(status, body, "Update App Store localization").get("data")

    attrs["locale"] = LOCALE
    status, body = request(
        "POST",
        "appStoreVersionLocalizations",
        body={
            "data": {
                "type": "appStoreVersionLocalizations",
                "attributes": attrs,
                "relationships": {
                    "appStoreVersion": {
                        "data": {"type": "appStoreVersions", "id": version_id}
                    }
                },
            }
        },
    )
    if not (200 <= status < 300) and whats_new_locked(body) and "whatsNew" in attrs:
        attrs.pop("whatsNew", None)
        print("App Store localization state does not allow whatsNew; retrying without it")
        status, body = request(
            "POST",
            "appStoreVersionLocalizations",
            body={
                "data": {
                    "type": "appStoreVersionLocalizations",
                    "attributes": attrs,
                    "relationships": {
                        "appStoreVersion": {
                            "data": {"type": "appStoreVersions", "id": version_id}
                        }
                    },
                }
            },
        )
    return require_ok(status, body, "Create App Store localization").get("data")


def app_infos(app_id):
    return get_all(
        f"apps/{app_id}/appInfos",
        {
            "fields[appInfos]": (
                "state,appStoreState,appStoreAgeRating,appInfoLocalizations,"
                "ageRatingDeclaration,primaryCategory"
            ),
            "limit": "200",
        },
    )


def ensure_app_info(app_id):
    infos = app_infos(app_id)
    editable = [
        info
        for info in infos
        if (
            info.get("attributes", {}).get("state")
            in {
                "PREPARE_FOR_SUBMISSION",
                "DEVELOPER_REJECTED",
                "REJECTED",
                "REPLACED_WITH_NEW_INFO",
            }
            or info.get("attributes", {}).get("appStoreState")
            in {"PREPARE_FOR_SUBMISSION", "DEVELOPER_REJECTED", "REJECTED"}
        )
    ]
    if editable:
        return editable[0]
    if infos:
        return infos[0]
    fail("No App Info record is visible for the app")


def app_info_localizations(app_info_id):
    return get_all(
        f"appInfos/{app_info_id}/appInfoLocalizations",
        {
            "fields[appInfoLocalizations]": (
                "locale,name,subtitle,privacyPolicyUrl,privacyChoicesUrl,privacyPolicyText"
            ),
            "limit": "200",
        },
    )


def ensure_app_info_localization(app_info_id):
    existing = None
    for localization in app_info_localizations(app_info_id):
        if localization.get("attributes", {}).get("locale") == LOCALE:
            existing = localization
            break
    if existing is None:
        localizations = app_info_localizations(app_info_id)
        existing = localizations[0] if localizations else None

    attrs = existing.get("attributes", {}) if existing else {}
    localization_attrs = {
        "name": required_metadata_value(
            "NVPN_APPSTORE_APP_NAME",
            attrs.get("name"),
            "app name",
            "Nostr VPN",
        ),
        "privacyPolicyUrl": required_metadata_value(
            "NVPN_APPSTORE_PRIVACY_URL",
            attrs.get("privacyPolicyUrl"),
            "privacy policy URL",
            DEFAULT_PRIVACY_URL,
        ),
    }
    subtitle = env_value("NVPN_APPSTORE_SUBTITLE", attrs.get("subtitle") or "")
    if subtitle:
        localization_attrs["subtitle"] = subtitle
    privacy_choices_url = env_value(
        "NVPN_APPSTORE_PRIVACY_CHOICES_URL",
        attrs.get("privacyChoicesUrl") or "",
    )
    if privacy_choices_url:
        localization_attrs["privacyChoicesUrl"] = privacy_choices_url

    if existing:
        status, body = request(
            "PATCH",
            f"appInfoLocalizations/{existing['id']}",
            body={
                "data": {
                    "type": "appInfoLocalizations",
                    "id": existing["id"],
                    "attributes": localization_attrs,
                }
            },
        )
        return require_ok(status, body, "Update App Info localization").get("data")

    localization_attrs["locale"] = LOCALE
    status, body = request(
        "POST",
        "appInfoLocalizations",
        body={
            "data": {
                "type": "appInfoLocalizations",
                "attributes": localization_attrs,
                "relationships": {
                    "appInfo": {"data": {"type": "appInfos", "id": app_info_id}}
                },
            }
        },
    )
    return require_ok(status, body, "Create App Info localization").get("data")


def primary_category_id():
    category_id = env_value("NVPN_APPSTORE_CATEGORY_ID", DEFAULT_CATEGORY_ID)
    categories = get_all(
        "appCategories",
        {
            "filter[platforms]": "IOS",
            "limit": "200",
        },
    )
    for category in categories:
        if category.get("id") == category_id:
            return category_id
    fail(f"App Store category id {category_id} is not visible for iOS")


def ensure_primary_category(app_info_id):
    category_id = primary_category_id()
    status, body = request(
        "PATCH",
        f"appInfos/{app_info_id}",
        body={
            "data": {
                "type": "appInfos",
                "id": app_info_id,
                "relationships": {
                    "primaryCategory": {
                        "data": {"type": "appCategories", "id": category_id}
                    }
                },
            }
        },
    )
    require_ok(status, body, "Update App Info primary category")
    return category_id


def age_rating_declaration_id(app_info_id):
    status, body = request(
        "GET",
        f"appInfos/{app_info_id}/relationships/ageRatingDeclaration",
    )
    data = require_ok(status, body, "Read age rating declaration").get("data")
    if not data or not data.get("id"):
        fail("No age rating declaration is visible for the app info")
    return data["id"]


def ensure_age_rating(app_info_id):
    declaration_id = age_rating_declaration_id(app_info_id)
    attrs = {
        "advertising": False,
        "alcoholTobaccoOrDrugUseOrReferences": "NONE",
        "contests": "NONE",
        "gambling": False,
        "gamblingSimulated": "NONE",
        "gunsOrOtherWeapons": "NONE",
        "healthOrWellnessTopics": False,
        "lootBox": False,
        "medicalOrTreatmentInformation": "NONE",
        "messagingAndChat": False,
        "parentalControls": False,
        "profanityOrCrudeHumor": "NONE",
        "ageAssurance": False,
        "sexualContentGraphicAndNudity": "NONE",
        "sexualContentOrNudity": "NONE",
        "horrorOrFearThemes": "NONE",
        "matureOrSuggestiveThemes": "NONE",
        # VPNs can route ordinary web traffic through user-configured exits.
        "unrestrictedWebAccess": True,
        "userGeneratedContent": False,
        "violenceCartoonOrFantasy": "NONE",
        "violenceRealisticProlongedGraphicOrSadistic": "NONE",
        "violenceRealistic": "NONE",
        "ageRatingOverrideV2": "NONE",
        "koreaAgeRatingOverride": "NONE",
    }
    status, body = request(
        "PATCH",
        f"ageRatingDeclarations/{declaration_id}",
        body={
            "data": {
                "type": "ageRatingDeclarations",
                "id": declaration_id,
                "attributes": attrs,
            }
        },
    )
    return require_ok(status, body, "Update age rating declaration").get("data")


def app_store_review_detail(version_id):
    status, body = request(
        "GET",
        f"appStoreVersions/{version_id}/appStoreReviewDetail",
        {
            "fields[appStoreReviewDetails]": (
                "contactFirstName,contactLastName,contactPhone,contactEmail,"
                "demoAccountName,demoAccountRequired,notes"
            )
        },
    )
    if status == 404:
        return None
    return require_ok(status, body, "Read App Review detail").get("data")


def review_detail_attrs(existing=None):
    current = existing.get("attributes", {}) if existing else {}
    return {
        "contactFirstName": required_metadata_value(
            "NVPN_APPSTORE_REVIEW_CONTACT_FIRST_NAME",
            current.get("contactFirstName"),
            "App Review contact first name",
            DEFAULT_REVIEW_CONTACT_FIRST,
        ),
        "contactLastName": required_metadata_value(
            "NVPN_APPSTORE_REVIEW_CONTACT_LAST_NAME",
            current.get("contactLastName"),
            "App Review contact last name",
            DEFAULT_REVIEW_CONTACT_LAST,
        ),
        "contactPhone": required_metadata_value(
            "NVPN_APPSTORE_REVIEW_CONTACT_PHONE",
            current.get("contactPhone"),
            "App Review contact phone",
            DEFAULT_REVIEW_CONTACT_PHONE,
        ),
        "contactEmail": required_metadata_value(
            "NVPN_APPSTORE_REVIEW_CONTACT_EMAIL",
            current.get("contactEmail"),
            "App Review contact email",
            DEFAULT_REVIEW_CONTACT_EMAIL,
        ),
        "demoAccountRequired": False,
        "notes": env_value(
            "NVPN_APPSTORE_REVIEW_NOTES",
            current.get("notes") or DEFAULT_REVIEW_NOTES,
        ),
    }


def ensure_review_detail(version_id):
    detail = app_store_review_detail(version_id)
    attrs = review_detail_attrs(detail)
    if detail:
        status, body = request(
            "PATCH",
            f"appStoreReviewDetails/{detail['id']}",
            body={
                "data": {
                    "type": "appStoreReviewDetails",
                    "id": detail["id"],
                    "attributes": attrs,
                }
            },
        )
        return require_ok(status, body, "Update App Review detail").get("data")

    status, body = request(
        "POST",
        "appStoreReviewDetails",
        body={
            "data": {
                "type": "appStoreReviewDetails",
                "attributes": attrs,
                "relationships": {
                    "appStoreVersion": {
                        "data": {"type": "appStoreVersions", "id": version_id}
                    }
                },
            }
        },
    )
    return require_ok(status, body, "Create App Review detail").get("data")


def ensure_content_rights(app_id):
    declaration = env_value(
        "NVPN_APPSTORE_CONTENT_RIGHTS_DECLARATION",
        DEFAULT_CONTENT_RIGHTS_DECLARATION,
    )
    status, body = request(
        "PATCH",
        f"apps/{app_id}",
        body={
            "data": {
                "type": "apps",
                "id": app_id,
                "attributes": {
                    "contentRightsDeclaration": declaration,
                },
            }
        },
    )
    return require_ok(status, body, "Update content rights declaration").get("data")


def price_territory():
    return env_value("NVPN_APPSTORE_PRICE_TERRITORY", DEFAULT_PRICE_TERRITORY)


def free_price_point(app_id):
    territory = price_territory()
    price_points = get_all(
        f"apps/{app_id}/appPricePoints",
        {
            "filter[territory]": territory,
            "fields[appPricePoints]": "customerPrice,proceeds,territory",
            "limit": "200",
        },
    )
    for price_point in price_points:
        price = price_point.get("attributes", {}).get("customerPrice")
        if price in {"0", "0.0", "0.00"}:
            return price_point
    fail(f"No free App Store price point is visible for territory {territory}")


def app_price_schedule_id(app_id):
    status, body = request("GET", f"apps/{app_id}/appPriceSchedule")
    if status == 404:
        return None
    data = require_ok(status, body, "Read app price schedule").get("data")
    return data.get("id") if data else None


def app_price_schedule_manual_prices(schedule_id):
    status, body = request(
        "GET",
        f"appPriceSchedules/{schedule_id}/manualPrices",
        {
            "fields[appPrices]": "startDate,endDate,appPricePoint",
            "limit": "200",
        },
    )
    if status == 404:
        return []
    return require_ok(status, body, "Read app price schedule manual prices").get("data", [])


def ensure_free_price_schedule(app_id):
    schedule_id = app_price_schedule_id(app_id)
    if schedule_id and app_price_schedule_manual_prices(schedule_id):
        return schedule_id

    territory = price_territory()
    price_point = free_price_point(app_id)
    local_price_id = "${free-price}"
    status, body = request(
        "POST",
        "appPriceSchedules",
        body={
            "data": {
                "type": "appPriceSchedules",
                "relationships": {
                    "app": {"data": {"type": "apps", "id": app_id}},
                    "baseTerritory": {
                        "data": {"type": "territories", "id": territory}
                    },
                    "manualPrices": {
                        "data": [{"type": "appPrices", "id": local_price_id}]
                    },
                },
            },
            "included": [
                {
                    "type": "appPrices",
                    "id": local_price_id,
                    "attributes": {},
                    "relationships": {
                        "appPricePoint": {
                            "data": {
                                "type": "appPricePoints",
                                "id": price_point["id"],
                            }
                        }
                    },
                }
            ],
        },
    )
    if status == 409:
        schedule_id = app_price_schedule_id(app_id)
        if schedule_id and app_price_schedule_manual_prices(schedule_id):
            return schedule_id
    data = require_ok(status, body, "Create free app price schedule").get("data")
    return data.get("id")


def find_build(app_id):
    builds = get_all(
        "builds",
        {
            "filter[app]": app_id,
            "filter[version]": BUILD_NUMBER,
            "fields[builds]": (
                "version,uploadedDate,processingState,buildAudienceType,"
                "usesNonExemptEncryption,expired"
            ),
            "limit": "20",
        },
    )
    for build in builds:
        attrs = build.get("attributes", {})
        if str(attrs.get("version")) == str(BUILD_NUMBER):
            return build
    return builds[0] if builds else None


def link_build(version_id, build):
    attrs = build.get("attributes", {})
    if attrs.get("processingState") != "VALID":
        fail(f"Build {BUILD_NUMBER} is {attrs.get('processingState')}, not VALID")
    if attrs.get("expired") is True:
        fail(f"Build {BUILD_NUMBER} is expired")
    status, body = request(
        "PATCH",
        f"appStoreVersions/{version_id}/relationships/build",
        body={"data": {"type": "builds", "id": build["id"]}},
    )
    require_ok(status, body, "Link App Store build")


def screenshot_sets(localization_id):
    return get_all(
        f"appStoreVersionLocalizations/{localization_id}/appScreenshotSets",
        {
            "fields[appScreenshotSets]": "screenshotDisplayType",
            "limit": "200",
        },
    )


def ensure_screenshot_set(localization_id, display_type):
    for screenshot_set in screenshot_sets(localization_id):
        if screenshot_set.get("attributes", {}).get("screenshotDisplayType") == display_type:
            return screenshot_set

    status, body = request(
        "POST",
        "appScreenshotSets",
        body={
            "data": {
                "type": "appScreenshotSets",
                "attributes": {"screenshotDisplayType": display_type},
                "relationships": {
                    "appStoreVersionLocalization": {
                        "data": {
                            "type": "appStoreVersionLocalizations",
                            "id": localization_id,
                        }
                    }
                },
            }
        },
    )
    return require_ok(status, body, f"Create screenshot set {display_type}").get("data")


def screenshots_for_set(set_id):
    return get_all(
        f"appScreenshotSets/{set_id}/appScreenshots",
        {
            "fields[appScreenshots]": "fileName,assetDeliveryState",
            "limit": "50",
        },
    )


def clear_screenshots(set_id):
    for screenshot in screenshots_for_set(set_id):
        status, body = request("DELETE", f"appScreenshots/{screenshot['id']}")
        require_ok(status, body, f"Delete screenshot {screenshot['id']}")


def reserve_screenshot(set_id, path):
    data = path.read_bytes()
    checksum = hashlib.md5(data).hexdigest()
    mime_type = mimetypes.guess_type(path.name)[0] or "image/png"
    status, body = request(
        "POST",
        "appScreenshots",
        body={
            "data": {
                "type": "appScreenshots",
                "attributes": {
                    "fileName": path.name,
                    "fileSize": len(data),
                },
                "relationships": {
                    "appScreenshotSet": {
                        "data": {"type": "appScreenshotSets", "id": set_id}
                    }
                },
            }
        },
    )
    screenshot = require_ok(status, body, f"Reserve screenshot {path.name}").get("data")
    operations = screenshot.get("attributes", {}).get("uploadOperations", [])
    if not operations:
        fail(f"No upload operations returned for {path}")
    for operation in operations:
        offset = int(operation.get("offset", 0))
        length = int(operation.get("length", len(data) - offset))
        operation.setdefault("requestHeaders", [])
        if not any(h.get("name", "").lower() == "content-type" for h in operation["requestHeaders"]):
            operation["requestHeaders"].append({"name": "Content-Type", "value": mime_type})
        upload_request(operation, data[offset : offset + length])

    status, body = request(
        "PATCH",
        f"appScreenshots/{screenshot['id']}",
        body={
            "data": {
                "type": "appScreenshots",
                "id": screenshot["id"],
                "attributes": {
                    "uploaded": True,
                    "sourceFileChecksum": checksum,
                },
            }
        },
    )
    return require_ok(status, body, f"Commit screenshot {path.name}").get("data")


def screenshot_state(screenshot_id):
    status, body = request(
        "GET",
        f"appScreenshots/{screenshot_id}",
        {"fields[appScreenshots]": "fileName,assetDeliveryState"},
    )
    screenshot = require_ok(status, body, "Read screenshot state").get("data")
    delivery = screenshot.get("attributes", {}).get("assetDeliveryState") or {}
    return delivery.get("state") or delivery.get("errors") or "UNKNOWN"


def wait_for_screenshots(screenshots):
    pending = {screenshot["id"]: screenshot for screenshot in screenshots}
    for _ in range(30):
        completed = []
        for screenshot_id in pending:
            state = screenshot_state(screenshot_id)
            if state == "COMPLETE":
                completed.append(screenshot_id)
            elif state == "FAILED":
                fail(f"Screenshot {screenshot_id} failed processing")
        for screenshot_id in completed:
            pending.pop(screenshot_id, None)
        if not pending:
            return
        time.sleep(4)
    print(
        "Warning: screenshot processing is still pending for "
        + ", ".join(pending.keys()),
        file=sys.stderr,
    )


def review_submissions(app_id):
    return get_all(
        f"apps/{app_id}/reviewSubmissions",
        {
            "filter[platform]": "IOS",
            "fields[reviewSubmissions]": "platform,state,submittedDate,appStoreVersionForReview",
            "include": "appStoreVersionForReview",
            "limit": "50",
        },
    )


def active_review_submission(app_id):
    active_states = {
        "READY_FOR_REVIEW",
        "WAITING_FOR_REVIEW",
        "IN_REVIEW",
        "UNRESOLVED_ISSUES",
        "CANCELING",
        "COMPLETING",
    }
    for submission in review_submissions(app_id):
        if submission.get("attributes", {}).get("state") in active_states:
            return submission
    return None


def create_review_submission(app_id):
    status, body = request(
        "POST",
        "reviewSubmissions",
        body={
            "data": {
                "type": "reviewSubmissions",
                "attributes": {"platform": "IOS"},
                "relationships": {
                    "app": {"data": {"type": "apps", "id": app_id}}
                },
            }
        },
    )
    if status == 409:
        existing = active_review_submission(app_id)
        if existing:
            return existing
    return require_ok(status, body, "Create review submission").get("data")


def add_review_submission_item(submission_id, version_id):
    status, body = request(
        "POST",
        "reviewSubmissionItems",
        body={
            "data": {
                "type": "reviewSubmissionItems",
                "relationships": {
                    "reviewSubmission": {
                        "data": {
                            "type": "reviewSubmissions",
                            "id": submission_id,
                        }
                    },
                    "appStoreVersion": {
                        "data": {
                            "type": "appStoreVersions",
                            "id": version_id,
                        }
                    },
                },
            }
        },
    )
    if status == 409:
        fail(
            "Create review submission item failed: HTTP 409\n"
            + json.dumps(body, indent=2)
        )
    return require_ok(status, body, "Create review submission item").get("data")


def submit_review_submission(app_id, version_id):
    submission = active_review_submission(app_id) or create_review_submission(app_id)
    state = submission.get("attributes", {}).get("state")
    if state in {"WAITING_FOR_REVIEW", "IN_REVIEW"}:
        print(f"App Store review submission already submitted: {state}")
        return submission
    if state in {"UNRESOLVED_ISSUES", "CANCELING", "COMPLETING"}:
        fail(f"App Store review submission is already active in state {state}")

    add_review_submission_item(submission["id"], version_id)
    status, body = request(
        "PATCH",
        f"reviewSubmissions/{submission['id']}",
        body={
            "data": {
                "type": "reviewSubmissions",
                "id": submission["id"],
                "attributes": {"submitted": True},
            }
        },
    )
    return require_ok(status, body, "Submit App Store review submission").get("data")


def upload_screenshots(localization_id):
    if not SCREENSHOT_ROOT.is_dir():
        fail(f"Screenshot directory not found: {SCREENSHOT_ROOT}")

    uploaded = []
    for display_dir in sorted(path for path in SCREENSHOT_ROOT.iterdir() if path.is_dir()):
        display_type = display_dir.name
        paths = sorted(
            path for path in display_dir.iterdir()
            if path.suffix.lower() in {".png", ".jpg", ".jpeg"}
        )
        if not paths:
            continue
        if len(paths) > 10:
            fail(f"{display_type} has {len(paths)} screenshots; App Store limit is 10")
        screenshot_set = ensure_screenshot_set(localization_id, display_type)
        clear_screenshots(screenshot_set["id"])
        print(f"Uploading {len(paths)} screenshot(s) for {display_type}")
        for path in paths:
            uploaded.append(reserve_screenshot(screenshot_set["id"], path))
    wait_for_screenshots(uploaded)
    return uploaded


app = find_app()
if app is None:
    fail(f"No App Store Connect app found for bundle {BUNDLE_ID}")

if ACTION == "status":
    print(f"App: {app.get('attributes', {}).get('name')} [{app['id']}]")
    for version in app_store_versions(app["id"]):
        attrs = version.get("attributes", {})
        print(
            f"  - {attrs.get('versionString')} {attrs.get('platform')} "
            f"{attrs.get('appStoreState')} [{version['id']}]"
        )
    raise SystemExit(0)

version = ensure_version(app["id"])
localization = ensure_localization(version["id"])
app_info = ensure_app_info(app["id"])
app_info_localization = ensure_app_info_localization(app_info["id"])
category_id = ensure_primary_category(app_info["id"])
age_rating = ensure_age_rating(app_info["id"])
review_detail = ensure_review_detail(version["id"])
content_rights = ensure_content_rights(app["id"])
price_schedule_id = ensure_free_price_schedule(app["id"])
build = find_build(app["id"])
if build is None:
    fail(f"Build {BUILD_NUMBER} is not visible in App Store Connect")
link_build(version["id"], build)
screenshots = upload_screenshots(localization["id"])
submission = None
if ACTION == "submit":
    submission = submit_review_submission(app["id"], version["id"])

print(f"Updated App Store draft {VERSION_NAME} for {BUNDLE_ID}")
print(f"Version: {version['id']}")
print(f"Localization: {localization['id']} ({LOCALE})")
print(
    f"App Info localization: {app_info_localization['id']} "
    f"({app_info_localization.get('attributes', {}).get('privacyPolicyUrl')})"
)
print(f"Primary category: {category_id}")
print(f"Age rating declaration: {age_rating['id']}")
print(f"App Review detail: {review_detail['id']}")
print(
    "Content rights: "
    f"{content_rights.get('attributes', {}).get('contentRightsDeclaration')}"
)
print(f"Price schedule: {price_schedule_id}")
print(f"Build: {BUILD_NUMBER} [{build['id']}]")
print(f"Screenshots uploaded: {len(screenshots)}")
if submission:
    print(
        "App Store review submission: "
        f"{submission['id']} "
        f"{submission.get('attributes', {}).get('state') or 'submitted'}"
    )
